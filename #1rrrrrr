  </div>
</header>

<!-- ─── MAIN ─── -->
<main class="page">
  <div id="app"></div>
</main>

<script>
// ═══════════════════════════════════════════════════════════════
// THEME
// ═══════════════════════════════════════════════════════════════
(function() {
  const saved = localStorage.getItem('spm-theme') || 'dark';
  document.documentElement.setAttribute('data-theme', saved);
})();

function setTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  localStorage.setItem('spm-theme', t);
  syncThemeButtons();
}

function syncThemeButtons() {
  const t = document.documentElement.getAttribute('data-theme');
  document.getElementById('opt-dark').classList.toggle('active', t === 'dark');
  document.getElementById('opt-light').classList.toggle('active', t === 'light');
}
syncThemeButtons();

// ═══════════════════════════════════════════════════════════════
// CLOCK
// ═══════════════════════════════════════════════════════════════
function updateClock() {
  const el = document.getElementById('tb-clock');
  if (!el) return;
  const now = new Date();
  el.textContent = now.toLocaleTimeString('en-US', {
    hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
  });
}
updateClock();
setInterval(updateClock, 1000);

// ═══════════════════════════════════════════════════════════════
// SEEDED RANDOM (stable across reloads)
// ═══════════════════════════════════════════════════════════════
function sr(seed) {
  const x = Math.sin(seed + 1) * 10000;
  return x - Math.floor(x);
}

// ═══════════════════════════════════════════════════════════════
// DATA LAYER
// ═══════════════════════════════════════════════════════════════
const STATES  = ['MI','NV','MS','GA','CMS','KY','TC','AR','OH','WI','WV'];
const STYPES  = [
  'Physician Fee Schedule', 'Outpatient Fee Schedule', 'Inpatient DRG Schedule',
  'ASC Payment Rates', 'DME Fee Schedule', 'Lab Fee Schedule'
];
const NOW = Date.now();

function generateSchedules() {
  const list = [];
  let id = 1;
  STATES.forEach((state, si) => {
    STYPES.forEach((type, ti) => {
      const seed = si * 6 + ti;
      const r  = sr(seed);
      const r2 = sr(seed + 100);
      const r3 = sr(seed + 200);
      const fileStatus = r > 0.85 ? 'not-found' : r > 0.78 ? 'checking' : 'available';
      const compStatus = r > 0.72 ? 'changes-found' : r > 0.45 ? 'no-changes' : r > 0.25 ? 'new-file' : 'pending';
      list.push({
        id:         `FS-${String(id).padStart(4,'0')}`,
        name:       `${state} ${type}`,
        state,
        fileStatus,
        compStatus,
        lastChecked:  new Date(NOW - r2 * 86400000),
        lastModified: r3 > 0.3 ? new Date(NOW - r3 * 604800000) : null,
        changeUrl:    compStatus === 'changes-found' ? `#dl-${id}` : null,
        prevVer:      '2026.Q1',
        curVer:       compStatus === 'changes-found' ? '2026.Q2' : '2026.Q1',
      });
      id++;
    });
  });
  return list;
}

const ALL = generateSchedules();

// portal-level summary
const PORTAL_DATA = STATES.map((st, si) => {
  const schedules = ALL.filter(s => s.state === st);
  const r = sr(si * 17);
  const status = r > 0.8 ? 'warn' : r > 0.9 ? 'error' : r > 0.75 ? 'check' : 'ok';
  return {
    abbr: st,
    status,
    count: schedules.length,
    changes: schedules.filter(s => s.compStatus === 'changes-found').length,
  };
});

// LOB definitions
const LOB_DEFS = [
  { id:'medicare',       name:'Medicare',       desc:'Medicare fee schedules and CMS reimbursement rates',  icon:'🏥',  clr:'#2e90fa', filter: s => s.name.includes('Physician') || s.name.includes('Outpatient') },
  { id:'medicaid',       name:'Medicaid',       desc:'State Medicaid programs and fee schedules',           icon:'🏛️',  clr:'#12b76a', filter: s => s.name.includes('Inpatient') || s.name.includes('ASC') },
  { id:'commercial',     name:'Commercial',     desc:'Commercial payer and managed care fee schedules',     icon:'💼',  clr:'#f79009', filter: s => s.name.includes('DME') || s.name.includes('Lab') },
  { id:'workers-comp',   name:"Workers' Comp",  desc:"State workers' compensation fee schedules",           icon:'⚕️',  clr:'#f04438', filter: (_,i) => i < 22 },
  { id:'auto-insurance', name:'Auto Insurance', desc:'Auto insurance medical fee schedules',                icon:'🚗',  clr:'#9e77ed', filter: (_,i) => i >= 22 && i < 44 },
  { id:'other',          name:'Other LOB',      desc:'Additional lines of business and specialty payers',   icon:'📋',  clr:'#06aed4', filter: (_,i) => i >= 44 },
];

const LOBS = LOB_DEFS.map(def => {
  const fs = ALL.filter(def.filter);
  return {
    ...def,
    schedules: fs,
    total:   fs.length,
    changes: fs.filter(s => s.compStatus === 'changes-found').length,
    avail:   fs.filter(s => s.fileStatus === 'available').length,
    lastSync: new Date(NOW - sr(LOB_DEFS.indexOf(def)) * 3600000),
    trend:   Array.from({length:8}, (_,i) => Math.round(2 + sr(LOB_DEFS.indexOf(def)*8+i) * 5)),
  };
});

// ═══════════════════════════════════════════════════════════════
// APP STATE
// ═══════════════════════════════════════════════════════════════
const S = {
  view: 'dashboard',    // 'dashboard' | 'detail'
  lobId: null,
  isRefreshing: false,
  lastRefresh: new Date(),
  search: '', fState: 'all', fFile: 'all', fComp: 'all',
};

function setState(patch) { Object.assign(S, patch); render(); }

// ═══════════════════════════════════════════════════════════════
// FORMATTERS
// ═══════════════════════════════════════════════════════════════
const fDate = d => !d ? '—' : d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
const fTime = d => !d ? '' : d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
const fDT   = d => !d ? '—' : `${fDate(d)} ${fTime(d)}`;
function fAgo(d) {
  if (!d) return '—';
  const s = (Date.now() - d) / 1000;
  if (s < 60)    return Math.round(s)+'s ago';
  if (s < 3600)  return Math.round(s/60)+'m ago';
  if (s < 86400) return Math.round(s/3600)+'h ago';
  return Math.round(s/86400)+'d ago';
}

// ═══════════════════════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════════════════════
const TOAST_ICONS = { info:'ℹ️', success:'✅', warning:'⚠️', error:'❌' };
function toast(title, msg='', type='info') {
  const c = document.getElementById('toasts');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `
    <div class="toast-stripe s-${type}"></div>
    <div class="toast-icon">${TOAST_ICONS[type]||'ℹ️'}</div>
    <div class="toast-body">
      <div class="toast-title">${title}</div>
      ${msg ? `<div class="toast-msg">${msg}</div>` : ''}
    </div>
    <div class="toast-bar s-${type}"></div>`;
  c.appendChild(el);
  setTimeout(() => el.remove(), 3300);
}

// ═══════════════════════════════════════════════════════════════
// SPARKLINE SVG
// ═══════════════════════════════════════════════════════════════
function sparkline(data, clr) {
  const W = 68, H = 22;
  const min = Math.min(...data), max = Math.max(...data);
  const rng = max - min || 1;
  const pts = data.map((v,i) => {
    const x = (i / (data.length-1)) * (W-4) + 2;
    const y = H - 3 - ((v-min)/rng) * (H-6);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  const last = pts.split(' ').pop().split(',');
  return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" fill="none">
    <polyline points="${pts}" stroke="${clr}" stroke-width="1.5"
      stroke-linejoin="round" stroke-linecap="round" opacity="0.7"/>
    <circle cx="${last[0]}" cy="${last[1]}" r="2.5" fill="${clr}"/>
  </svg>`;
}

// ═══════════════════════════════════════════════════════════════
// BADGE RENDERERS
// ═══════════════════════════════════════════════════════════════
function fileBadge(s) {
  const m = {
    'available': ['b-available',  '✓ Available'],
    'not-found': ['b-not-found',  '✗ Not Found'],
    'checking':  ['b-checking',   '↻ Checking'],
    'error':     ['b-error',      '⚠ Error'],
  };
  const [cls, lbl] = m[s] || ['b-not-compared','—'];
  return `<span class="badge ${cls}"><span class="badge-dot"></span>${lbl}</span>`;
}

function compBadge(s) {
  const m = {
    'no-changes':   ['b-no-changes', '— No Changes'],
    'changes-found':['b-changes',    '▲ Changes Found'],
    'pending':      ['b-pending',    '⏳ Pending'],
    'new-file':     ['b-new-file',   '★ New File'],
    'not-compared': ['b-not-compared','· Not Compared'],
  };
  const [cls, lbl] = m[s] || ['b-not-compared','—'];
  return `<span class="badge ${cls}"><span class="badge-dot"></span>${lbl}</span>`;
}

// ═══════════════════════════════════════════════════════════════
// RENDER — TOPBAR PORTALS
// ═══════════════════════════════════════════════════════════════
function renderPortalChips() {
  return PORTAL_DATA.map(p => `
    <div class="tb-portal-chip" title="${p.abbr}: ${p.changes} change${p.changes!==1?'s':''}">
      <span class="chip-dot dot-${p.status}"></span>
      ${p.abbr}
    </div>`).join('');
}

// ═══════════════════════════════════════════════════════════════
// RENDER — KPI STRIP
// ═══════════════════════════════════════════════════════════════
function renderKPIs() {
  const allFs = LOBS.flatMap(l => l.schedules);
  const total   = allFs.length;
  const changes = allFs.filter(s => s.compStatus === 'changes-found').length;
  const avail   = allFs.filter(s => s.fileStatus === 'available').length;
  const pending = allFs.filter(s => s.compStatus === 'pending').length;
  const availPct = Math.round(avail / total * 100);

  const cards = [
    {
      label: 'Total Fee Schedules', val: total, cls: 'v-accent',
      badge: '11 portals', badgeCls: 'kb-neutral',
      sub: `Across ${STATES.length} state portals`,
      pct: 100, barClr: 'var(--accent)',
    },
    {
      label: 'Changes Detected', val: changes, cls: 'v-amber',
      badge: `+${changes} today`, badgeCls: 'kb-amber',
      sub: `Requiring validation`,
      pct: Math.round(changes/total*100), barClr: 'var(--amber)',
    },
    {
      label: 'Files Available', val: avail, cls: 'v-green',
      badge: `${availPct}%`, badgeCls: 'kb-up',
      sub: `${total - avail} unavailable`,
      pct: availPct, barClr: 'var(--green)',
    },
    {
      label: 'Pending Comparison', val: pending, cls: '',
      badge: 'In queue', badgeCls: 'kb-neutral',
      sub: `Awaiting diff processing`,
      pct: Math.round(pending/total*100), barClr: 'var(--purple)',
    },
  ];

  return `<div class="kpi-grid">
    ${cards.map(c => `
      <div class="kpi-card">
        <div class="kpi-card-top">
          <div class="kpi-label">${c.label}</div>
          <div class="kpi-badge ${c.badgeCls}">${c.badge}</div>
        </div>
        <div class="kpi-value ${c.cls}">${c.val}</div>
        <div class="kpi-sub">${c.sub}</div>
        <div class="kpi-track">
          <div class="kpi-fill" style="width:${c.pct}%;background:${c.barClr}"></div>
        </div>
      </div>`).join('')}
  </div>`;
}

// ═══════════════════════════════════════════════════════════════
// RENDER — PORTAL STATUS PANEL
// ═══════════════════════════════════════════════════════════════
function renderPortalPanel() {
  return `
  <div class="portal-panel">
    <div class="sec-label">Portal Health — All 11 State Portals</div>
    <div class="portal-grid">
      ${PORTAL_DATA.map(p => `
        <div class="portal-tile">
          <div class="portal-abbr">${p.abbr}</div>
          <div class="portal-status-dot dot-${p.status}"></div>
          <div class="portal-count">${p.count} / ${p.changes}▲</div>
        </div>`).join('')}
    </div>
  </div>`;
}

// ═══════════════════════════════════════════════════════════════
// RENDER — LOB GRID
// ═══════════════════════════════════════════════════════════════
function renderLOBCard(lob) {
  const availPct = lob.total > 0 ? Math.round(lob.avail / lob.total * 100) : 0;
  const hasChanges = lob.changes > 0;
  return `
  <div class="lob-card" style="--lob-clr:${lob.clr}" onclick="navToLOB('${lob.id}')">
    <div class="lob-accent-bar"></div>
    <div class="lob-body">
      <div class="lob-head">
        <div class="lob-identity">
          <div class="lob-icon">${lob.icon}</div>
          <div>
            <div class="lob-name">${lob.name}</div>
            <div class="lob-desc">${lob.desc}</div>
          </div>
        </div>
        <div class="lob-pill ${hasChanges ? 'lob-pill-changes' : 'lob-pill-clear'}">
          ${hasChanges ? `▲ ${lob.changes}` : '✓ 0'}
        </div>
      </div>

      <div class="avail-row">
        <div class="avail-lbl">File Availability</div>
        <div class="avail-pct">${availPct}%</div>
      </div>
      <div class="avail-track">
        <div class="avail-fill" style="width:${availPct}%"></div>
      </div>

      <div class="lob-stats">
        <div class="lob-stat">
          <div class="lob-stat-val">${lob.total}</div>
          <div class="lob-stat-lbl">Schedules</div>
        </div>
        <div class="lob-stat">
          <div class="lob-stat-val" style="color:${hasChanges ? 'var(--amber)' : 'var(--green)'}">${lob.changes}</div>
          <div class="lob-stat-lbl">Changes</div>
        </div>
        <div class="lob-stat">
          <div class="lob-stat-val">${lob.avail}</div>
          <div class="lob-stat-lbl">Available</div>
        </div>
      </div>

      <div class="lob-footer">
        <div class="lob-sync-txt">🕐 ${fAgo(lob.lastSync)}</div>
        ${sparkline(lob.trend, lob.clr)}
      </div>
    </div>
  </div>`;
}

function renderDashboard() {
  const totalChanges = LOBS.reduce((s,l) => s+l.changes, 0);
  return `
  <div class="space-5">
    <div class="page-hdr">
      <div class="page-hdr-left">
        <div class="page-title">Fee Schedule Monitor</div>
        <div class="page-sub">
          Last refresh: ${fDT(S.lastRefresh)} &nbsp;·&nbsp;
          <span style="color:var(--amber);font-weight:600;">${totalChanges} active changes</span>
          &nbsp;·&nbsp; Monitoring 11 state portals
        </div>
      </div>
      <div class="page-actions">
        <button class="btn btn-ghost btn-sm" onclick="handleExport()">↓ Export Report</button>
        <button class="btn btn-surface btn-sm" onclick="toast('Settings','Panel coming soon','info')">⚙ Settings</button>
      </div>
    </div>

    ${renderKPIs()}
    ${renderPortalPanel()}

    <div>
      <div class="sec-label">Lines of Business — 6 Categories</div>
      <div class="lob-grid">${LOBS.map(renderLOBCard).join('')}</div>
    </div>
  </div>`;
}

// ═══════════════════════════════════════════════════════════════
// RENDER — DETAIL VIEW
// ═══════════════════════════════════════════════════════════════
function getFiltered(lob) {
  return lob.schedules.filter(s => {
    const q = S.search.toLowerCase();
    if (q && !s.name.toLowerCase().includes(q) && !s.state.toLowerCase().includes(q) && !s.id.toLowerCase().includes(q)) return false;
    if (S.fState !== 'all' && s.state !== S.fState) return false;
    if (S.fFile  !== 'all' && s.fileStatus !== S.fFile)   return false;
    if (S.fComp  !== 'all' && s.compStatus !== S.fComp)   return false;
    return true;
  });
}

function renderDetailKPIs(lob, rows) {
  const changes  = rows.filter(s => s.compStatus === 'changes-found').length;
  const avail    = rows.filter(s => s.fileStatus === 'available').length;
  const notFound = rows.filter(s => s.fileStatus === 'not-found').length;
  const pending  = rows.filter(s => s.compStatus === 'pending').length;
  const cards = [
    { label:'Total Schedules', val:rows.length, cls:'',        badge:'filtered', badgeCls:'kb-neutral', barClr:'var(--accent)',  pct:rows.length/lob.total*100 },
    { label:'Changes Found',   val:changes,     cls:'v-amber', badge:'▲ delta',  badgeCls:'kb-amber',   barClr:'var(--amber)',   pct:rows.length?changes/rows.length*100:0 },
    { label:'Files Available', val:avail,        cls:'v-green', badge:`${rows.length?Math.round(avail/rows.length*100):0}%`, badgeCls:'kb-up', barClr:'var(--green)', pct:rows.length?avail/rows.length*100:0 },
    { label:'Not Found',       val:notFound,     cls:notFound>0?'v-red':'', badge:'missing', badgeCls:notFound>0?'kb-down':'kb-neutral', barClr:'var(--red)', pct:rows.length?notFound/rows.length*100:0 },
  ];
  return `<div class="kpi-grid">
    ${cards.map(c => `
      <div class="kpi-card">
        <div class="kpi-card-top">
          <div class="kpi-label">${c.label}</div>
          <div class="kpi-badge ${c.badgeCls}">${c.badge}</div>
        </div>
        <div class="kpi-value ${c.cls}">${c.val}</div>
        <div class="kpi-track">
          <div class="kpi-fill" style="width:${c.pct}%;background:${c.barClr}"></div>
        </div>
      </div>`).join('')}
  </div>`;
}

function renderFilters(lob, rows) {
  return `
  <div class="filter-bar">
    <div class="filter-search">
      <span class="filter-search-ic">🔍</span>
      <input class="f-input" type="text" placeholder="Search by name, state, or ID…"
        value="${S.search.replace(/"/g,'&quot;')}"
        oninput="setState({search:this.value})"/>
    </div>
    <select class="f-select" onchange="setState({fState:this.value})">
      <option value="all">All States</option>
      ${STATES.map(st => `<option value="${st}"${S.fState===st?' selected':''}>${st}</option>`).join('')}
    </select>
    <select class="f-select" onchange="setState({fFile:this.value})">
      <option value="all">All File Statuses</option>
      <option value="available"${S.fFile==='available'?' selected':''}>Available</option>
      <option value="not-found"${S.fFile==='not-found'?' selected':''}>Not Found</option>
      <option value="checking"${S.fFile==='checking'?' selected':''}>Checking</option>
      <option value="error"${S.fFile==='error'?' selected':''}>Error</option>
    </select>
    <select class="f-select" onchange="setState({fComp:this.value})">
      <option value="all">All Comparison</option>
      <option value="changes-found"${S.fComp==='changes-found'?' selected':''}>Changes Found</option>
      <option value="no-changes"${S.fComp==='no-changes'?' selected':''}>No Changes</option>
      <option value="new-file"${S.fComp==='new-file'?' selected':''}>New File</option>
      <option value="pending"${S.fComp==='pending'?' selected':''}>Pending</option>
      <option value="not-compared"${S.fComp==='not-compared'?' selected':''}>Not Compared</option>
    </select>
    <div class="f-divider"></div>
    <div class="f-count"><strong>${rows.length}</strong> / ${lob.total} records</div>
    <button class="btn btn-ghost btn-xs"
      onclick="setState({search:'',fState:'all',fFile:'all',fComp:'all'})">✕ Clear</button>
  </div>`;
}

function renderTableRow(s) {
  const dlBtn = s.changeUrl
    ? `<button class="btn btn-success btn-xs" onclick="handleDownload('${s.id}',event)" title="Download change file">↓ Diff</button>`
    : `<button class="btn btn-ghost btn-xs" disabled>↓ Diff</button>`;
  return `
  <tr>
    <td>
      <div class="cell-name">${s.name}</div>
      <span class="cell-id">${s.id}</span>
    </td>
    <td><span class="state-tag">${s.state}</span></td>
    <td>${fileBadge(s.fileStatus)}</td>
    <td>${compBadge(s.compStatus)}</td>
    <td>
      <span class="ver-tag">${s.curVer}</span>
      ${s.prevVer !== s.curVer ? `<span class="ver-prev">← ${s.prevVer}</span>` : ''}
    </td>
    <td>
      <div class="date-cell">${fDate(s.lastChecked)}<span class="time-cell">${fTime(s.lastChecked)}</span></div>
    </td>
    <td>
      <div class="date-cell">${s.lastModified ? fDate(s.lastModified) : '—'}</div>
    </td>
    <td>
      <div class="row-actions">
        <button class="btn btn-ghost btn-xs" onclick="handleRefreshRow('${s.id}',event)" title="Refresh">↻</button>
        ${dlBtn}
        <button class="btn btn-ghost btn-xs" onclick="toast('Portal','Opening state portal…','info')" title="View portal">↗</button>
      </div>
    </td>
  </tr>`;
}

function renderTable(lob, rows) {
  return `
  <div class="table-card">
    <div class="table-scroll">
      <table class="data-table">
        <thead>
          <tr>
            <th>Schedule Name / ID</th>
            <th>State</th>
            <th>File Status</th>
            <th>Comparison</th>
            <th>Version</th>
            <th>Last Checked</th>
            <th>Last Modified</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          ${rows.length
            ? rows.map(renderTableRow).join('')
            : `<tr><td colspan="8">
                <div class="empty">
                  <div class="empty-icon">⬡</div>
                  <div class="empty-msg">No records match the current filters.</div>
                </div>
               </td></tr>`
          }
        </tbody>
      </table>
    </div>
    <div class="tbl-footer">
      <div class="tbl-footer-txt">
        Showing <strong>${rows.length}</strong> of <strong>${lob.total}</strong> fee schedules
      </div>
      <div class="tbl-footer-txt" style="color:var(--text-3)">
        Last sync: ${fDT(lob.lastSync)}
      </div>
    </div>
  </div>`;
}

function renderDetail(lob) {
  const rows = getFiltered(lob);
  return `
  <div class="space-5">
    <div class="breadcrumb">
      <span class="bc-link" onclick="navBack()">Dashboard</span>
      <span class="bc-sep">/</span>
      <span class="bc-cur">${lob.name}</span>
    </div>

    <div class="detail-hdr-card" style="--lob-clr:${lob.clr}">
      <div class="detail-hdr-accent"></div>
      <div class="detail-hdr-glow"></div>
      <div class="detail-identity">
        <button class="btn btn-surface btn-sm" onclick="navBack()">← Back</button>
        <div class="detail-icon">${lob.icon}</div>
        <div>
          <div class="detail-name">${lob.name}</div>
          <div class="detail-meta">${lob.desc} &nbsp;·&nbsp; ${lob.total} schedules &nbsp;·&nbsp; Last synced ${fDT(lob.lastSync)}</div>
        </div>
      </div>
      <div class="detail-actions">
        <button class="btn btn-ghost btn-sm" onclick="handleRefreshLOB('${lob.id}')">↻ Refresh All</button>
        <button class="btn btn-primary btn-sm" onclick="handleExport()">↓ Export</button>
      </div>
    </div>

    ${renderDetailKPIs(lob, rows)}
    ${renderFilters(lob, rows)}
    ${renderTable(lob, rows)}
  </div>`;
}

// ═══════════════════════════════════════════════════════════════
// MAIN RENDER
// ═══════════════════════════════════════════════════════════════
function render() {
  // sync theme buttons
  syncThemeButtons();

  // sync refresh button
  const rb = document.getElementById('refresh-btn');
  if (rb) {
    rb.disabled = S.isRefreshing;
    rb.innerHTML = S.isRefreshing ? `<span class="spin">↻</span> Refreshing…` : '↻ Refresh All';
  }

  // render portal chips
  const tc = document.getElementById('tb-portals');
  if (tc) tc.innerHTML = renderPortalChips();

  // render main content
  const app = document.getElementById('app');
  if (S.view === 'detail' && S.lobId) {
    const lob = LOBS.find(l => l.id === S.lobId);
    if (lob) { app.innerHTML = renderDetail(lob); return; }
  }
  app.innerHTML = renderDashboard();
}

// ═══════════════════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════════════════
function navToLOB(lobId) {
  setState({ view:'detail', lobId, search:'', fState:'all', fFile:'all', fComp:'all' });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
function navBack() {
  setState({ view:'dashboard', lobId: null });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ═══════════════════════════════════════════════════════════════
// ACTION HANDLERS
// ═══════════════════════════════════════════════════════════════
function handleRefreshAll() {
  if (S.isRefreshing) return;
  setState({ isRefreshing: true });
  toast('Refreshing All Portals', 'Polling 11 state portals…', 'info');
  setTimeout(() => {
    LOBS.forEach(l => l.lastSync = new Date());
    setState({ isRefreshing: false, lastRefresh: new Date() });
    toast('Refresh Complete', 'All portals updated successfully.', 'success');
  }, 2200);
}

function handleRefreshLOB(lobId) {
  const lob = LOBS.find(l => l.id === lobId);
  if (!lob) return;
  toast(`Refreshing ${lob.name}`, 'Polling portal endpoints…', 'info');
  setTimeout(() => {
    lob.lastSync = new Date();
    toast(`${lob.name} Updated`, 'Schedules refreshed.', 'success');
    render();
  }, 1400);
}

function handleRefreshRow(id, e) {
  if (e) e.stopPropagation();
  toast(`Refreshing ${id}`, 'Checking portal…', 'info');
  setTimeout(() => toast(`${id} refreshed`, '', 'success'), 900);
}

function handleDownload(id, e) {
  if (e) e.stopPropagation();
  toast('Download Started', `Diff file for ${id} queued.`, 'success');
}

function handleExport() {
  toast('Export Queued', 'Generating report — check your downloads.', 'info');
}

// ═══════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════
render();
</script>
</body>
</html>
