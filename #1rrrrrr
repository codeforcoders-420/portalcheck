<div id="toasts"></div>

<!-- ─── TOPBAR ─── -->
<header class="topbar" id="topbar">
  <a class="logo">
    <div class="logo-mark">⬡</div>
    <span class="logo-text">PortalMonitor</span>
    <span class="logo-tag">v2.4</span>
  </a>

  <div class="tb-divider"></div>

  <div class="tb-live">
    <div class="live-dot"></div>
    Live
  </div>

  <div class="tb-divider"></div>

  <div class="tb-portals" id="tb-portals"><!-- rendered by JS --></div>

