    const sc=FS.filter(f=>f.lob===lob&&(!q||f.name.toLowerCase().includes(q)||lob.toLowerCase().includes(q)));
    if(q&&!sc.length)return;
    const op=ST.exp.has(lob),lc=FS.filter(f=>f.lob===lob).reduce((s,f)=>s+(cm[f.id]||0),0);
    html+=`<div><button class="lob-btn" data-lob="${lob}"><span class="lbl"><span class="ld ${DOTS[lob]}"></span>${lob}</span><span class="lbr">${lc?`<span class="lc">${lc}</span>`:''}<span class="lch${op?' open':''}">${ic('cr',12)}</span></span></button>`;
