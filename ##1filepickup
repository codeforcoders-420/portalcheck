    .dm{display:flex;align-items:center;gap:8px;margin-top:12px;position:relative;z-index:1;}
    .dv{font-family:'DM Mono',monospace;font-size:11px;color:#CBD5E1;background:rgba(255,255,255,.1);padding:2px 8px;border-radius:4px;}
