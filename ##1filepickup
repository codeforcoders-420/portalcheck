    .ig{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
    .ic2{background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;}
    .icl{display:flex;align-items:center;gap:5px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--fg-3);margin-bottom:4px;}
