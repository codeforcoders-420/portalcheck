  const en=ST.fBehs.filter(b=>b.enabled).length;
  let html=`<div class="be"><div class="beh"><div class="bet">${ic('set2',14)} Scrub Behaviors</div><span class="bec" id="bec">${en} of ${ST.fBehs.length} enabled</span></div><div id="blist">`;
  ST.fBehs.forEach((b,i)=>{html+=`<div class="br" data-bid="${b.id}"><div class="bnum">${i+1}</div><div class="binp"><input class="bil" placeholder="Rule label..." value="${esc(b.label)}" data-bid="${b.id}" data-f="label" /><input class="bid" placeholder="Description (optional)..." value="${esc(b.desc)}" data-bid="${b.id}" data-f="desc" /></div><div class="brr"><label class="tw"><input type="checkbox" ${b.enabled?'checked':''} data-bid="${b.id}" class="btog" /><span class="ts"></span></label><button class="bdl" data-bid="${b.id}">${ic('trash',13)}</button></div></div>`;});
  html+=`</div><div class="bar"><button class="adb" id="addb"><div class="adbi">${ic('plus',13)}</div> Add Rule</button></div></div>`;
  const w=document.getElementById('bewrap');w.innerHTML=html;
  w.querySelectorAll('.bil,.bid').forEach(el=>{el.addEventListener('input',()=>{const b=ST.fBehs.find(b=>b.id===el.dataset.bid);if(b)b[el.dataset.f]=el.value;});});
  w.querySelectorAll('.btog').forEach(c=>{c.addEventListener('change',()=>{const b=ST.fBehs.find(b=>b.id===c.dataset.bid);if(b){b.enabled=c.checked;const el=document.getElementById('bec');if(el){const e2=ST.fBehs.filter(b=>b.enabled).length;el.textContent=`${e2} of ${ST.fBehs.length} enabled`;}}});});
  w.querySelectorAll('.bdl').forEach(btn=>{btn.onclick=()=>{ST.fBehs=ST.fBehs.filter(b=>b.id!==btn.dataset.bid);renderBE();};});
  document.getElementById('addb').onclick=()=>{ST.fBehs=[...ST.fBehs,{id:uid(),label:'',desc:'',enabled:true}];renderBE();setTimeout(()=>{const ins=document.querySelectorAll('.bil');ins[ins.length-1]?.focus();},50);};
}
function renderMT(){
  let html=`<div class="mth"><span>Destination Field</span><span>Source Logic</span></div>`;
  MF.forEach(f=>{const val=esc(ST.fMap[f.key]||''),inp=f.multi?`<textarea class="mtta" data-mk="${f.key}" rows="${f.rows||2}">${val}</textarea>`:`<input class="mti" data-mk="${f.key}" value="${val}" />`;html+=`<div class="mtr"><div class="mtd"><div class="mtdi">${ic(f.icon,12)}</div><div><div class="mtrl">${f.label}</div><div class="mtdc">${f.dest}</div></div></div>${inp}</div>`;});
  document.getElementById('mtwrap').innerHTML=html;
  document.querySelectorAll('[data-mk]').forEach(el=>{el.addEventListener('input',()=>{ST.fMap[el.dataset.mk]=el.value;});});
}

