    .blb{font-size:12px;font-weight:600;color:var(--fg-2);line-height:1.3;}
    .blb .num{color:var(--fg-4);font-weight:400;margin-right:4px;}
    .bds{font-size:11px;color:var(--fg-3);margin-top:2px;line-height:1.45;}
    .mi2{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:12px;margin-bottom:8px;}
    .mih{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
    .mii{width:24px;height:24px;border-radius:var(--rs);background:var(--indigo-light);border:1px solid rgba(79,70,229,.15);display:flex;align-items:center;justify-content:center;}
    .mii svg{width:12px;height:12px;color:var(--indigo);}
    .mfn{font-size:12px;font-weight:700;color:var(--fg-2);}
    .mds{font-size:10px;font-family:'DM Mono',monospace;color:var(--fg-3);background:var(--surface-2);padding:1px 6px;border-radius:4px;margin-left:4px;}
    .mlo{font-size:12px;color:var(--fg-3);white-space:pre-line;line-height:1.55;padding-left:32px;}
    .ht{position:relative;padding-left:28px;}
    .ht::before{content:'';position:absolute;left:8px;top:0;bottom:0;width:1px;background:var(--border);}
    .hi{position:relative;margin-bottom:12px;}
    .hd{position:absolute;left:-22px;top:10px;width:16px;height:16px;border-radius:50%;border:2px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;}
    .hd.cu{border-color:var(--indigo);background:var(--indigo);}
    .hd.cu::after{content:'';width:6px;height:6px;border-radius:50%;background:#fff;}
    .hc{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:12px;}
    .hc.cu{background:var(--indigo-light);border-color:rgba(79,70,229,.2);}
    .hct{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
    .hv{font-family:'DM Mono',monospace;font-size:12px;font-weight:700;color:var(--fg-2);}
    .cb{font-size:9px;font-weight:700;background:var(--indigo);color:#fff;padding:1px 6px;border-radius:4px;}
    .hdt{font-size:11px;color:var(--fg-3);}
    .hby{font-size:11px;color:var(--fg-3);margin-bottom:4px;}
    .hn{font-size:12px;font-weight:500;color:var(--fg-2);}
    /* ── Behaviors Editor ── */
    .be{background:var(--surface);border:1px solid var(--border);border-radius:var(--rxl);overflow:hidden;box-shadow:var(--ss);}
    .beh{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;border-bottom:1px solid var(--border);background:var(--surface-2);}
    .bet{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:var(--fg-2);}
    .bet svg{width:14px;height:14px;color:var(--indigo);}
    .bec{font-size:11px;color:var(--fg-3);}
