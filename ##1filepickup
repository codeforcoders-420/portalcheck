    .br:last-child{border-bottom:none;}
    .br:hover{background:var(--surface-2);}
    .br:hover .bdl{opacity:1;}
    .bnum{width:22px;height:22px;border-radius:var(--rs);background:var(--surface-2);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;font-size:10px;font-weight:700;color:var(--fg-3);}
    .br:hover .bnum{background:var(--indigo-light);color:var(--indigo);}
    .binp{flex:1;min-width:0;display:flex;flex-direction:column;gap:4px;}
    .bil,.bid{width:100%;background:none;border:none;border-bottom:1px solid transparent;font-family:inherit;color:var(--fg);outline:none;padding:2px 0;transition:border-color .12s;}
    .bil{font-size:13px;font-weight:600;}
    .bid{font-size:12px;color:var(--fg-3);}
    .bil:hover,.bid:hover{border-bottom-color:var(--border);}
    .bil:focus,.bid:focus{border-bottom-color:var(--indigo);}
    .bil::placeholder,.bid::placeholder{color:var(--fg-4);font-weight:400;}
    .brr{display:flex;align-items:center;gap:8px;flex-shrink:0;margin-top:2px;}
    .bdl{width:26px;height:26px;border:none;background:none;cursor:pointer;border-radius:var(--rs);display:flex;align-items:center;justify-content:center;color:var(--fg-4);opacity:0;transition:.12s;}
    .bdl:hover{color:#EF4444;background:rgba(239,68,68,.08);}
    .bdl svg{width:13px;height:13px;}
    .bar{padding:10px 20px;border-top:1px dashed var(--border);background:var(--surface-2);}
    .adb{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:var(--indigo);cursor:pointer;background:none;border:none;font-family:inherit;padding:0;transition:.12s;}
    .adb:hover{color:var(--indigo-dark);}
    .adbi{width:24px;height:24px;border-radius:var(--rs);background:var(--indigo-light);display:flex;align-items:center;justify-content:center;}
    .adbi svg{width:13px;height:13px;}
    /* ── Full Form ── */
    .fo{position:fixed;inset:0;z-index:200;background:var(--bg);display:flex;flex-direction:column;}
    .fo.hidden{display:none;}
    .fhdr{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;background:var(--nav-bg);border-bottom:1px solid var(--border);flex-shrink:0;}
    .fhl{display:flex;align-items:center;gap:12px;}
    .fbb{width:34px;height:34px;border:none;background:none;cursor:pointer;border-radius:var(--r);display:flex;align-items:center;justify-content:center;color:var(--fg-4);transition:.12s;}
    .fbb:hover{background:var(--surface-2);color:var(--fg);}
    .fdv{width:1px;height:24px;background:var(--border);}
    .fico{width:32px;height:32px;border-radius:var(--r);background:linear-gradient(135deg,#4F46E5,#7C3AED);display:flex;align-items:center;justify-content:center;}
    .fico svg{width:15px;height:15px;color:#fff;}
    .ftl{font-size:14px;font-weight:700;color:var(--fg);}
    .fvh{font-size:11px;color:var(--fg-4);margin-top:2px;}
    .fhr{display:flex;gap:8px;}
    .fbdy{display:flex;flex:1;overflow:hidden;}
    .fnav{width:200px;background:var(--nav-bg);border-right:1px solid var(--border);padding:12px;flex-shrink:0;display:flex;flex-direction:column;}
    .fnt{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--fg-4);padding:8px 12px 6px;}
    .fnb{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:var(--r);border:none;background:none;cursor:pointer;font-family:inherit;font-size:13px;text-align:left;color:var(--fg-3);transition:.12s;margin-bottom:2px;width:100%;}
    .fnb:hover{background:var(--surface-2);color:var(--fg);}
    .fnb.active{background:var(--indigo-light);color:var(--indigo);font-weight:600;}
    .fnb svg{width:15px;height:15px;flex-shrink:0;}
    .fnb.active svg{color:var(--indigo);}.fnb:not(.active) svg{color:var(--fg-4);}
    .fntip{margin-top:auto;background:var(--indigo-light);border:1px solid rgba(79,70,229,.15);border-radius:var(--r);padding:12px;}
    .fntip-t{font-size:11px;font-weight:700;color:var(--indigo);margin-bottom:4px;}
    .fntip-s{font-size:11px;color:var(--fg-3);line-height:1.5;}
    .fcon{flex:1;overflow-y:auto;padding:32px;}
    .fcin{max-width:720px;margin:0 auto;}
    .fpt{font-size:18px;font-weight:700;color:var(--fg);margin-bottom:4px;}
    .fps{font-size:13px;color:var(--fg-3);margin-bottom:24px;}
    .fp{display:none;}
    .fp.active{display:block;}
    .fna{display:flex;justify-content:space-between;margin-top:24px;}
    .mtwrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--rxl);overflow:hidden;}
    .mth{display:grid;grid-template-columns:2fr 3fr;gap:16px;padding:12px 24px;border-bottom:1px solid var(--border);background:var(--surface-2);}
    .mth span{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--fg-3);}
    .mtr{display:grid;grid-template-columns:2fr 3fr;gap:16px;padding:14px 24px;border-bottom:1px solid var(--border-2);align-items:start;transition:background .12s;}
    .mtr:last-child{border-bottom:none;}
    .mtr:hover{background:var(--surface-2);}
    .mtd{display:flex;align-items:center;gap:8px;}
    .mtdi{width:26px;height:26px;border-radius:var(--rs);background:var(--indigo-light);border:1px solid rgba(79,70,229,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .mtdi svg{width:12px;height:12px;color:var(--indigo);}
    .mtrl{font-size:12px;font-weight:700;color:var(--fg-2);}
    .mtdc{font-size:10px;font-family:'DM Mono',monospace;color:var(--fg-3);}
    .mti,.mtta{width:100%;padding:7px 10px;border:1px solid var(--border);border-radius:var(--rs);background:var(--surface-2);font-size:12px;color:var(--fg);font-family:inherit;outline:none;transition:.15s;}
    .mti:focus,.mtta:focus{border-color:var(--indigo);background:var(--surface);box-shadow:0 0 0 2px rgba(79,70,229,.1);}
    .mtta{resize:none;line-height:1.5;}
    /* ── Copy modal ── */
    .scard{background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;margin-bottom:16px;}
    .scl{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--fg-3);margin-bottom:4px;}
    .scn{font-size:13px;font-weight:600;color:var(--fg);margin-bottom:2px;}
    .scm{font-size:11px;font-family:'DM Mono',monospace;color:var(--fg-3);}
    .lpk{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;}
    .lpb{display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:20px;border:1px solid var(--border);background:var(--surface-2);font-size:11px;font-weight:700;cursor:pointer;font-family:inherit;transition:.12s;color:var(--fg-3);}
    .lpb.sel{border-color:var(--indigo)!important;}
    .acs{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:4px;}
    .ac{padding:12px 14px;border-radius:var(--r);border:1px solid var(--border);background:var(--surface-2);cursor:pointer;transition:.12s;}
    .ac.sel{border-color:var(--indigo);background:var(--indigo-light);}
    .acn{font-size:13px;font-weight:600;color:var(--fg-2);text-transform:capitalize;}
    .ac.sel .acn{color:var(--indigo);}
    .acd{font-size:11px;color:var(--fg-3);margin-top:2px;line-height:1.4;}
    /* ── Import ── */
    .dz{border:2px dashed var(--border);border-radius:var(--rl);padding:40px 24px;text-align:center;cursor:pointer;transition:.15s;}
    .dz:hover,.dz.drag{border-color:var(--indigo);background:var(--indigo-light);}
    .dzi{width:56px;height:56px;border-radius:var(--rl);background:var(--surface-2);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;transition:background .15s;}
    .dz:hover .dzi,.dz.drag .dzi{background:rgba(79,70,229,.12);}
    .dzi svg{width:24px;height:24px;color:var(--fg-3);}
    .dzt{font-size:13px;font-weight:600;color:var(--fg-2);margin-bottom:4px;}
    .dzs{font-size:12px;color:var(--fg-3);}
    .fhint{background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);border-radius:var(--r);padding:12px 14px;margin-top:14px;}
    .fht{font-size:11px;font-weight:700;color:#D97706;display:flex;align-items:center;gap:5px;margin-bottom:8px;}
    .fht svg{width:12px;height:12px;}
    .frs{display:flex;flex-direction:column;gap:4px;}
    .fr{font-size:11px;font-family:'DM Mono',monospace;color:#92400E;background:rgba(245,158,11,.1);padding:4px 8px;border-radius:4px;}
    body.dark .fr{color:#FCD34D;}
    .pld{display:flex;align-items:center;gap:10px;padding:12px 16px;background:var(--indigo-light);border:1px solid rgba(79,70,229,.15);border-radius:var(--r);margin-top:14px;}
    .sp2{width:18px;height:18px;border:2px solid rgba(79,70,229,.2);border-top-color:var(--indigo);border-radius:50%;animation:spin .7s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}
    .pld p{font-size:13px;font-weight:500;color:var(--indigo);}
    .perr{display:flex;align-items:flex-start;gap:8px;padding:12px 16px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.15);border-radius:var(--r);margin-top:14px;}
    .perr svg{width:14px;height:14px;color:#EF4444;flex-shrink:0;margin-top:1px;}
    .perr p{font-size:13px;color:#DC2626;}
    .pok{display:flex;align-items:center;gap:8px;padding:12px 16px;background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.15);border-radius:var(--r);margin-bottom:16px;}
    .pok svg{width:15px;height:15px;color:#059669;flex-shrink:0;}
    .pok p{font-size:13px;font-weight:500;color:#059669;}
    .pvl{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--fg-3);margin-bottom:6px;}
    .pvv{font-size:13px;font-weight:600;color:var(--fg);background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r);padding:8px 12px;margin-bottom:14px;}
    .pvlist{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;}
    .pvitem{display:flex;align-items:flex-start;gap:10px;padding:8px 12px;border-bottom:1px solid var(--border-2);}
    .pvitem:last-child{border-bottom:none;}
    .pvn{font-size:10px;font-weight:700;color:var(--fg-3);width:18px;flex-shrink:0;margin-top:1px;}
    .pvlbl{font-size:12px;font-weight:600;color:var(--fg-2);}
    .pvdsc{font-size:11px;color:var(--fg-3);margin-top:1px;}
    .bkl{display:inline-flex;align-items:center;gap:4px;font-size:12px;color:var(--fg-3);cursor:pointer;background:none;border:none;font-family:inherit;margin-top:10px;transition:color .12s;}
    .bkl:hover{color:var(--fg);}
    .bkl svg{width:12px;height:12px;}
    .iab{display:flex;align-items:flex-start;gap:10px;padding:12px 16px;background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);border-radius:var(--r);margin-bottom:16px;}
    .iab svg{width:14px;height:14px;color:#D97706;flex-shrink:0;margin-top:1px;}
    .iab p{font-size:12px;color:#92400E;line-height:1.55;}
    body.dark .iab p{color:#FCD34D;}
    ::-webkit-scrollbar{width:5px;height:5px;}
    ::-webkit-scrollbar-thumb{background:var(--border);border-radius:8px;}
  </style>
</head>
