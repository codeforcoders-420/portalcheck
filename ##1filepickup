async function handleImpFile(file){
  document.getElementById('ps').innerHTML=`<div class="pld"><div class="sp2"></div><p>Parsing ${esc(file.name)}...</p></div>`;
  try{const r=await parseXL(file);r.fileName=file.name;ST.impParsed=r;ST.impStep='preview';renderImp();}
  catch(e){document.getElementById('ps').innerHTML=`<div class="perr">${ic('alt',14)}<p>Could not parse. Ensure it is a valid .xlsx, .xls, or .csv file.</p></div>`;}
}
async function parseXL(file){return new Promise((resolve,reject)=>{const reader=new FileReader();reader.onload=e=>{try{const data=new Uint8Array(e.target.result),wb=XLSX.read(data,{type:'array'}),ws=wb.Sheets[wb.SheetNames[0]],rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});let title='';const behaviors=[],colMap={};let inM=false;const KEYS={'procedure_code':'procedureCode','procedure code':'procedureCode','modifier':'modifier','modifier_2':'modifier2','modifier 2':'modifier2','modifier_3':'modifier3','modifier 3':'modifier3','modifier_4':'modifier4','modifier 4':'modifier4','effective_date':'effectiveDate','effective date':'effectiveDate','termination_date':'terminationDate','termination date':'terminationDate','reimbursement_method':'reimbursementMethod','reimbursement method':'reimbursementMethod','allowed':'allowed'};for(let i=0;i<rows.length;i++){const row=rows[i],cA=String(row[0]||'').trim(),cB=String(row[1]||'').trim();if(!cA)continue;if(!title){title=cA.replace(/^scrub rule\s*[-–]\s*/i,'').trim()||cA;continue;}if(/column\s*mapping/i.test(cA)){inM=true;continue;}if(!inM){const c=cA.replace(/^\d+[\.\s]+/,'').trim();if(c.length>4)behaviors.push({id:uid(),label:c,desc:cB||'',enabled:true});}else{const fk=cA.replace(/^\d+[\.\s]+/,'').trim().toLowerCase().replace(/[^a-z0-9 _]/g,'').trim(),mk=KEYS[fk];if(mk){let desc=cB,j=i+1;while(j<rows.length){const nA=String(rows[j][0]||'').trim(),nB=String(rows[j][1]||'').trim();if(!nA&&nB){desc+='\n'+nB;j++;}else if(nA&&!/^\d+[\.\s]/.test(nA)){desc+='\n'+nA;j++;}else break;}colMap[mk]=desc.trim();}}}resolve({title:title||'Imported Rule',behaviors,columnMapping:colMap});}catch(err){reject(err);}};reader.onerror=reject;reader.readAsArrayBuffer(file);});}

