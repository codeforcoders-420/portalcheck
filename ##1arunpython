                                <p class="text-sm">${msg.content}</p>
                            </div>
                        </div>
                    `;
                }
            });
            
            container.innerHTML = html;
            container.scrollTop = container.scrollHeight;
        }

        function sendMessage() {
            const input = document.getElementById('user-input');
            const message = input.value.trim();
            
            if (!message || isProcessing) return;
            
            aiMessages.push({ role: 'user', content: message });
            input.value = '';
            renderChatMessages();
            
            isProcessing = true;
            setTimeout(() => {
                const response = generateAIResponse(message);
                aiMessages.push({ role: 'assistant', content: response });
                renderChatMessages();
                isProcessing = false;
            }, 1000);
        }

        function generateAIResponse(userMessage) {
            const lowerMessage = userMessage.toLowerCase();
            const app = applications.find(a => a.id === activeAppId);
            
            if (!app) return 'I\'m here to help! Ask me about the current application.';
            
            // Application-specific responses
            if (activeAppId === 1) {
                if (lowerMessage.includes('format') || lowerMessage.includes('file')) {
                    return 'The Change File Generator accepts CSV, XLS, and XLSX files. Make sure your source file includes a Fee Schedule ID in the header row.';
                } else if (lowerMessage.includes('scrub') || lowerMessage.includes('analysis')) {
                    return 'The scrub analysis validates your data against business rules, checks for duplicates, and identifies any formatting issues. Results are saved to the output folder with a detailed report.';
                }
            } else if (activeAppId === 2) {
                if (lowerMessage.includes('format') || lowerMessage.includes('file')) {
                    return 'You can compare CSV, XLS, XLSX, and TXT files. Both files should have a similar structure for meaningful comparison results.';
                } else if (lowerMessage.includes('difference') || lowerMessage.includes('compare')) {
                    return 'The comparison identifies added rows, deleted rows, and modified values. Results show line-by-line differences with color coding for easy identification.';
                }
            } else if (activeAppId === 3) {
                if (lowerMessage.includes('dt') || lowerMessage.includes('file')) {
                    return 'DT File Generate processes 1-50 Excel files at once. Specify the row and column numbers for data extraction, and select the appropriate type (Default, GA, IN, or KY).';
                }
            } else if (activeAppId === 4) {
                if (lowerMessage.includes('database') || lowerMessage.includes('environment')) {
                    return 'Select one source environment and multiple target environments for comparison. The system will identify schema differences, data discrepancies, and configuration variations.';
                }
            } else if (activeAppId === 10) {
                if (lowerMessage.includes('sql') || lowerMessage.includes('query')) {
                    return 'Select a pre-stored SQL query from the list and choose your target environment. Results are automatically exported to Excel format in the output folder.';
                }
            }
            
            return `I can help you with ${app.name}. Ask me about file formats, processing steps, or troubleshooting common issues.`;
        }

