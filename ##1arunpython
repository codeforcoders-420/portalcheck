<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TFS Workflow Applications</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #334155; border-radius: 20px; }
        .loader { border: 3px solid #f3f3f3; border-bottom-color: #2563eb; border-radius: 50%; width: 48px; height: 48px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .chat-container { scroll-behavior: smooth; }
        .file-drop-zone { transition: all 0.3s ease; }
        .file-drop-zone:hover { background-color: #f1f5f9; border-color: #2563eb; }
        .modal { display: none; }
        .modal.active { display: flex; }
        .app-completed { position: relative; }
        .app-completed::after { 
            content: ''; 
            position: absolute; 
            right: 8px; 
            top: 50%; 
            transform: translateY(-50%); 
            width: 8px; 
            height: 8px; 
            background-color: #10b981; 
            border-radius: 50%; 
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <div class="w-64 bg-white border-r border-gray-200 flex flex-col">
            <div class="p-6 border-b border-gray-200">
                <h1 class="text-xl font-bold text-gray-900">TFS Workflow</h1>
                <p class="text-sm text-gray-500 mt-1">Applications Portal</p>
            </div>
            <nav class="flex-1 p-4 overflow-y-auto custom-scrollbar" id="sidebar">
                <!-- Sidebar items rendered by JavaScript -->
            </nav>
        </div>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <div class="bg-white border-b border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900" id="app-title">Select an Application</h2>
                        <p class="text-sm text-gray-500 mt-1" id="app-description">Choose from the sidebar</p>
                    </div>
                    <div class="flex gap-3">
                        <div class="text-right">
                            <div class="text-xs text-gray-500">Config Last Updated</div>
                            <div class="inline-block px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded mt-1">2024-01-15 14:30</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-gray-500">Config Last Updated By</div>
                            <div class="inline-block px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded mt-1">John Smith</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-gray-500">PROD Last Updated</div>
                            <div class="inline-block px-2 py-1 bg-green-100 text-green-700 text-xs rounded mt-1">2024-01-14 09:15</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-gray-500">PROD Last Updated By</div>
                            <div class="inline-block px-2 py-1 bg-green-100 text-green-700 text-xs rounded mt-1">Jane Doe</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content Area -->
            <div class="flex-1 overflow-y-auto p-6 custom-scrollbar">
                <div id="app-content" class="max-w-4xl mx-auto">
                    <div class="text-center text-gray-400 py-12">
                        <i data-lucide="inbox" class="w-16 h-16 mx-auto mb-4"></i>
                        <p>Select an application from the sidebar to get started</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- AI Modal -->
    <div id="ai-modal" class="modal fixed inset-0 bg-black bg-opacity-50 items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl mx-4 flex flex-col" style="max-height: 80vh;">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <div class="flex items-center gap-2">
                    <i data-lucide="sparkles" class="w-5 h-5 text-blue-600"></i>
                    <h3 class="text-lg font-semibold text-gray-900">AI Assistant</h3>
                </div>
                <button onclick="closeAIModal()" class="text-gray-400 hover:text-gray-600">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 custom-scrollbar chat-container">
                <!-- Chat messages rendered by JavaScript -->
            </div>
            <div class="p-4 border-t border-gray-200">
                <div class="flex gap-2">
                    <input 
                        type="text" 
                        id="user-input" 
                        placeholder="Ask me anything..." 
                        class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                        onkeypress="if(event.key === 'Enter') sendMessage()"
                    >
                    <button 
                        onclick="sendMessage()" 
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2"
                    >
                        <i data-lucide="send" class="w-4 h-4"></i>
                        Send
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Application data
        const applications = [
            {
                id: 1,
                name: 'Change File Generator',
                description: 'Generate change files from source data',
                icon: 'file-text',
                category: 'File Processing',
                folder: '/output/change_files'
            },
            {
                id: 2,
                name: 'File to File Compare',
                description: 'Compare two files and identify differences',
                icon: 'git-compare',
                category: 'Analysis',
                folder: '/output/comparisons'
            },
            {
                id: 3,
                name: 'DT File Generate',
                description: 'Generate DT files from multiple Excel sources',
                icon: 'file-spreadsheet',
                category: 'File Processing',
                folder: '/output/dt_files'
            },
            {
                id: 4,
                name: 'DB to DB Compare',
                description: 'Compare data between source and target environments',
                icon: 'database',
                category: 'Analysis',
                folder: '/output/db_compare'
            },
            {
                id: 5,
                name: 'Standard Change File Converter',
                description: 'Convert Excel to standard change file format',
                icon: 'refresh-cw',
                category: 'File Processing',
                folder: '/output/standard_change'
            },
            {
                id: 6,
                name: 'Peer Review Validator',
                description: 'Validate peer review files against environments',
                icon: 'shield-check',
                category: 'Validation',
                folder: '/output/peer_review'
            },
            {
                id: 7,
                name: 'IR Form Generator',
                description: 'Generate IR forms with classification details',
                icon: 'file-plus',
                category: 'Reporting',
                folder: '/output/ir_forms'
            },
            {
                id: 8,
                name: 'Impact Report Generator',
                description: 'Generate impact reports from data files',
                icon: 'file-bar-chart',
                category: 'Reporting',
                folder: '/output/impact_reports'
            },
            {
                id: 9,
                name: 'Impact Report Compare',
                description: 'Compare impact reports with claims data',
                icon: 'file-diff',
                category: 'Analysis',
                folder: '/output/ir_compare'
            },
            {
                id: 10,
                name: 'Standard SQL Queries',
                description: 'Execute pre-stored SQL queries on environments',
                icon: 'terminal',
                category: 'Database',
                folder: '/output/sql_results'
            },
            {
                id: 11,
                name: 'Upload Latest Files',
                description: 'Attach latest files to TFS with comments',
                icon: 'upload-cloud',
                category: 'File Management',
                folder: '/output/uploads'
            },
            {
                id: 12,
                name: 'Audit Trail',
                description: 'View audit logs and history',
                icon: 'history',
                category: 'Monitoring',
                folder: '/output/audit'
            }
        ];

        // Track which applications have files in their folders (mock state)
        const appFolderStatus = {
            1: false,
            2: false,
            3: false,
            4: false,
            5: false,
            6: false,
            7: false,
            8: false,
            9: false,
            10: false,
            11: false,
            12: false
        };

        let activeAppId = null;
        let selectedFile = null;
        let selectedFile1 = null;
        let selectedFile2 = null;
        let selectedFiles = [];
        let aiMessages = [];
        let isProcessing = false;

        // Initialize
        function init() {
            renderSidebar();
            lucide.createIcons();
        }

        // Render sidebar
        function renderSidebar() {
            const sidebar = document.getElementById('sidebar');
            const categories = [...new Set(applications.map(app => app.category))];
            
            let html = '';
            categories.forEach(category => {
                html += `<div class="mb-4">`;
                html += `<h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">${category}</h3>`;
                
                const categoryApps = applications.filter(app => app.category === category);
                categoryApps.forEach(app => {
                    const isActive = activeAppId === app.id;
                    const hasFiles = appFolderStatus[app.id];
                    const completedClass = hasFiles ? 'app-completed' : '';
                    html += `
                        <button 
                            onclick="switchApp(${app.id})"
                            class="w-full flex items-center gap-3 px-3 py-2 rounded-lg mb-1 transition-colors ${completedClass} ${
                                isActive 
                                    ? 'bg-blue-50 text-blue-600' 
                                    : hasFiles
                                    ? 'text-gray-700 hover:bg-gray-100 bg-green-50'
                                    : 'text-gray-700 hover:bg-gray-100'
                            }"
                        >
                            <i data-lucide="${app.icon}" class="w-4 h-4"></i>
                            <span class="text-sm">${app.name}</span>
                        </button>
                    `;
                });
                html += `</div>`;
            });
            
            sidebar.innerHTML = html;
            lucide.createIcons();
        }

        // Switch application
        function switchApp(id) {
            activeAppId = id;
            selectedFile = null;
            selectedFile1 = null;
            selectedFile2 = null;
            selectedFiles = [];
            renderSidebar();
            renderAppContent();
        }

        // Render application content
        function renderAppContent() {
            const app = applications.find(a => a.id === activeAppId);
            if (!app) return;

            document.getElementById('app-title').textContent = app.name;
            document.getElementById('app-description').textContent = app.description;

            const content = document.getElementById('app-content');

            if (activeAppId === 1) {
                // Application 1: Change File Generator
                content.innerHTML = `
                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Upload Source File</h3>
                        
                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Select File</label>
                            <div class="file-drop-zone border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer" onclick="document.getElementById('file-input-1').click()">
                                <i data-lucide="upload" class="w-12 h-12 mx-auto text-gray-400 mb-2"></i>
                                <p class="text-sm text-gray-600">Click to upload or drag and drop</p>
                                <p class="text-xs text-gray-400 mt-1">CSV, XLS, XLSX files supported</p>
                            </div>
                            <input type="file" id="file-input-1" class="hidden" accept=".csv,.xls,.xlsx" onchange="handleFileSelect(event)">
                            <div id="file-display-1" class="mt-3"></div>
                        </div>

                        <div id="fee-schedule-display" class="mb-6" style="display: none;">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Fee Schedule ID</label>
                            <div class="px-4 py-3 bg-blue-50 border border-blue-200 rounded-lg">
                                <span id="fee-schedule-id" class="text-blue-900 font-medium">FS-2024-001</span>
                            </div>
                        </div>

                        <div class="flex gap-3">
                            <button 
                                id="run-scrub-btn"
                                onclick="runScrubAnalysis()" 
                                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed flex items-center gap-2"
                                disabled
                            >
                                <i data-lucide="play" class="w-4 h-4"></i>
                                Run Scrub Analysis
                            </button>
                            <button 
                                onclick="openAIModal()" 
                                class="px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 flex items-center gap-2"
                            >
                                <i data-lucide="sparkles" class="w-4 h-4"></i>
                                Use GenAI
                            </button>
                        </div>

                        <div id="output-location-1" class="mt-6" style="display: none;">
                            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                                <div class="flex items-start gap-3">
                                    <i data-lucide="check-circle" class="w-5 h-5 text-green-600 mt-0.5"></i>
                                    <div>
                                        <h4 class="text-sm font-semibold text-green-900 mb-1">Processing Complete</h4>
                                        <p class="text-sm text-green-700">Output saved to: <span class="font-mono" id="output-path-1"></span></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            } else if (activeAppId === 2) {
                // Application 2: File to File Compare
                content.innerHTML = `
                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Upload Files to Compare</h3>
                        
                        <div class="grid grid-cols-2 gap-4 mb-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                                    <i data-lucide="file" class="w-4 h-4 text-blue-600"></i>
                                    File 1
                                </label>
                                <div class="file-drop-zone border-2 border-dashed border-blue-300 rounded-lg p-6 text-center cursor-pointer" onclick="document.getElementById('file-input-2a').click()">
                                    <i data-lucide="upload" class="w-12 h-12 mx-auto text-blue-400 mb-2"></i>
                                    <p class="text-sm text-gray-600">Click to upload</p>
                                    <p class="text-xs text-gray-400 mt-1">First file</p>
                                </div>
                                <input type="file" id="file-input-2a" class="hidden" accept=".csv,.xls,.xlsx,.txt" onchange="handleFile1Select(event)">
                                <div id="file-display-2a" class="mt-3"></div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                                    <i data-lucide="file" class="w-4 h-4 text-purple-600"></i>
                                    File 2
                                </label>
                                <div class="file-drop-zone border-2 border-dashed border-purple-300 rounded-lg p-6 text-center cursor-pointer" onclick="document.getElementById('file-input-2b').click()">
                                    <i data-lucide="upload" class="w-12 h-12 mx-auto text-purple-400 mb-2"></i>
                                    <p class="text-sm text-gray-600">Click to upload</p>
                                    <p class="text-xs text-gray-400 mt-1">Second file</p>
                                </div>
                                <input type="file" id="file-input-2b" class="hidden" accept=".csv,.xls,.xlsx,.txt" onchange="handleFile2Select(event)">
                                <div id="file-display-2b" class="mt-3"></div>
                            </div>
                        </div>

                        <div class="flex gap-3">
                            <button 
                                id="compare-files-btn"
                                onclick="compareFiles()" 
                                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed flex items-center gap-2"
                                disabled
                            >
                                <i data-lucide="git-compare" class="w-4 h-4"></i>
                                Compare Files
                            </button>
                            <button 
                                onclick="openAIModal()" 
                                class="px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 flex items-center gap-2"
                            >
                                <i data-lucide="sparkles" class="w-4 h-4"></i>
                                Use GenAI
                            </button>
                        </div>

                        <div id="output-location-2" class="mt-6" style="display: none;">
                            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                                <div class="flex items-start gap-3">
                                    <i data-lucide="check-circle" class="w-5 h-5 text-green-600 mt-0.5"></i>
                                    <div>
                                        <h4 class="text-sm font-semibold text-green-900 mb-1">Comparison Complete</h4>
                                        <p class="text-sm text-green-700">Differences report saved to: <span class="font-mono" id="output-path-2"></span></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            } else if (activeAppId === 3) {
                // Application 3: DT File Generate
                content.innerHTML = `
                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">DT File Generator</h3>
                        
                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Select Excel Files (1-50 files)</label>
                            <div class="file-drop-zone border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer" onclick="document.getElementById('file-input-3').click()">
                                <i data-lucide="upload" class="w-12 h-12 mx-auto text-gray-400 mb-2"></i>
                                <p class="text-sm text-gray-600">Click to upload multiple files</p>
                                <p class="text-xs text-gray-400 mt-1">Excel files (.xls, .xlsx)</p>
                            </div>
                            <input type="file" id="file-input-3" class="hidden" accept=".xls,.xlsx" multiple onchange="handleMultipleFilesSelect(event)">
                            <div id="file-display-3" class="mt-3"></div>
                        </div>

                        <div class="grid grid-cols-3 gap-4 mb-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Selection Type</label>
                                <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <option>Default</option>
                                    <option>GA</option>
                                    <option>IN</option>
                                    <option>KY</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Row #</label>
                                <input type="text" placeholder="Enter row number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Column Number</label>
                                <input type="text" placeholder="Enter column number" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                            </div>
                        </div>

                        <div class="flex gap-3">
                            <button 
                                onclick="generateDTFile()" 
                                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2"
                            >
                                <i data-lucide="file-output" class="w-4 h-4"></i>
                                Generate DT File
                            </button>
                            <button 
                                onclick="openAIModal()" 
                                class="px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 flex items-center gap-2"
                            >
                                <i data-lucide="sparkles" class="w-4 h-4"></i>
                                Use GenAI
                            </button>
                        </div>
                    </div>
                `;
            } else if (activeAppId === 4) {
                // Application 4: DB to DB Compare
                content.innerHTML = `
                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Database to Database Compare</h3>
                        
                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Comparison Type</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                                <option>PreDev</option>
                                <option>Post Dev</option>
                                <option>Post PROD</option>
                            </select>
                        </div>

                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-3">Source Environment (Select One)</label>
                            <div class="grid grid-cols-4 gap-3">
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="ModDev" class="text-blue-600">
                                    <span class="text-sm">ModDev</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="ModPROD" class="text-blue-600">
                                    <span class="text-sm">ModPROD</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="Dev" class="text-blue-600">
                                    <span class="text-sm">Dev</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="vDEV" class="text-blue-600">
                                    <span class="text-sm">vDEV</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="CFG" class="text-blue-600">
                                    <span class="text-sm">CFG</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="vCFG" class="text-blue-600">
                                    <span class="text-sm">vCFG</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="INT" class="text-blue-600">
                                    <span class="text-sm">INT</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="vINT" class="text-blue-600">
                                    <span class="text-sm">vINT</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="CRT" class="text-blue-600">
                                    <span class="text-sm">CRT</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="vCRT" class="text-blue-600">
                                    <span class="text-sm">vCRT</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="GLD" class="text-blue-600">
                                    <span class="text-sm">GLD</span>
                                </label>
                                <label class="flex items-center gap-2 p-3 border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                                    <input type="radio" name="source-env" value="PROD" class="text-blue-600">
                                    <span class="text-sm">PROD</span>
                                </label>
                            </div>
                        </div>

                        <div class="mb-6">
                            <div class="flex items-center justify-between mb-3">
                                <label class="block text-sm font-medium text-gray-700">Target Environments (Select Multiple)</label>
