    <script>
        // Get story ID from URL parameters
        const urlParams = new URLSearchParams(window.location.search);
        const storyId = urlParams.get('storyId') || 'STY-0000';
        const year = urlParams.get('year') || 'N/A';
        const lob = urlParams.get('lob') || 'N/A';
        const fs = urlParams.get('fs') || 'N/A';

        // Display story ID
        document.getElementById('storyIdDisplay').textContent = storyId;

        // Application Templates
        const appTemplates = {
            app1: {
                title: 'Application 1 - Data Configuration',
                description: 'Configure and manage data settings for your workflow',
                content: `
                    <div class="info-box">
                        <svg class="info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div class="info-content">
                            <div class="info-title">Story Information</div>
                            <div class="info-text">Story ID: ${storyId} | Year: ${year} | LOB: ${lob} | FS: ${fs}</div>
                        </div>
