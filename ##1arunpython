        // Load application content
        function loadApp(appKey) {
            // Update active state in sidebar
            document.querySelectorAll('.app-item').forEach(item => {
                item.classList.remove('active');
            });
            event.target.closest('.app-item').classList.add('active');

            // Load content
            const app = appTemplates[appKey];
            const contentCard = document.getElementById('contentCard');
            
            contentCard.innerHTML = `
                <div class="content-header">
                    <div class="content-title">${app.title}</div>
                    <div class="content-description">${app.description}</div>
                </div>
                ${app.content}
            `;
        }

        // Show loader
        function showLoader() {
            document.getElementById('loaderOverlay').classList.add('show');
        }

        // Hide loader
        function hideLoader() {
            document.getElementById('loaderOverlay').classList.remove('show');
        }

        // Run application
        function runApplication(appName) {
            showLoader();
            
            // Simulate processing time (2-3 seconds)
            setTimeout(() => {
                hideLoader();
                alert(`${appName} executed successfully!\n\nValidation completed for Story ID: ${storyId}`);
            }, 2500);
        }

        // Validate form
        function validateForm() {
            showLoader();
            setTimeout(() => {
                hideLoader();
                alert('Form validation completed successfully!');
            }, 1500);
        }

        // Reset form
        function resetForm() {
            if (confirm('Are you sure you want to reset all fields?')) {
                document.querySelectorAll('.form-input, .form-select, .form-textarea').forEach(field => {
                    if (field.tagName === 'SELECT') {
                        field.selectedIndex = 0;
                    } else {
                        field.value = '';
                    }
                });
                document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                    checkbox.checked = false;
                });
                alert('Form has been reset!');
            }
        }

        // Load initial app on page load
        window.addEventListener('DOMContentLoaded', function() {
            loadApp('app1');
        });
    </script>
