    {lbl:'Total Schedules',val:tot.toLocaleString(),sub:`${totA.toLocaleString()} active`,c:'#3b82f6',kg:'var(--kgb)',p:Math.round((totA/tot)*100),ico:`<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="1.5" width="13" height="13" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M1.5 6h13M5.5 1.5v4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>`},
    {lbl:'Synced LOBs',val:String(syn),sub:`${Math.round((syn/LOBS.length)*100)}% of ${LOBS.length} LOBs`,c:'#34d399',kg:'var(--kgg)',p:Math.round((syn/LOBS.length)*100),ico:`<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2.5 2.5 4-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`},
    {lbl:'Stale / Offline',val:String(sta+off),sub:`${sta} stale · ${off} offline`,c:'#fbbf24',kg:'var(--kga)',p:Math.round(((sta+off)/LOBS.length)*100),ico:`<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2.5L14.5 13.5H1.5L8 2.5Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M8 6.5v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="11.5" r=".7" fill="currentColor"/></svg>`},
    {lbl:'TFS In-Flight',val:String(tfsA),sub:`${tfsB} blocked`,c:'#a78bfa',kg:'var(--kgv)',p:tfsA>0?Math.round((TFSD.filter(t=>t.state==='Active').length/tfsA)*100):0,ico:`<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="3.5" width="13" height="9.5" rx="1.3" stroke="currentColor" stroke-width="1.3"/><path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>`},
  ];
  document.getElementById('kpiGrid').innerHTML=cards.map(c=>`<div class="kpi-card" style="--kg:radial-gradient(ellipse at top left,${c.kg} 0%,transparent 70%)"><div class="kpi-gauge">${gauge(c.p,c.c)}<div class="kpi-gi" style="color:${c.c}">${c.ico}</div></div><div class="kpi-body"><div class="kpi-val">${c.val}</div><div class="kpi-lbl">${c.lbl}</div><div class="kpi-sub">${c.sub}</div></div></div>`).join('');
}

/* SIDEBAR */
function renderSidebar(){
  const dc={synced:'ds',stale:'da',offline:'dr'};
  document.getElementById('sidebarList').innerHTML=LOBS.map(r=>`<button class="sb-item ${selId===r.id?'on':''}" onclick="sel('${r.id}')"><span class="sb-dot ${dc[r.sync]}"></span><span class="sb-name">${r.lob}</span>${r.tfs>0?`<span class="sb-tfs">${r.tfs}</span>`:''}</button>`).join('');
  document.getElementById('sfTotal').textContent=LOBS.length;
  document.getElementById('sfTFS').textContent=TFSD.filter(t=>t.state!=='Completed').length;
}

/* LOB TABLE */
function filteredLOBs(){
  let rows=[...LOBS];
  if(q){const qq=q.toLowerCase();rows=rows.filter(r=>r.lob.toLowerCase().includes(qq)||r.owner.toLowerCase().includes(qq))}
  if(cF!=='all')rows=rows.filter(r=>r.sync===cF);
  rows.sort((a,b)=>{
    if(cS==='lob')return a.lob.localeCompare(b.lob);
    if(cS==='count')return b.cnt-a.cnt;
    if(cS==='tfs')return b.tfs-a.tfs;
    if(cS==='sync')return a.ha-b.ha;
    return 0;
  });
  return rows;
}

function renderLOB(){
  const rows=filteredLOBs();
  document.getElementById('rowCnt').textContent=`${rows.length} of ${LOBS.length} LOBs`;
  if(!rows.length){document.getElementById('lobBody').innerHTML=`<tr><td colspan="10" style="text-align:center;padding:48px;color:var(--txm)">No LOBs match your filter.</td></tr>`;return}
  document.getElementById('lobBody').innerHTML=rows.map((r,idx)=>{
    const pct=Math.round((r.act/r.cnt)*100);
    const ac=r.ha>24?'bad':r.ha>8?'warn':'ok';
    const at=r.ha===0?'moments ago':r.ha<24?`${r.ha}h ago`:`${Math.round(r.ha/24)}d ago`;
    const dc2=r.d>0?'up':r.d<0?'dn':'fl';
    const dt=r.d>0?`+${r.d}`:r.d===0?'—':String(r.d);
    return `<tr class="${selId===r.id?'sel':''}" onclick="sel('${r.id}')">
      <td style="color:var(--txm);font-family:var(--font-mono);font-size:11px">${idx+1}</td>
      <td><div class="cn">${r.lob}</div></td>
      <td><div class="cbig">${r.cnt.toLocaleString()}</div></td>
      <td>
        <div style="display:flex;align-items:center;gap:8px">
          <div class="pmini-track" style="width:80px;flex-shrink:0"><div class="pmini-fill" style="width:${pct}%"></div></div>
          <span style="font-family:var(--font-mono);font-size:11px;color:var(--txs)">${r.act}</span>
        </div>
      </td>
      <td><span class="sp ${r.sync}"><span class="sp-dot d${r.sync[0]} ${r.sync==='synced'?'apu':''}"></span>${r.sync[0].toUpperCase()+r.sync.slice(1)}</span></td>
      <td><div class="st">${r.ls}</div><div class="sa ${ac}">${at}</div></td>
      <td><div class="oc"><div class="oav">${r.ini}</div><span class="on2">${r.owner}</span></div></td>
      <td class="c">${r.tfs>0?`<div class="tfsb"><div class="tfsb-n">${r.tfs}</div><div class="tfsb-s">items</div></div>`:`<span class="tfs-nil">—</span>`}</td>
      <td><div class="spkc">${spk(r.trend,r.sync)}<span class="spkd ${dc2}">${dt}</span></div></td>
      <td><button class="rchev ${selId===r.id?'open':''}" onclick="event.stopPropagation();sel('${r.id}')"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></button></td>
    </tr>`;
  }).join('');
}

/* DETAIL */
function sel(id){selId=(selId===id)?null:id;renderLOB();renderSidebar();renderDetail()}
function renderDetail(){
  const panel=document.getElementById('detailPanel');
  if(!selId){panel.classList.add('hidden');return}
  const r=LOBS.find(x=>x.id===selId);
  if(!r){panel.classList.add('hidden');return}
  panel.classList.remove('hidden');
  document.getElementById('dpHdr').innerHTML=`<div class="dp-left"><div class="dp-av">${r.ini}</div><div><div class="dp-lob">${r.lob}</div><div class="dp-div">Owner: ${r.owner}</div></div><span class="sp ${r.sync}" style="margin-left:8px"><span class="sp-dot d${r.sync[0]}"></span>${r.sync[0].toUpperCase()+r.sync.slice(1)}</span></div><button class="dp-close" onclick="sel('${r.id}')"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>`;
  const sc={Active:'active','In Review':'review',Blocked:'blocked',Completed:'completed'};
  const tf=TFSD.filter(t=>t.lob===r.lob);
  document.getElementById('dpBody').innerHTML=`
    <div class="ds-grid">
      <div class="ds-card"><div class="ds-lbl">Total Schedules</div><div class="ds-val cw">${r.cnt}</div></div>
      <div class="ds-card"><div class="ds-lbl">Active</div><div class="ds-val cg">${r.act}</div></div>
      <div class="ds-card"><div class="ds-lbl">Inactive</div><div class="ds-val ca">${r.ina}</div></div>
      <div class="ds-card"><div class="ds-lbl">TFS Items</div><div class="ds-val cv">${r.tfs||'None'}</div></div>
    </div>
    ${tf.length?`<div><div class="dt-title">Related TFS Items</div><div class="dt-rows">${tf.map(t=>`<div class="dt-row"><span class="dt-id">${t.id}</span><span class="dt-name">${t.title}</span><span class="stpill ${sc[t.state]}">${t.state}</span><div class="dt-prog"><div class="dt-fill tprog-fill ${sc[t.state]}" style="width:${t.pct}%"></div></div><span class="dt-pct">${t.pct}%</span></div>`).join('')}</div></div>`:
    '<div style="font-size:12px;color:var(--txm);padding:4px 0">No active TFS items for this LOB.</div>'}`;
}

/* TFS TABLE */
function renderTFS(){
  let rows=[...TFSD];
  if(cTF!=='all')rows=rows.filter(t=>t.state===cTF);
  document.getElementById('tfsBadge').textContent=`${TFSD.filter(t=>t.state!=='Completed').length} active`;
  const sc={Active:'active','In Review':'review',Blocked:'blocked',Completed:'completed'};
  const pc={High:'ph',Medium:'pm',Low:'pl'};
  document.getElementById('tfsBody').innerHTML=rows.map((t,i)=>`
    <tr style="${i%2!==0?'background:var(--theven)':''}">
      <td><span class="tfs-id">${t.id}</span></td>
      <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--txs)">${t.title}</td>
      <td style="color:var(--txm);white-space:nowrap">${t.lob}</td>
      <td><span class="stpill ${sc[t.state]}">${t.state}</span></td>
      <td><div class="pcell"><span class="pdot ${pc[t.pri]}"></span>${t.pri}</div></td>
      <td><div class="oc"><div class="oav" style="width:22px;height:22px;font-size:8px">${t.as.substring(0,2).toUpperCase()}</div><span class="on2">${t.as}</span></div></td>
      <td><div class="tprog-cell"><div class="tprog-track"><div class="tprog-fill ${sc[t.state]}" style="width:${t.pct}%"></div></div><span class="tprog-pct">${t.pct}%</span></div></td>
      <td style="color:var(--txm);white-space:nowrap">${t.ago}</td>
    </tr>`).join('');
}

/* EVENTS */
document.getElementById('filterPills').addEventListener('click',e=>{
  const b=e.target.closest('[data-f]');if(!b)return;
  cF=b.dataset.f;
  document.querySelectorAll('#filterPills .pill').forEach(p=>p.classList.remove('on'));
  b.classList.add('on');renderLOB();
});
document.getElementById('tfsFilterPills').addEventListener('click',e=>{
  const b=e.target.closest('[data-tf]');if(!b)return;
  cTF=b.dataset.tf;
  document.querySelectorAll('#tfsFilterPills .pill').forEach(p=>p.classList.remove('on'));
  b.classList.add('on');renderTFS();
});
document.getElementById('sortSelect').addEventListener('change',e=>{cS=e.target.value;renderLOB()});
document.getElementById('searchInput').addEventListener('input',e=>{q=e.target.value;renderLOB()});

/* INIT */
renderKPI(); renderSidebar(); renderLOB(); renderTFS();
</script>
</body>
</html>
