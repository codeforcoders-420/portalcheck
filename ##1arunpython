def extract_provider_type_key(file_path: Path):
    """
    Extract normalized provider type key from filename.
    Examples:
      pt-12-fee-schedule-042026.xlsx           -> PT-12
      pt-12-fee-schedule-04082026-042026.xlsx  -> PT-12
      PT 12 fee schedule-042026.xlsx           -> PT-12
    """
    name = file_path.stem.lower()
    normalized = re.sub(r"[_\s]+", "-", name)
    normalized = re.sub(r"-+", "-", normalized)

    match = re.search(r"\bpt[- ]?(\d+)\b", normalized, re.IGNORECASE)
    if match:
        return f"PT-{match.group(1)}"

    return None

def find_matching_yesterday_file(today_file: Path, comparison_folder: Path):
    """
    Match previous file using:
    1. exact filename
    2. Provider Type key (PT + number)
    3. loose normalized filename fallback
    """
    exact_match = comparison_folder / today_file.name
    if exact_match.exists():
        return exact_match

    today_pt_key = extract_provider_type_key(today_file)
    if today_pt_key:
        candidates = []
        for candidate in comparison_folder.glob("*.xls*"):
            candidate_pt_key = extract_provider_type_key(candidate)
            if candidate_pt_key == today_pt_key:
                candidates.append(candidate)

        if len(candidates) == 1:
            return candidates[0]

        if len(candidates) > 1:
            candidates.sort(key=lambda p: p.stat().st_mtime, reverse=True)
            return candidates[0]

    today_norm = today_file.stem.lower()
    today_norm = re.sub(r'[\s_]+', '-', today_norm)
    today_norm = re.sub(r'\d{8}', '', today_norm)
    today_norm = re.sub(r'\d{6}', '', today_norm)
    today_norm = re.sub(r'-+', '-', today_norm).strip('-')

    candidates = []
    for candidate in comparison_folder.glob("*.xls*"):
        candidate_norm = candidate.stem.lower()
        candidate_norm = re.sub(r'[\s_]+', '-', candidate_norm)
        candidate_norm = re.sub(r'\d{8}', '', candidate_norm)
        candidate_norm = re.sub(r'\d{6}', '', candidate_norm)
        candidate_norm = re.sub(r'-+', '-', candidate_norm).strip('-')

        if candidate_norm == today_norm:
            candidates.append(candidate)

    if len(candidates) == 1:
        return candidates[0]

    if len(candidates) > 1:
        candidates.sort(key=lambda p: p.stat().st_mtime, reverse=True)
        return candidates[0]

    return None

def write_difference_file(diff_df: pd.DataFrame, today_file: Path, output_folder: Path):
    ensure_dir(output_folder)

    if diff_df.empty:
        return None

    out_path = output_folder / f"{today_file.stem}_Differences.xlsx"

    with pd.ExcelWriter(out_path, engine="openpyxl") as writer:
        diff_df.to_excel(writer, index=False, sheet_name="Differences")

    return out_path

def write_summary_workbook(summary_rows, overall_info, output_folder: Path):
    ensure_dir(output_folder)
    summary_path = output_folder / "Nevada_FeeSchedule_Comparison_Summary.xlsx"

    summary_df = pd.DataFrame(summary_rows, columns=[
        "Today File",
        "Yesterday File",
        "Status",
        "Difference File",
        "Total Differences",
        "Rate Change",
        "Effective date change",
        "New Code",
        "Terminate",
        "End date change",
        "Specialty change",
        "Remarks"
    ])

    overall_df = pd.DataFrame([
        {"Metric": "Today Folder", "Value": overall_info["today_folder"]},
        {"Metric": "Comparison Folder", "Value": overall_info["yesterday_folder"]},
        {"Metric": "Downloaded Files", "Value": overall_info["downloaded_files"]},
        {"Metric": "Download Failures", "Value": overall_info["download_failures"]},
        {"Metric": "Compared Successfully", "Value": overall_info["compared_successfully"]},
        {"Metric": "Comparison Failures", "Value": overall_info["comparison_failures"]},
        {"Metric": "Skipped - No Previous Match", "Value": overall_info["skipped_no_yesterday_match"]},
    ])

    with pd.ExcelWriter(summary_path, engine="openpyxl") as writer:
        overall_df.to_excel(writer, index=False, sheet_name="Overall Summary")
        summary_df.to_excel(writer, index=False, sheet_name="File Summary")

    return summary_path

# ============================================================
# MAIN
# ============================================================

def main():
    try:
        ensure_dir(ROOT_DIR)

        today_folder_name, yesterday_folder_name = get_today_yesterday_folder_names()
        today_folder = ROOT_DIR / today_folder_name

        expected_yesterday_folder = ROOT_DIR / yesterday_folder_name
        if expected_yesterday_folder.exists() and expected_yesterday_folder.is_dir():
            comparison_folder = expected_yesterday_folder
        else:
            comparison_folder = find_latest_available_previous_folder(ROOT_DIR, today_folder_name)

        log("=" * 90)
        log(f"Today folder      : {today_folder}")
        log(f"Expected yesterday: {expected_yesterday_folder}")
        log(f"Comparison folder : {comparison_folder}")
        log("=" * 90)

        today_folder, downloaded_files, failures = download_all_excel_files()
        log(f"Downloaded files count: {len(downloaded_files)}")

        if comparison_folder is None or not comparison_folder.exists():
            log("No previous folder found for comparison.")
            return

        diff_output_folder = today_folder / "Differences"
        ensure_dir(diff_output_folder)

        summary_rows = []
        compare_success = 0
        compare_fail = 0
        skipped = 0

        for today_file in downloaded_files:
            if today_file.suffix.lower() not in [".xls", ".xlsx"]:
                continue

            yesterday_file = find_matching_yesterday_file(today_file, comparison_folder)
            if not yesterday_file:
                skipped += 1
                summary_rows.append({
                    "Today File": today_file.name,
                    "Yesterday File": "",
                    "Status": "Skipped",
                    "Difference File": "",
                    "Total Differences": 0,
                    "Rate Change": 0,
                    "Effective date change": 0,
                    "New Code": 0,
                    "Terminate": 0,
                    "End date change": 0,
                    "Specialty change": 0,
                    "Remarks": f"Matching file not found in comparison folder {comparison_folder.name}"
                })
                log(f"SKIPPED: {today_file.name} -> no matching file in {comparison_folder.name}")
                continue

            try:
                log(f"Trying to parse workbook: {today_file.name}")
                log(f"Comparing TODAY [{today_file.name}] vs PREVIOUS [{yesterday_file.name}]")

                today_meta = read_schedule_file(today_file)
                yesterday_meta = read_schedule_file(yesterday_file)

                diff_df, diff_summary = compare_two_files(today_meta, yesterday_meta)
                diff_file_path = write_difference_file(diff_df, today_file, diff_output_folder)

                if diff_summary["total_differences"] == 0:
                    summary_rows.append({
                        "Today File": today_file.name,
                        "Yesterday File": yesterday_file.name,
                        "Status": "No Differences",
                        "Difference File": "",
                        "Total Differences": 0,
                        "Rate Change": 0,
                        "Effective date change": 0,
                        "New Code": 0,
                        "Terminate": 0,
                        "End date change": 0,
                        "Specialty change": 0,
                        "Remarks": f"Current file is identical to {comparison_folder.name}"
                    })
                    compare_success += 1
                    log(f"No differences found: {today_file.name}")
                else:
                    summary_rows.append({
                        "Today File": today_file.name,
                        "Yesterday File": yesterday_file.name,
                        "Status": "Compared",
                        "Difference File": diff_file_path.name if diff_file_path else "",
                        "Total Differences": diff_summary["total_differences"],
                        "Rate Change": diff_summary["rate_change_count"],
                        "Effective date change": diff_summary["effective_date_change_count"],
                        "New Code": diff_summary["new_code_count"],
                        "Terminate": diff_summary["terminate_count"],
                        "End date change": diff_summary["end_date_change_count"],
                        "Specialty change": diff_summary["specialty_change_count"],
                        "Remarks": f"Compared against folder {comparison_folder.name}"
                    })
                    compare_success += 1
                    log(f"Difference file created: {diff_file_path}")

            except Exception as exc:
                compare_fail += 1
                summary_rows.append({
                    "Today File": today_file.name,
                    "Yesterday File": yesterday_file.name if yesterday_file else "",
                    "Status": "Failed",
                    "Difference File": "",
                    "Total Differences": 0,
                    "Rate Change": 0,
                    "Effective date change": 0,
                    "New Code": 0,
                    "Terminate": 0,
                    "End date change": 0,
                    "Specialty change": 0,
                    "Remarks": str(exc)
                })
                log(f"FAILED COMPARISON: {today_file.name} -> {exc}")
                traceback.print_exc()

        overall_info = {
            "today_folder": str(today_folder),
            "yesterday_folder": str(comparison_folder),
            "downloaded_files": len(downloaded_files),
            "download_failures": len(failures),
            "compared_successfully": compare_success,
            "comparison_failures": compare_fail,
            "skipped_no_yesterday_match": skipped,
        }

        summary_path = write_summary_workbook(summary_rows, overall_info, diff_output_folder)

        log("\n" + "=" * 90)
        log("PROCESS COMPLETED")
        log(f"Downloaded                : {len(downloaded_files)}")
        log(f"Download failures         : {len(failures)}")
        log(f"Compared successfully     : {compare_success}")
        log(f"Comparison failures       : {compare_fail}")
        log(f"Skipped                   : {skipped}")
        log(f"Comparison folder used    : {comparison_folder}")
        log(f"Summary workbook          : {summary_path}")
        log("=" * 90)

    except Exception as exc:
        log(f"FATAL ERROR: {exc}")
        traceback.print_exc()
        sys.exit(1)

if __name__ == "__main__":
    main()
