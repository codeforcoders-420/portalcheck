package com.example.aspconverter;

import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.nio.file.*;
import java.text.DecimalFormat;
import java.time.YearMonth;
import java.time.format.DateTimeFormatter;
import java.util.*;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class AspFileConverter {

    // Hardcoded input/output paths
    private static final String INPUT_FOLDER = "C:/Users/InputFiles/";
    private static final String OUTPUT_FOLDER = "C:/Users/OutputFiles/";

    private static final List<String> SUPPORTED_EXTENSIONS = List.of(".xls", ".xlsx");

    // Expected source headers
    private static final String HCPCS_HEADER = "HCPCS Code";
    private static final String PAYMENT_LIMIT_HEADER = "Payment Limit";

    // Output headers based on your mapping
    private static final String OUTPUT_COL_1 = "Procedure Code";
    private static final String OUTPUT_COL_2 = "Modifier1";
    private static final String OUTPUT_COL_3 = "New Rate";

    public static void main(String[] args) {
        try {
            convertAllFiles();
            System.out.println("Conversion completed successfully.");
        } catch (Exception e) {
            System.err.println("Error during conversion: " + e.getMessage());
            e.printStackTrace();
        }
    }

    public static void convertAllFiles() throws IOException {
        Path inputDir = Paths.get(INPUT_FOLDER);
        Path outputDir = Paths.get(OUTPUT_FOLDER);

        if (!Files.exists(inputDir) || !Files.isDirectory(inputDir)) {
            throw new IllegalArgumentException("Input folder does not exist: " + INPUT_FOLDER);
        }

        if (!Files.exists(outputDir)) {
            Files.createDirectories(outputDir);
        }

        try (DirectoryStream<Path> stream = Files.newDirectoryStream(inputDir)) {
            for (Path file : stream) {
                if (Files.isRegularFile(file) && isExcelFile(file)) {
                    System.out.println("Processing file: " + file.getFileName());
                    try {
                        processSingleFile(file, outputDir);
                    } catch (Exception e) {
                        System.err.println("Failed for file: " + file.getFileName() + " -> " + e.getMessage());
                        e.printStackTrace();
                    }
                }
            }
        }
    }

    private static boolean isExcelFile(Path file) {
        String name = file.getFileName().toString().toLowerCase();
        return SUPPORTED_EXTENSIONS.stream().anyMatch(name::endsWith);
    }

    private static void processSingleFile(Path sourceFile, Path outputDir) throws IOException {
        try (InputStream is = Files.newInputStream(sourceFile);
             Workbook sourceWorkbook = WorkbookFactory.create(is);
             Workbook outputWorkbook = new XSSFWorkbook()) {

            Sheet sourceSheet = sourceWorkbook.getSheetAt(0); // first sheet
            HeaderInfo headerInfo = findHeaderRow(sourceSheet);

            if (headerInfo == null) {
                throw new IllegalStateException("Could not find header row with required columns in file: "
                        + sourceFile.getFileName());
            }

            Sheet outputSheet = outputWorkbook.createSheet("ASP Output");

            // Create header style
            CellStyle headerStyle = outputWorkbook.createCellStyle();
            Font boldFont = outputWorkbook.createFont();
            boldFont.setBold(true);
            headerStyle.setFont(boldFont);

            // Text style
            CellStyle textStyle = outputWorkbook.createCellStyle();
            DataFormat dataFormat = outputWorkbook.createDataFormat();
            textStyle.setDataFormat(dataFormat.getFormat("@"));

            // Decimal style for 0.0000
            CellStyle rateStyle = outputWorkbook.createCellStyle();
            rateStyle.setDataFormat(dataFormat.getFormat("0.0000"));

            // Write output headers
            Row outHeader = outputSheet.createRow(0);

            Cell h1 = outHeader.createCell(0);
            h1.setCellValue(OUTPUT_COL_1);
            h1.setCellStyle(headerStyle);

            Cell h2 = outHeader.createCell(1);
            h2.setCellValue(OUTPUT_COL_2);
            h2.setCellStyle(headerStyle);

            Cell h3 = outHeader.createCell(2);
            h3.setCellValue(OUTPUT_COL_3);
            h3.setCellStyle(headerStyle);

            DataFormatter formatter = new DataFormatter();
            int outputRowNum = 1;

            for (int r = headerInfo.headerRowIndex + 1; r <= sourceSheet.getLastRowNum(); r++) {
                Row sourceRow = sourceSheet.getRow(r);
                if (sourceRow == null) {
                    continue;
                }

                String hcpcsCode = getCellStringValue(sourceRow.getCell(headerInfo.hcpcsColIndex), formatter).trim();
                String paymentLimitRaw = getCellStringValue(sourceRow.getCell(headerInfo.paymentLimitColIndex), formatter).trim();

                // Skip fully empty data rows
                if (hcpcsCode.isEmpty() && paymentLimitRaw.isEmpty()) {
                    continue;
                }

                Row outRow = outputSheet.createRow(outputRowNum++);

                // Procedure Code
                Cell c1 = outRow.createCell(0);
                c1.setCellValue(hcpcsCode);
                c1.setCellStyle(textStyle);

                // Modifier1 -> blank
                Cell c2 = outRow.createCell(1);
                c2.setCellValue("");
                c2.setCellStyle(textStyle);

                // New Rate
                Cell c3 = outRow.createCell(2);
                Double rateValue = parseAmount(paymentLimitRaw);

                if (rateValue != null) {
                    c3.setCellValue(rateValue);
                    c3.setCellStyle(rateStyle);
                } else {
                    // keep original content if it cannot be parsed numerically
                    c3.setCellValue(paymentLimitRaw);
                    c3.setCellStyle(textStyle);
                }
            }

            outputSheet.autoSizeColumn(0);
            outputSheet.autoSizeColumn(1);
            outputSheet.autoSizeColumn(2);

            String outputFileName = buildOutputFileName(sourceFile.getFileName().toString());
            Path outputFile = outputDir.resolve(outputFileName);

            try (OutputStream os = Files.newOutputStream(outputFile)) {
                outputWorkbook.write(os);
            }

            System.out.println("Output written: " + outputFile);
        }
    }

    /**
     * Finds the header row by detecting both:
     * - HCPCS Code
     * - Payment Limit
     *
     * Ignores special characters in header comparison.
     */
    private static HeaderInfo findHeaderRow(Sheet sheet) {
        DataFormatter formatter = new DataFormatter();

        for (int rowIndex = 0; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
            Row row = sheet.getRow(rowIndex);
            if (row == null) {
                continue;
            }

            Integer hcpcsIndex = null;
            Integer paymentLimitIndex = null;

            short lastCellNum = row.getLastCellNum();
            if (lastCellNum < 0) {
                continue;
            }

            for (int colIndex = 0; colIndex < lastCellNum; colIndex++) {
                Cell cell = row.getCell(colIndex);
                String cellValue = formatter.formatCellValue(cell);

                String normalized = normalizeHeader(cellValue);

                if (normalized.equals(normalizeHeader(HCPCS_HEADER))) {
                    hcpcsIndex = colIndex;
                }

                if (normalized.equals(normalizeHeader(PAYMENT_LIMIT_HEADER))) {
                    paymentLimitIndex = colIndex;
                }
            }

            if (hcpcsIndex != null && paymentLimitIndex != null) {
                return new HeaderInfo(rowIndex, hcpcsIndex, paymentLimitIndex);
            }
        }

        return null;
    }

    /**
     * Removes special characters and normalizes header text.
     * Example:
     * "Payment Limit", "Payment-Limit", "Payment Limit*" -> "paymentlimit"
     */
    private static String normalizeHeader(String value) {
        if (value == null) {
            return "";
        }
        return value.replaceAll("[^A-Za-z0-9]", "")
                    .toLowerCase(Locale.ROOT)
                    .trim();
    }

    private static String getCellStringValue(Cell cell, DataFormatter formatter) {
        if (cell == null) {
            return "";
        }
        return formatter.formatCellValue(cell);
    }

    /**
     * Converts values like:
     * "$12.34", "12.34", "1,234.56"
     * into numeric double.
     */
    private static Double parseAmount(String rawValue) {
        if (rawValue == null || rawValue.trim().isEmpty()) {
            return null;
        }

        String cleaned = rawValue.replaceAll("[$,\\s]", "").trim();

        if (cleaned.isEmpty()) {
            return null;
        }

        try {
            return Double.parseDouble(cleaned);
        } catch (NumberFormatException e) {
            return null;
        }
    }

    /**
     * Extracts Month + Year from source filename and creates:
     * April 2026_ASP.xlsx
     *
     * Example input:
     * April 2026 Medicare Part B Payment Limit File 031926.xls
     */
    private static String buildOutputFileName(String sourceFileName) {
        Pattern pattern = Pattern.compile(
                "(January|February|March|April|May|June|July|August|September|October|November|December)\\s+(\\d{4})",
                Pattern.CASE_INSENSITIVE
        );

        Matcher matcher = pattern.matcher(sourceFileName);
        if (matcher.find()) {
            String month = capitalizeFirstLetter(matcher.group(1).toLowerCase(Locale.ROOT));
            String year = matcher.group(2);
            return month + " " + year + "_ASP.xlsx";
        }

        // fallback if month/year not found
        return removeExtension(sourceFileName) + "_ASP.xlsx";
    }

    private static String capitalizeFirstLetter(String value) {
        if (value == null || value.isEmpty()) {
            return value;
        }
        return value.substring(0, 1).toUpperCase(Locale.ROOT) + value.substring(1);
    }

    private static String removeExtension(String fileName) {
        int dotIndex = fileName.lastIndexOf('.');
        return dotIndex > 0 ? fileName.substring(0, dotIndex) : fileName;
    }

    private static class HeaderInfo {
        private final int headerRowIndex;
        private final int hcpcsColIndex;
        private final int paymentLimitColIndex;

        private HeaderInfo(int headerRowIndex, int hcpcsColIndex, int paymentLimitColIndex) {
            this.headerRowIndex = headerRowIndex;
            this.hcpcsColIndex = hcpcsColIndex;
            this.paymentLimitColIndex = paymentLimitColIndex;
        }
    }
}
