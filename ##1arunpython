import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.math.BigDecimal;
import java.math.RoundingMode;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.*;

/**
 * Java 17 + Apache POI
 *
 * ASC converter:
 * 1. Finds sheet whose name contains ASC for sheet 1.
 * 2. Detects header row using: Code, Modifier, Modifier 2, Modifier 3, Modifier 4,
 *    Rate Type, Begin Date, End Date, FEE.
 * 3. Applies ASC mapping from source ASC sheet.
 * 4. Reads PAY0-SYSMAN-PAPRICE sheet and applies second mapping.
 * 5. Merges both sets of rows into one output workbook: MS MCD ASC.xlsx
 * 6. Writes all output cells as TEXT.
 */
public class FeeScheduleTransformerASC {

    private static final DateTimeFormatter OUTPUT_DATE = DateTimeFormatter.ofPattern("MM/dd/yyyy");
    private static final LocalDate MIN_EFFECTIVE_DATE = LocalDate.of(2022, 1, 1);
    private static final LocalDate OPEN_END_SOURCE = LocalDate.of(2299, 12, 31);
    private static final String OPEN_END_OUTPUT = "12/31/9999";

    private static final List<String> OUTPUT_HEADERS = List.of(
            "SCH NAME",
            "Procedure Code",
            "Modifier1",
            "Modifier2",
            "Modifier3",
            "Modifier4",
            "Effective Date",
            "End Date",
            "Pricing Method",
            "New Rate",
            "Old Rate",
            "Comments"
    );

    public static void main(String[] args) throws Exception {
        Path input = Path.of("/mnt/data/WEB-Ambulatory-Surgical-Center-Fee-Sch-JANUARY-2026-FNL-v2.xlsx");
        Path output = Path.of("/mnt/data/MS MCD ASC.xlsx");

        transform(input, output);
        System.out.println("Created output file: " + output.toAbsolutePath());
    }

    public static void transform(Path inputFile, Path outputFile) throws IOException {
        try (InputStream in = Files.newInputStream(inputFile);
             Workbook sourceWorkbook = WorkbookFactory.create(in)) {

            List<OutputRecord> combined = new ArrayList<>();
            combined.addAll(processAscSheet(sourceWorkbook));
            combined.addAll(processPay0SysmanSheet(sourceWorkbook));

            writeWorkbook(outputFile, combined);
        }
    }

    private static List<OutputRecord> processAscSheet(Workbook workbook) {
        Sheet ascSheet = findSheetContaining(workbook, "ASC")
                .orElseThrow(() -> new IllegalArgumentException("No sheet found containing ASC in the sheet name."));

        int headerRowIndex = findHeaderRow(ascSheet, Set.of(
                "Code", "Modifier", "Modifier 2", "Modifier 3", "Modifier 4",
                "Rate Type", "Begin Date", "End Date", "FEE"
        ));

        Map<String, Integer> headerMap = buildHeaderMap(ascSheet.getRow(headerRowIndex));
        List<OutputRecord> records = new ArrayList<>();

        for (int rowIndex = headerRowIndex + 1; rowIndex <= ascSheet.getLastRowNum(); rowIndex++) {
            Row row = ascSheet.getRow(rowIndex);
            if (row == null || isRowEmpty(row)) {
                continue;
            }

            String procedureCode = getCellAsString(row, headerMap.get("Code"));
            if (procedureCode.isBlank()) {
                continue;
            }

            String rateType = getCellAsString(row, headerMap.get("Rate Type"));
            String pricingMethod = "ASC".equalsIgnoreCase(rateType) ? "Allowed" : "";

            records.add(new OutputRecord(
                    "MS MCD ASC",
                    procedureCode,
                    getCellAsString(row, headerMap.get("Modifier")),
                    getCellAsString(row, headerMap.get("Modifier 2")),
                    getCellAsString(row, headerMap.get("Modifier 3")),
                    getCellAsString(row, headerMap.get("Modifier 4")),
                    normalizeEffectiveDate(getCellAsString(row, headerMap.get("Begin Date"))),
                    normalizeEndDate(getCellAsString(row, headerMap.get("End Date"))),
                    pricingMethod,
                    normalizeRateToFourDecimals(getCellAsString(row, headerMap.get("FEE"))),
                    "N/A",
                    "New Code"
            ));
        }

        return records;
    }

    private static List<OutputRecord> processPay0SysmanSheet(Workbook workbook) {
        Sheet sheet = findSheetContaining(workbook, "PAY0-SYSMAN-PAPRICE")
                .orElseThrow(() -> new IllegalArgumentException("PAY0-SYSMAN-PAPRICE sheet not found."));

        int headerRowIndex = findHeaderRow(sheet, Set.of(
                "Procedure Code", "Pricing Indicator", "DOS From", "DOS Thru"
        ));

        Map<String, Integer> headerMap = buildHeaderMap(sheet.getRow(headerRowIndex));
        List<OutputRecord> records = new ArrayList<>();

        for (int rowIndex = headerRowIndex + 1; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
            Row row = sheet.getRow(rowIndex);
            if (row == null || isRowEmpty(row)) {
                continue;
            }

            String procedureCode = getCellAsString(row, headerMap.get("Procedure Code"));
            if (procedureCode.isBlank()) {
                continue;
            }

            String pricingIndicator = getCellAsString(row, headerMap.get("Pricing Indicator"));
            String pricingMethod = switch (pricingIndicator.toUpperCase(Locale.ROOT)) {
                case "SYSMAN" -> "By Report";
                case "PAY0" -> "Allowed";
                default -> "";
            };

            records.add(new OutputRecord(
                    "MS MCD ASC",
                    procedureCode,
                    "",
                    "",
                    "",
                    "",
                    normalizeEffectiveDate(getCellAsString(row, headerMap.get("DOS From"))),
                    normalizeEndDate(getCellAsString(row, headerMap.get("DOS Thru"))),
                    pricingMethod,
                    "0.0000",
                    "N/A",
                    "New Code"
            ));
        }

        return records;
    }

    private static Optional<Sheet> findSheetContaining(Workbook workbook, String token) {
        for (int i = 0; i < workbook.getNumberOfSheets(); i++) {
            Sheet sheet = workbook.getSheetAt(i);
            if (sheet.getSheetName().toUpperCase(Locale.ROOT).contains(token.toUpperCase(Locale.ROOT))) {
                return Optional.of(sheet);
            }
        }
        return Optional.empty();
    }

    private static int findHeaderRow(Sheet sheet, Set<String> requiredHeaders) {
        DataFormatter formatter = new DataFormatter();

        for (Row row : sheet) {
            Set<String> rowValues = new HashSet<>();
            for (Cell cell : row) {
                String value = formatter.formatCellValue(cell).trim();
                if (!value.isBlank()) {
                    rowValues.add(value);
                }
            }
            if (rowValues.containsAll(requiredHeaders)) {
                return row.getRowNum();
            }
        }

        throw new IllegalArgumentException("Header row not found in sheet: " + sheet.getSheetName());
    }

    private static Map<String, Integer> buildHeaderMap(Row headerRow) {
        Map<String, Integer> headerMap = new HashMap<>();
        DataFormatter formatter = new DataFormatter();

        for (Cell cell : headerRow) {
            headerMap.put(formatter.formatCellValue(cell).trim(), cell.getColumnIndex());
        }
        return headerMap;
    }

    private static boolean isRowEmpty(Row row) {
        DataFormatter formatter = new DataFormatter();
        for (Cell cell : row) {
            if (!formatter.formatCellValue(cell).trim().isBlank()) {
                return false;
            }
        }
        return true;
    }

    private static String getCellAsString(Row row, Integer colIndex) {
        if (colIndex == null) {
            return "";
        }
        Cell cell = row.getCell(colIndex, Row.MissingCellPolicy.RETURN_BLANK_AS_NULL);
        if (cell == null) {
            return "";
        }
        return new DataFormatter().formatCellValue(cell).trim();
    }

    private static String normalizeEffectiveDate(String raw) {
        LocalDate date = parseFlexibleDate(raw);
        if (date == null) {
            return "";
        }
        if (date.isBefore(MIN_EFFECTIVE_DATE)) {
            return OUTPUT_DATE.format(MIN_EFFECTIVE_DATE);
        }
        return OUTPUT_DATE.format(date);
    }

    private static String normalizeEndDate(String raw) {
        LocalDate date = parseFlexibleDate(raw);
        if (date == null) {
            return "";
        }
        if (OPEN_END_SOURCE.equals(date)) {
            return OPEN_END_OUTPUT;
        }
        return OUTPUT_DATE.format(date);
    }

    private static LocalDate parseFlexibleDate(String raw) {
        if (raw == null) {
            return null;
        }

        String value = raw.trim();
        if (value.isBlank()) {
            return null;
        }

        List<DateTimeFormatter> formatters = List.of(
                DateTimeFormatter.ofPattern("MM/dd/yyyy"),
                DateTimeFormatter.ofPattern("M/d/yyyy"),
                DateTimeFormatter.ofPattern("yyyyMMdd")
        );

        for (DateTimeFormatter formatter : formatters) {
            try {
                return LocalDate.parse(value, formatter);
            } catch (DateTimeParseException ignored) {
            }
        }

        if (value.matches("\\d+")) {
            try {
                double numeric = Double.parseDouble(value);
                if (DateUtil.isValidExcelDate(numeric)) {
                    return DateUtil.getLocalDateTime(numeric).toLocalDate();
                }
            } catch (NumberFormatException ignored) {
            }
        }

        return null;
    }

    private static String normalizeRateToFourDecimals(String raw) {
        if (raw == null || raw.isBlank()) {
            return "";
        }

        String cleaned = raw.replace("$", "")
                .replace(",", "")
                .trim();

        try {
            BigDecimal value = new BigDecimal(cleaned);
            return value.setScale(4, RoundingMode.HALF_UP).toPlainString();
        } catch (NumberFormatException ex) {
            return cleaned;
        }
    }

    private static void writeWorkbook(Path outputFile, List<OutputRecord> records) throws IOException {
        try (Workbook workbook = new XSSFWorkbook()) {
            Sheet sheet = workbook.createSheet("Output");
            DataFormat dataFormat = workbook.createDataFormat();
            CellStyle textStyle = workbook.createCellStyle();
            textStyle.setDataFormat(dataFormat.getFormat("@"));

            int rowIndex = 0;
            Row headerRow = sheet.createRow(rowIndex++);
            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                Cell cell = headerRow.createCell(i, CellType.STRING);
                cell.setCellStyle(textStyle);
                cell.setCellValue(OUTPUT_HEADERS.get(i));
            }

            for (OutputRecord record : records) {
                Row row = sheet.createRow(rowIndex++);
                List<String> values = List.of(
                        record.schName(),
                        record.procedureCode(),
                        record.modifier1(),
                        record.modifier2(),
                        record.modifier3(),
                        record.modifier4(),
                        record.effectiveDate(),
                        record.endDate(),
                        record.pricingMethod(),
                        record.newRate(),
                        record.oldRate(),
                        record.comments()
                );

                for (int i = 0; i < values.size(); i++) {
                    Cell cell = row.createCell(i, CellType.STRING);
                    cell.setCellStyle(textStyle);
                    cell.setCellValue(values.get(i));
                }
            }

            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                sheet.autoSizeColumn(i);
            }

            try (OutputStream out = Files.newOutputStream(outputFile)) {
                workbook.write(out);
            }
        }
    }

    private record OutputRecord(
            String schName,
            String procedureCode,
            String modifier1,
            String modifier2,
            String modifier3,
            String modifier4,
            String effectiveDate,
            String endDate,
            String pricingMethod,
            String newRate,
            String oldRate,
            String comments
    ) {
    }
}
