<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Fee Schedule Dashboard – Live View</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{--font-sans:'Inter',system-ui,sans-serif;--font-mono:'Geist Mono','Menlo',monospace;--r-sm:6px;--r-md:10px;--r-lg:14px;--topbar-h:56px;--sidebar-w:224px;--t:.18s ease}
[data-theme="dark"]{--bg:#070c18;--bg2:#0f1628;--bg3:#141d35;--bgh:rgba(255,255,255,.05);--bga:rgba(59,130,246,.08);--surf:rgba(15,22,40,.9);--surf2:rgba(255,255,255,.02);--bdr:rgba(255,255,255,.07);--bdrf:rgba(59,130,246,.5);--tx:#dde4f0;--txs:#8494b0;--txm:#4f5f7a;--txw:#fff;--blue:#3b82f6;--blues:rgba(59,130,246,.12);--bkblue:rgba(59,130,246,.3);--violet:#a78bfa;--violets:rgba(167,139,250,.12);--green:#34d399;--greens:rgba(52,211,153,.12);--gkgreen:rgba(52,211,153,.3);--amber:#fbbf24;--ambers:rgba(251,191,36,.12);--gkamber:rgba(251,191,36,.3);--red:#f87171;--reds:rgba(248,113,113,.12);--gkred:rgba(248,113,113,.3);--kgb:rgba(59,130,246,.15);--kgg:rgba(52,211,153,.12);--kga:rgba(251,191,36,.12);--kgv:rgba(167,139,250,.12);--topbarbg:rgba(7,12,24,.96);--sidebarbg:rgba(11,18,32,.9);--scrt:rgba(255,255,255,.04);--scrth:rgba(255,255,255,.12);--tgtrack:#1c2540;--tgthumb:#3b82f6;--tgtxt:#8494b0;--thodd:transparent;--theven:rgba(255,255,255,.012);--thbg:rgba(255,255,255,.02);--thtx:#4f5f7a;--dtbg:rgba(59,130,246,.04);--dtbdr:rgba(59,130,246,.2);--dthbg:rgba(59,130,246,.06);--pact:linear-gradient(135deg,#3b82f6,#6366f1);--pactx:#fff;--ptx:#8494b0;--phtx:#dde4f0;--bghost:rgba(255,255,255,.04);--bgbdr:rgba(255,255,255,.1);--bgtx:#8494b0;--bghbdr:rgba(255,255,255,.2);--bghtx:#dde4f0;--brandg:linear-gradient(135deg,#3b82f6,#6366f1);--avbg:linear-gradient(135deg,#6366f1,#3b82f6)}
[data-theme="light"]{--bg:#f1f4f9;--bg2:#fff;--bg3:#f8fafc;--bgh:rgba(0,0,0,.04);--bga:rgba(59,130,246,.06);--surf:#fff;--surf2:rgba(0,0,0,.01);--bdr:rgba(0,0,0,.08);--bdrf:rgba(59,130,246,.4);--tx:#1e293b;--txs:#64748b;--txm:#94a3b8;--txw:#0f172a;--blue:#2563eb;--blues:rgba(37,99,235,.08);--bkblue:rgba(37,99,235,.25);--violet:#7c3aed;--violets:rgba(124,58,237,.08);--green:#059669;--greens:rgba(5,150,105,.08);--gkgreen:rgba(5,150,105,.25);--amber:#d97706;--ambers:rgba(217,119,6,.08);--gkamber:rgba(217,119,6,.25);--red:#dc2626;--reds:rgba(220,38,38,.08);--gkred:rgba(220,38,38,.25);--kgb:rgba(37,99,235,.06);--kgg:rgba(5,150,105,.06);--kga:rgba(217,119,6,.06);--kgv:rgba(124,58,237,.06);--topbarbg:rgba(255,255,255,.96);--sidebarbg:#f8fafc;--scrt:rgba(0,0,0,.03);--scrth:rgba(0,0,0,.14);--tgtrack:#e2e8f0;--tgthumb:#2563eb;--tgtxt:#64748b;--thodd:transparent;--theven:rgba(0,0,0,.012);--thbg:rgba(0,0,0,.02);--thtx:#94a3b8;--dtbg:rgba(37,99,235,.03);--dtbdr:rgba(37,99,235,.15);--dthbg:rgba(37,99,235,.05);--pact:linear-gradient(135deg,#2563eb,#4f46e5);--pactx:#fff;--ptx:#64748b;--phtx:#1e293b;--bghost:#f8fafc;--bgbdr:rgba(0,0,0,.12);--bgtx:#64748b;--bghbdr:rgba(0,0,0,.2);--bghtx:#1e293b;--brandg:linear-gradient(135deg,#2563eb,#4f46e5);--avbg:linear-gradient(135deg,#4f46e5,#2563eb)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px}
body{font-family:var(--font-sans);background:var(--bg);color:var(--tx);min-height:100vh;-webkit-font-smoothing:antialiased;transition:background var(--t),color var(--t)}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:var(--scrt)}::-webkit-scrollbar-thumb{background:var(--scrth);border-radius:99px}
*{scrollbar-width:thin;scrollbar-color:var(--scrth) var(--scrt)}
.mono{font-family:var(--font-mono)}.ab{color:var(--blue)}

/* TOPBAR */
.topbar{position:sticky;top:0;z-index:50;height:var(--topbar-h);display:flex;align-items:center;gap:20px;padding:0 24px;background:var(--topbarbg);border-bottom:1px solid var(--bdr);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);transition:background var(--t),border-color var(--t)}
.tb-brand{display:flex;align-items:center;gap:10px;flex-shrink:0;user-select:none}
.brand-icon{width:30px;height:30px;border-radius:8px;background:var(--brandg);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.brand-name{font-size:14px;font-weight:600;color:var(--txw);letter-spacing:-.2px;transition:color var(--t)}
.brand-sep{color:var(--txm);font-size:13px;opacity:.5}
.brand-sub{font-size:12px;font-weight:500;color:var(--txs);transition:color var(--t)}
.tb-nav{display:flex;align-items:center;gap:2px}
.nav-tab{padding:6px 12px;font-size:12px;font-weight:500;border-radius:var(--r-sm);border:none;cursor:pointer;background:transparent;color:var(--txs);transition:background var(--t),color var(--t);font-family:var(--font-sans)}
.nav-tab:hover{background:var(--bgh);color:var(--tx)}
.nav-tab.on{background:rgba(255,255,255,.09)!important;color:var(--txw)!important}
[data-theme="light"] .nav-tab.on{background:rgba(0,0,0,.07)!important;color:var(--tx)!important}
.tb-right{display:flex;align-items:center;gap:12px;margin-left:auto;flex-shrink:0}
.clock{display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-size:11px;color:var(--txs)}
.env-sel{display:flex;align-items:center;gap:7px;padding:5px 10px;border:1px solid var(--bdr);border-radius:var(--r-sm);background:var(--bgh);transition:background var(--t),border-color var(--t)}
.env-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;transition:background var(--t)}
.env-select{background:transparent;border:none;outline:none;font-size:12px;font-weight:500;font-family:var(--font-sans);cursor:pointer;color:var(--tx)}
.env-select option{background:var(--bg2);color:var(--tx)}
.theme-toggle{display:flex;align-items:center;gap:8px;padding:5px 10px 5px 6px;border:1px solid var(--bdr);border-radius:99px;background:var(--bghost);cursor:pointer;transition:all var(--t);font-family:var(--font-sans)}
.theme-toggle:hover{border-color:var(--bghbdr)}
.tg-track{width:32px;height:18px;border-radius:99px;background:var(--tgtrack);position:relative;flex-shrink:0;transition:background var(--t)}
.tg-thumb{position:absolute;top:3px;left:3px;width:12px;height:12px;border-radius:50%;background:var(--tgthumb);display:flex;align-items:center;justify-content:center;transition:transform .22s cubic-bezier(.4,0,.2,1),background var(--t);box-shadow:0 1px 4px rgba(0,0,0,.3)}
[data-theme="dark"] .tg-thumb{transform:translateX(14px)}
[data-theme="light"] .tg-thumb{transform:translateX(0)}
.icon-sun,.icon-moon{position:absolute;color:#fff;transition:opacity .18s ease}
[data-theme="dark"] .icon-sun{opacity:0}[data-theme="dark"] .icon-moon{opacity:1}
[data-theme="light"] .icon-sun{opacity:1}[data-theme="light"] .icon-moon{opacity:0}
.tg-label{font-size:11px;font-weight:600;color:var(--tgtxt);letter-spacing:.01em;white-space:nowrap;transition:color var(--t)}
.live-badge{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:.08em;color:var(--green)}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 1.8s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.45;transform:scale(.85)}}
.user-av{width:30px;height:30px;border-radius:50%;background:var(--avbg);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}

/* LAYOUT */
.layout{display:flex;height:calc(100vh - var(--topbar-h))}

/* SIDEBAR */
.sidebar{width:var(--sidebar-w);flex-shrink:0;display:flex;flex-direction:column;border-right:1px solid var(--bdr);background:var(--sidebarbg);overflow-y:auto;transition:background var(--t),border-color var(--t)}
.sb-section{padding:18px 12px 8px}
.sb-heading{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--txm);padding:0 10px;margin-bottom:10px}
.sb-list{display:flex;flex-direction:column;gap:2px}
.sb-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:var(--r-sm);border:none;background:transparent;color:var(--txs);font-size:12px;font-weight:500;font-family:var(--font-sans);cursor:pointer;text-align:left;transition:all var(--t);width:100%}
.sb-item:hover{background:var(--bgh);color:var(--tx)}
.sb-item.on{background:var(--bga);color:var(--txw)}
[data-theme="light"] .sb-item.on{color:var(--tx)}
.sb-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sb-name{flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-tfs{font-size:10px;font-weight:600;font-family:var(--font-mono);color:var(--blue);background:var(--blues);padding:1px 5px;border-radius:4px;flex-shrink:0}
.sb-footer{margin-top:auto;padding:14px 22px;border-top:1px solid var(--bdr);display:flex;flex-direction:column;gap:8px}
.sb-stat{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--txs)}
.sb-stat .mono{font-weight:600;color:var(--tx)}
.sb-stat .mono.ab{color:var(--blue)}

/* MAIN */
.main{flex:1;min-width:0;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:20px}

/* PAGE HEADER */
.pg-header{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap}
.pg-title{font-size:18px;font-weight:700;color:var(--txw);letter-spacing:-.3px;transition:color var(--t)}
[data-theme="light"] .pg-title{color:var(--tx)}
.pg-sub{font-size:12px;color:var(--txs);margin-top:3px}
.pg-actions{display:flex;align-items:center;gap:8px}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 13px;font-size:12px;font-weight:600;border-radius:var(--r-sm);cursor:pointer;border:1px solid transparent;transition:all var(--t);font-family:var(--font-sans);white-space:nowrap}
.btn-ghost{background:var(--bghost);border-color:var(--bgbdr);color:var(--bgtx)}
.btn-ghost:hover{border-color:var(--bghbdr);color:var(--bghtx)}
.btn-primary{background:linear-gradient(135deg,var(--blue),#6366f1);color:#fff}
.btn-primary:hover{opacity:.88}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr)}}
.kpi-card{border-radius:var(--r-lg);border:1px solid var(--bdr);padding:18px;display:flex;align-items:center;gap:14px;position:relative;overflow:hidden;background:var(--surf);transition:all var(--t)}
.kpi-card::before{content:'';position:absolute;inset:0;background:var(--kg);pointer-events:none}
.kpi-gauge{position:relative;flex-shrink:0;width:44px;height:44px}
.kpi-gauge svg{display:block}
.kpi-gi{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
.kpi-body{position:relative;min-width:0}
.kpi-val{font-family:var(--font-mono);font-size:26px;font-weight:700;color:var(--txw);line-height:1;letter-spacing:-.5px;transition:color var(--t)}
[data-theme="light"] .kpi-val{color:var(--tx)}
.kpi-lbl{font-size:11px;font-weight:600;color:var(--txs);margin-top:4px}
.kpi-sub{font-size:11px;color:var(--txm);margin-top:2px}

/* TOOLBAR */
.toolbar{display:flex;align-items:center;flex-wrap:wrap;gap:10px;padding:12px 16px;border-radius:var(--r-md);border:1px solid var(--bdr);background:var(--surf);transition:all var(--t)}
.tb-search{position:relative;flex:1;min-width:180px;display:flex;align-items:center}
.tb-search svg{position:absolute;left:10px;color:var(--txm);pointer-events:none}
.search-inp{width:100%;padding:7px 10px 7px 30px;font-size:12px;font-family:var(--font-sans);border:1px solid var(--bdr);border-radius:var(--r-sm);background:var(--bg3);color:var(--tx);outline:none;transition:all var(--t)}
.search-inp::placeholder{color:var(--txm)}
.search-inp:focus{border-color:var(--bdrf);box-shadow:0 0 0 3px var(--bkblue)}
.filter-pills{display:flex;align-items:center;gap:3px;flex-wrap:wrap}
.pill{padding:6px 12px;font-size:12px;font-weight:500;border-radius:99px;border:none;cursor:pointer;background:transparent;color:var(--ptx);font-family:var(--font-sans);transition:all var(--t)}
.pill:hover{color:var(--phtx)}
.pill.on{background:var(--pact)!important;color:var(--pactx)!important}
.tb-sort{display:flex;align-items:center;gap:8px;margin-left:auto}
.sort-lbl{font-size:12px;color:var(--txm)}
.sort-sel{font-size:12px;font-family:var(--font-sans);border:1px solid var(--bdr);border-radius:var(--r-sm);padding:6px 10px;background:var(--bg3);color:var(--tx);outline:none;cursor:pointer;transition:all var(--t)}

/* TABLE */
.tbl-card{border-radius:var(--r-lg);border:1px solid var(--bdr);overflow:hidden;background:var(--surf);transition:all var(--t)}
.tbl-scroll{overflow-x:auto}
.dtable{width:100%;border-collapse:collapse;font-size:12px}
.dtable thead tr{border-bottom:1px solid var(--bdr)}
.dtable th{padding:10px 16px;text-align:left;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--thtx);background:var(--thbg);white-space:nowrap;transition:background var(--t),color var(--t)}
.dtable th.c{text-align:center}
.dtable tbody tr{border-bottom:1px solid var(--bdr);cursor:pointer;transition:background var(--t)}
.dtable tbody tr:nth-child(odd){background:var(--thodd)}
.dtable tbody tr:nth-child(even){background:var(--theven)}
.dtable tbody tr:hover{background:var(--bgh)!important}
.dtable tbody tr.sel{background:var(--bga)!important}
.dtable tbody tr:last-child{border-bottom:none}
.dtable td{padding:13px 16px;vertical-align:middle;color:var(--tx);transition:color var(--t)}
.dtable td.c{text-align:center}
.cn{font-weight:600;color:var(--txw);transition:color var(--t)}
[data-theme="light"] .cn{color:var(--tx)}
.cd{font-size:11px;color:var(--txm);margin-top:2px}
.cbig{font-family:var(--font-mono);font-size:17px;font-weight:700;color:var(--txw);line-height:1;transition:color var(--t)}
[data-theme="light"] .cbig{color:var(--tx)}
.pmini{display:flex;align-items:center;gap:7px;margin-top:6px}
.pmini-track{flex:1;height:4px;border-radius:99px;background:rgba(255,255,255,.07);overflow:hidden;transition:background var(--t)}
[data-theme="light"] .pmini-track{background:rgba(0,0,0,.08)}
.pmini-fill{height:100%;border-radius:99px;background:var(--green)}
.pmini-lbl{font-size:11px;color:var(--txm);white-space:nowrap}
.sp{display:inline-flex;align-items:center;gap:6px;padding:3px 9px;border-radius:99px;font-size:11px;font-weight:600;white-space:nowrap}
.sp-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sp.synced{background:var(--greens);color:var(--green);box-shadow:0 0 0 1px var(--gkgreen)}
.sp.stale{background:var(--ambers);color:var(--amber);box-shadow:0 0 0 1px var(--gkamber)}
.sp.offline{background:var(--reds);color:var(--red);box-shadow:0 0 0 1px var(--gkred)}
.ds{background:var(--green)}.da{background:var(--amber)}.dr{background:var(--red)}
.apu{animation:pulse 1.8s ease-in-out infinite}
.st{color:var(--txs)}
.sa{font-size:11px;font-weight:500;margin-top:2px}
.sa.ok{color:var(--txm)}.sa.warn{color:var(--amber)}.sa.bad{color:var(--red)}
.oc{display:flex;align-items:center;gap:8px}
.oav{width:26px;height:26px;border-radius:50%;background:var(--avbg);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.on2{font-size:12px;color:var(--txs)}
.tfsb{display:inline-flex;flex-direction:column;align-items:center;gap:2px}
.tfsb-n{width:30px;height:30px;border-radius:8px;background:var(--violets);color:var(--violet);font-family:var(--font-mono);font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center}
.tfsb-s{font-size:10px;color:var(--txm)}
.tfs-nil{color:var(--txm);opacity:.3}
.spkc{display:flex;align-items:center;gap:8px}
.spkd{font-family:var(--font-mono);font-size:11px;font-weight:600;min-width:28px}
.spkd.up{color:var(--green)}.spkd.dn{color:var(--red)}.spkd.fl{color:var(--txm)}
.rchev{color:var(--txm);background:none;border:none;cursor:pointer;padding:4px;display:flex;align-items:center;justify-content:center;transition:color var(--t),transform var(--t)}
.rchev:hover{color:var(--tx)}
.rchev.open{color:var(--blue);transform:rotate(90deg)}
.tbl-footer{padding:10px 16px;border-top:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;background:var(--surf2);transition:all var(--t)}
.row-cnt{font-size:11px;color:var(--txm)}
.legend{display:flex;align-items:center;gap:16px}
.legend-item{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--txm)}
.ldot{width:7px;height:7px;border-radius:50%}
.ldot.synced{background:var(--green)}.ldot.stale{background:var(--amber)}.ldot.offline{background:var(--red)}

/* DETAIL PANEL */
.detail-panel{border-radius:var(--r-lg);border:1px solid var(--dtbdr);overflow:hidden;background:var(--dtbg);transition:all var(--t)}
.detail-panel.hidden{display:none}
.dp-hdr{padding:16px 20px;border-bottom:1px solid var(--bdr);background:var(--dthbg);display:flex;align-items:center;justify-content:space-between;transition:all var(--t)}
.dp-left{display:flex;align-items:center;gap:12px}
.dp-av{width:36px;height:36px;border-radius:10px;background:var(--avbg);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
.dp-lob{font-size:14px;font-weight:700;color:var(--txw);transition:color var(--t)}
[data-theme="light"] .dp-lob{color:var(--tx)}
.dp-div{font-size:11px;color:var(--txs);margin-top:2px}
.dp-close{width:28px;height:28px;border-radius:6px;border:none;background:var(--bgh);color:var(--txm);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all var(--t)}
.dp-close:hover{color:var(--tx);background:var(--bdr)}
.dp-body{padding:20px;display:flex;flex-direction:column;gap:16px}
.ds-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
@media(max-width:700px){.ds-grid{grid-template-columns:repeat(2,1fr)}}
.ds-card{border-radius:var(--r-md);border:1px solid var(--bdr);padding:12px 14px;background:var(--surf2);transition:all var(--t)}
.ds-lbl{font-size:11px;color:var(--txm);margin-bottom:4px}
.ds-val{font-family:var(--font-mono);font-size:20px;font-weight:700;line-height:1;transition:color var(--t)}
.ds-val.cw{color:var(--txw)}[data-theme="light"] .ds-val.cw{color:var(--tx)}
.ds-val.cg{color:var(--green)}.ds-val.ca{color:var(--amber)}.ds-val.cv{color:var(--violet)}
.dt-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--txm);margin-bottom:8px}
.dt-rows{display:flex;flex-direction:column;gap:6px}
.dt-row{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--r-sm);border:1px solid var(--bdr);background:var(--surf2);transition:all var(--t)}
.dt-id{font-family:var(--font-mono);font-size:11px;color:var(--blue);flex-shrink:0}
.dt-name{flex:1;font-size:12px;color:var(--txs);min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.dt-prog{width:64px;height:5px;border-radius:99px;background:rgba(255,255,255,.07);flex-shrink:0;overflow:hidden;transition:background var(--t)}
