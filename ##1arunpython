import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.math.BigDecimal;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.*;
import java.util.stream.Collectors;
import java.util.stream.IntStream;

public class FeeScheduleTransformerBHS {

    private static final DateTimeFormatter OUTPUT_DATE = DateTimeFormatter.ofPattern("MM/dd/yyyy");
    private static final LocalDate MIN_EFFECTIVE_DATE = LocalDate.of(2022, 1, 1);
    private static final List<String> OUTPUT_HEADERS = List.of(
            "SCH NAME", "Procedure Code", "Modifier1", "Modifier2", "Modifier3", "Modifier4",
            "Effective Date", "End Date", "Pricing Method", "New Rate", "Old Rate", "Comments"
    );

    public static void main(String[] args) throws Exception {
        Path input = Path.of("/mnt/data/WEB-Behavioral-Health-Services-Fee-Schedule-JANUARY-2026-.xlsx");
        Path outputFolder = Path.of("/mnt/data/bhs_output");
        transform(input, outputFolder);
        System.out.println("Files created in: " + outputFolder.toAbsolutePath());
    }

    public static void transform(Path inputFile, Path outputFolder) throws IOException {
        Files.createDirectories(outputFolder);

        try (InputStream is = Files.newInputStream(inputFile);
             Workbook sourceWb = WorkbookFactory.create(is)) {

            Sheet bhsSheet = findSheetContaining(sourceWb, "BHS");
            Sheet manualPricSheet = findSheetContaining(sourceWb, "MANUAL PRIC");

            int bhsHeaderRowIndex = findHeaderRow(bhsSheet,
                    Set.of("Code", "Modifier 1", "Modifier 2", "Modifier 3", "Modifier 4", "Rate Type", "Begin Date", "End Date", "Fee"));
            Map<String, Integer> bhsHeaderMap = buildHeaderMap(bhsSheet.getRow(bhsHeaderRowIndex));

            int manualHeaderRowIndex = findHeaderRow(manualPricSheet,
                    Set.of("Procedure Code", "Prcng Ind", "Rate Type", "DOS From", "DOS Thru"));
            Map<String, Integer> manualHeaderMap = buildHeaderMap(manualPricSheet.getRow(manualHeaderRowIndex));

            Map<String, List<List<String>>> groupedRows = new LinkedHashMap<>();
            groupedRows.put("MS MCD MNTH", new ArrayList<>());
            groupedRows.put("MS MCD MNTH FAC", new ArrayList<>());

            processBhsSheet(bhsSheet, bhsHeaderRowIndex, bhsHeaderMap, groupedRows);
            processManualPricSheet(manualPricSheet, manualHeaderRowIndex, manualHeaderMap, groupedRows);

            writeWorkbook(outputFolder.resolve("MS MCD MNTH.xlsx"), groupedRows.get("MS MCD MNTH"));
            writeWorkbook(outputFolder.resolve("MS MCD MNTH FAC.xlsx"), groupedRows.get("MS MCD MNTH FAC"));
        }
    }

    private static void processBhsSheet(Sheet sheet, int headerRowIndex, Map<String, Integer> headerMap,
                                        Map<String, List<List<String>>> groupedRows) {
        IntStream.rangeClosed(headerRowIndex + 1, sheet.getLastRowNum())
                .mapToObj(sheet::getRow)
                .filter(Objects::nonNull)
                .map(row -> mapBhsRow(row, headerMap))
                .filter(Objects::nonNull)
                .forEach(mapped -> groupedRows.computeIfAbsent(mapped.get(0), k -> new ArrayList<>()).add(mapped));
    }

    private static List<String> mapBhsRow(Row row, Map<String, Integer> headerMap) {
        String procedureCode = cellText(row, headerMap.get("Code"));
        if (procedureCode.isBlank()) {
            return null;
        }

        String rateType = cellText(row, headerMap.get("Rate Type")).toUpperCase(Locale.ROOT);
        String schName = switch (rateType) {
            case "DEF" -> "MS MCD MNTH";
            case "SDF" -> "MS MCD MNTH FAC";
            default -> null;
        };

        if (schName == null) {
            return null;
        }

        String pricingMethod = ("DEF".equals(rateType) || "SDF".equals(rateType)) ? "Allowed" : "";

        return List.of(
                schName,
                procedureCode,
                cleanModifier(cellText(row, headerMap.get("Modifier 1"))),
                cleanModifier(cellText(row, headerMap.get("Modifier 2"))),
                cleanModifier(cellText(row, headerMap.get("Modifier 3"))),
                cleanModifier(cellText(row, headerMap.get("Modifier 4"))),
                normalizeEffectiveDate(cellText(row, headerMap.get("Begin Date"))),
                normalizeEndDate(cellText(row, headerMap.get("End Date"))),
                pricingMethod,
                normalizeRate(cellText(row, headerMap.get("Fee"))),
                "N/A",
                "New Code"
        );
    }

    private static void processManualPricSheet(Sheet sheet, int headerRowIndex, Map<String, Integer> headerMap,
                                               Map<String, List<List<String>>> groupedRows) {
        IntStream.rangeClosed(headerRowIndex + 1, sheet.getLastRowNum())
                .mapToObj(sheet::getRow)
                .filter(Objects::nonNull)
                .map(row -> mapManualPricRow(row, headerMap))
                .filter(Objects::nonNull)
                .forEach(mapped -> groupedRows.computeIfAbsent(mapped.get(0), k -> new ArrayList<>()).add(mapped));
    }

    private static List<String> mapManualPricRow(Row row, Map<String, Integer> headerMap) {
        String procedureCode = cellText(row, headerMap.get("Procedure Code"));
        if (procedureCode.isBlank()) {
            return null;
        }

        String rateType = cellText(row, headerMap.get("Rate Type")).toUpperCase(Locale.ROOT);
        String schName = switch (rateType) {
            case "DEF" -> "MS MCD MNTH";
            case "SDF" -> "MS MCD MNTH FAC";
            default -> null;
        };
        if (schName == null) {
            return null;
        }

        String pricingIndicator = firstNonBlank(
                cellText(row, headerMap.get("Pricing Indicator")),
                cellText(row, headerMap.get("Prcng Ind"))
        ).toUpperCase(Locale.ROOT);

        String pricingMethod = switch (pricingIndicator) {
            case "SYSMAN" -> "By Report";
            case "PAY0" -> "Allowed";
            default -> "";
        };

        return List.of(
                schName,
                procedureCode,
                "",
                "",
                "",
                "",
                normalizeEffectiveDate(cellText(row, headerMap.get("DOS From"))),
                normalizeEndDate(cellText(row, headerMap.get("DOS Thru"))),
                pricingMethod,
                "0.0000",
                "N/A",
                "New Code"
        );
    }

    private static void writeWorkbook(Path outputFile, List<List<String>> rows) throws IOException {
        try (Workbook wb = new XSSFWorkbook()) {
            Sheet sheet = wb.createSheet("Output");
            DataFormat df = wb.createDataFormat();
            CellStyle textStyle = wb.createCellStyle();
            textStyle.setDataFormat(df.getFormat("@"));

            Row header = sheet.createRow(0);
            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                Cell cell = header.createCell(i, CellType.STRING);
                cell.setCellValue(OUTPUT_HEADERS.get(i));
                cell.setCellStyle(textStyle);
            }

            for (int r = 0; r < rows.size(); r++) {
                Row outRow = sheet.createRow(r + 1);
                List<String> values = rows.get(r);
                for (int c = 0; c < OUTPUT_HEADERS.size(); c++) {
                    Cell cell = outRow.createCell(c, CellType.STRING);
                    cell.setCellValue(c < values.size() ? values.get(c) : "");
                    cell.setCellStyle(textStyle);
                }
            }

            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                sheet.autoSizeColumn(i);
                sheet.setColumnWidth(i, Math.min(sheet.getColumnWidth(i) + 1200, 20000));
            }

            try (OutputStream os = Files.newOutputStream(outputFile)) {
                wb.write(os);
            }
        }
    }

    private static Sheet findSheetContaining(Workbook wb, String keyword) {
        return IntStream.range(0, wb.getNumberOfSheets())
                .mapToObj(wb::getSheetAt)
                .filter(s -> s.getSheetName().toUpperCase(Locale.ROOT).contains(keyword.toUpperCase(Locale.ROOT)))
                .findFirst()
                .orElseThrow(() -> new IllegalArgumentException("Sheet containing '" + keyword + "' not found"));
    }

    private static int findHeaderRow(Sheet sheet, Set<String> requiredHeaders) {
        return IntStream.rangeClosed(sheet.getFirstRowNum(), sheet.getLastRowNum())
                .filter(idx -> {
                    Row row = sheet.getRow(idx);
                    if (row == null) return false;
                    Set<String> rowValues = IntStream.range(0, row.getLastCellNum())
                            .mapToObj(row::getCell)
                            .filter(Objects::nonNull)
                            .map(FeeScheduleTransformerBHS::cellToString)
                            .map(String::trim)
                            .collect(Collectors.toSet());
                    return requiredHeaders.stream().allMatch(rowValues::contains);
                })
                .findFirst()
                .orElseThrow(() -> new IllegalArgumentException("Header row not found in sheet: " + sheet.getSheetName()));
    }

    private static Map<String, Integer> buildHeaderMap(Row headerRow) {
        Map<String, Integer> map = new HashMap<>();
        for (Cell cell : headerRow) {
            map.put(cellToString(cell).trim(), cell.getColumnIndex());
        }
        return map;
    }

    private static String cellText(Row row, Integer colIndex) {
        if (row == null || colIndex == null) return "";
        Cell cell = row.getCell(colIndex);
        return cell == null ? "" : cellToString(cell).trim();
    }

    private static String cellToString(Cell cell) {
        if (cell == null) return "";
        return switch (cell.getCellType()) {
            case STRING -> cell.getStringCellValue();
            case NUMERIC -> {
                double value = cell.getNumericCellValue();
                if (DateUtil.isCellDateFormatted(cell)) {
                    yield cell.getLocalDateTimeCellValue().toLocalDate().format(OUTPUT_DATE);
                }
                if (Math.floor(value) == value) {
                    yield String.format(Locale.ROOT, "%.0f", value);
                }
                yield BigDecimal.valueOf(value).stripTrailingZeros().toPlainString();
            }
            case BOOLEAN -> String.valueOf(cell.getBooleanCellValue());
            case FORMULA -> {
                try {
                    yield cell.getStringCellValue();
                } catch (Exception ex) {
                    try {
                        double value = cell.getNumericCellValue();
                        if (Math.floor(value) == value) {
                            yield String.format(Locale.ROOT, "%.0f", value);
                        }
                        yield BigDecimal.valueOf(value).stripTrailingZeros().toPlainString();
                    } catch (Exception ignored) {
                        yield "";
                    }
                }
            }
            case BLANK, _NONE, ERROR -> "";
        };
    }

    private static String cleanModifier(String value) {
        String cleaned = value == null ? "" : value.trim();
        return cleaned.replaceAll("^'+|'+$", "").trim();
    }

    private static String normalizeRate(String raw) {
        String cleaned = raw == null ? "" : raw.replace("$", "").replace(",", "").trim();
        if (cleaned.isBlank()) return "0.0000";
        try {
            return new BigDecimal(cleaned).setScale(4, BigDecimal.ROUND_HALF_UP).toPlainString();
        } catch (Exception ex) {
            return "0.0000";
        }
    }

    private static String normalizeEffectiveDate(String raw) {
        LocalDate date = parseDate(raw);
        if (date == null) return "";
        if (date.isBefore(MIN_EFFECTIVE_DATE)) {
            date = MIN_EFFECTIVE_DATE;
        }
        return date.format(OUTPUT_DATE);
    }

    private static String normalizeEndDate(String raw) {
        LocalDate date = parseDate(raw);
        if (date == null) return "";
        if (LocalDate.of(2299, 12, 31).equals(date)) {
            date = LocalDate.of(9999, 12, 31);
        }
        return date.format(OUTPUT_DATE);
    }

    private static LocalDate parseDate(String raw) {
        if (raw == null) return null;
        String value = raw.trim();
        if (value.isBlank()) return null;

        List<DateTimeFormatter> formatters = List.of(
                DateTimeFormatter.ofPattern("MM/dd/yyyy"),
                DateTimeFormatter.ofPattern("M/d/yyyy"),
                DateTimeFormatter.ofPattern("yyyyMMdd")
        );
        for (DateTimeFormatter formatter : formatters) {
            try {
                return LocalDate.parse(value, formatter);
            } catch (DateTimeParseException ignored) {
            }
        }
        return null;
    }

    private static String firstNonBlank(String... values) {
        for (String value : values) {
            if (value != null && !value.isBlank()) {
                return value.trim();
            }
        }
        return "";
    }
}
