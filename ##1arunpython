def get_session():
    session = requests.Session()
    session.headers.update({"User-Agent": USER_AGENT})
    return session

def extract_excel_links(html, page_url):
    hrefs = set()
    for match in re.finditer(r'href=["\']([^"\']+)["\']', html, re.IGNORECASE):
        href = match.group(1).strip()
        href_lower = href.lower()
        if ".xlsx" in href_lower or ".xls" in href_lower:
            hrefs.add(urljoin(page_url, href))
    return sorted(hrefs)

def download_file(session, url, dest_folder: Path):
    filename = safe_filename(Path(url.split("?")[0]).name)
    dest = dest_folder / filename

    log(f"Downloading: {filename}")
    with session.get(url, stream=True, timeout=REQUEST_TIMEOUT) as response:
        response.raise_for_status()
        with open(dest, "wb") as file_obj:
            for chunk in response.iter_content(chunk_size=1024 * 1024):
                if chunk:
                    file_obj.write(chunk)

    return dest

def download_all_excel_files():
    today_folder_name, _ = get_today_yesterday_folder_names()
    today_folder = ROOT_DIR / today_folder_name
    ensure_dir(today_folder)

    session = get_session()
    response = session.get(BASE_URL, timeout=REQUEST_TIMEOUT)
    response.raise_for_status()

    links = extract_excel_links(response.text, BASE_URL)
    if not links:
        raise RuntimeError("No Excel links found on the fee schedule page.")

    downloaded_files = []
    failures = []

    for link in links:
        try:
            downloaded_files.append(download_file(session, link, today_folder))
        except Exception as exc:
            failures.append((link, str(exc)))
            log(f"FAILED DOWNLOAD: {link} -> {exc}")

    return today_folder, downloaded_files, failures

