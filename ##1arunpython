def to_output_row(
    sch_name,
    proc,
    mod,
    eff_date,
    end_date,
    pricing_method,
    new_rate,
    old_rate,
    comments,
    differences
):
    return {
        "SCH_NAME": sch_name,
        "Procedure Code": proc,
        "Modifier1": mod,
        "Modifier2": "",
        "Modifier3": "",
        "Modifier4": "",
        "Effective Date": eff_date,
        "End Date": end_date,
        "Pricing Method": pricing_method,
        "New Rate": new_rate,
        "Old Rate": old_rate,
        "Comments": comments,
        "Differences": differences
    }

def compare_two_files(today_meta, yesterday_meta):
    today_df = today_meta["data"].copy()
    yesterday_df = yesterday_meta["data"].copy()

    specialty_exists = today_meta["specialty_exists"] or yesterday_meta["specialty_exists"]

    for df in [today_df, yesterday_df]:
        for col in [
            "proc", "mod", "rate_type", "rate", "rate_begin_date",
            "rate_end_date", "specialty", "sch_name"
        ]:
            if col not in df.columns:
                df[col] = ""

        for col in [
            "proc", "mod", "rate_type", "rate", "rate_begin_date",
            "rate_end_date", "specialty", "sch_name"
        ]:
            df[col] = df[col].fillna("").astype(str).str.strip()

    def build_full_sig_vectorized(df, use_specialty):
        cols = ["proc", "mod", "rate_type", "rate", "rate_begin_date"]
        if use_specialty:
            cols.append("specialty")
        return df[cols].astype(str).agg("||".join, axis=1)

    def build_match_key_vectorized(df, use_specialty):
        cols = ["proc", "mod", "rate_type"]
        if use_specialty:
            cols.append("specialty")
        return df[cols].astype(str).agg("||".join, axis=1)

    today_df["full_sig"] = build_full_sig_vectorized(today_df, specialty_exists)
    yesterday_df["full_sig"] = build_full_sig_vectorized(yesterday_df, specialty_exists)

    exact_common = set(today_df["full_sig"]).intersection(set(yesterday_df["full_sig"]))

    today_mismatch = today_df[~today_df["full_sig"].isin(exact_common)].copy()
    yesterday_mismatch = yesterday_df[~yesterday_df["full_sig"].isin(exact_common)].copy()

    if today_mismatch.empty:
        today_mismatch["match_key"] = pd.Series(dtype="object")
    else:
        today_mismatch["match_key"] = build_match_key_vectorized(today_mismatch, specialty_exists)

    if yesterday_mismatch.empty:
        yesterday_mismatch["match_key"] = pd.Series(dtype="object")
    else:
        yesterday_mismatch["match_key"] = build_match_key_vectorized(yesterday_mismatch, specialty_exists)

    today_map = {}
    if not today_mismatch.empty:
        for key, group in today_mismatch.groupby("match_key", dropna=False):
            today_map[key] = group.iloc[0]

    yesterday_map = {}
    if not yesterday_mismatch.empty:
        for key, group in yesterday_mismatch.groupby("match_key", dropna=False):
            yesterday_map[key] = group.iloc[0]

    all_keys = sorted(set(today_map.keys()).union(set(yesterday_map.keys())))
    results = []

    for key in all_keys:
        today_row = today_map.get(key)
        yesterday_row = yesterday_map.get(key)

        if today_row is not None and yesterday_row is not None:
            changed_fields = []

            if today_row["rate"] != yesterday_row["rate"]:
                changed_fields.append("Rate")
            if today_row["rate_begin_date"] != yesterday_row["rate_begin_date"]:
                changed_fields.append("Rate Begin Date")
            if today_row["rate_end_date"] != yesterday_row["rate_end_date"]:
                changed_fields.append("Rate End Date")
            if specialty_exists and today_row["specialty"] != yesterday_row["specialty"]:
                changed_fields.append("Specialty")

            if not changed_fields:
                continue

            comments = []
            if "Rate" in changed_fields:
                comments.append("Rate Change")
            if "Rate Begin Date" in changed_fields:
                comments.append("Effective date change")
            if "Rate End Date" in changed_fields:
                comments.append("End date change")
            if "Specialty" in changed_fields:
                comments.append("Specialty change")

            results.append(
                to_output_row(
                    sch_name=today_row["sch_name"],
                    proc=today_row["proc"],
                    mod=today_row["mod"],
                    eff_date=today_row["rate_begin_date"],
                    end_date=today_row["rate_end_date"],
                    pricing_method=today_row["rate_type"],
                    new_rate=today_row["rate"],
                    old_rate=yesterday_row["rate"],
                    comments=" | ".join(comments),
                    differences=", ".join(changed_fields)
                )
            )

        elif today_row is not None and yesterday_row is None:
            results.append(
                to_output_row(
                    sch_name=today_row["sch_name"],
                    proc=today_row["proc"],
                    mod=today_row["mod"],
                    eff_date=today_row["rate_begin_date"],
                    end_date=today_row["rate_end_date"],
                    pricing_method=today_row["rate_type"],
                    new_rate=today_row["rate"],
                    old_rate="",
                    comments="New Code",
                    differences="New Code"
                )
            )

        elif today_row is None and yesterday_row is not None:
            results.append(
                to_output_row(
                    sch_name=yesterday_row["sch_name"],
                    proc=yesterday_row["proc"],
                    mod=yesterday_row["mod"],
                    eff_date=yesterday_row["rate_begin_date"],
                    end_date=yesterday_row["rate_end_date"],
                    pricing_method=yesterday_row["rate_type"],
                    new_rate="",
                    old_rate=yesterday_row["rate"],
                    comments="Terminate",
                    differences="Terminate"
                )
            )

    diff_df = pd.DataFrame(results, columns=OUTPUT_HEADERS)
    diff_summary = build_diff_summary(diff_df)
    return diff_df, diff_summary

def build_diff_summary(diff_df: pd.DataFrame):
    if diff_df.empty:
        return {
            "total_differences": 0,
            "rate_change_count": 0,
            "effective_date_change_count": 0,
            "new_code_count": 0,
            "terminate_count": 0,
            "end_date_change_count": 0,
            "specialty_change_count": 0,
        }

    comments_series = diff_df["Comments"].fillna("").astype(str)

    return {
        "total_differences": len(diff_df),
        "rate_change_count": comments_series.str.contains(r"\bRate Change\b", case=False, regex=True).sum(),
        "effective_date_change_count": comments_series.str.contains(r"\bEffective date change\b", case=False, regex=True).sum(),
        "new_code_count": comments_series.str.contains(r"\bNew Code\b", case=False, regex=True).sum(),
        "terminate_count": comments_series.str.contains(r"\bTerminate\b", case=False, regex=True).sum(),
        "end_date_change_count": comments_series.str.contains(r"\bEnd date change\b", case=False, regex=True).sum(),
        "specialty_change_count": comments_series.str.contains(r"\bSpecialty change\b", case=False, regex=True).sum(),
    }

