/* Success Message */
.success-message {
    background: #f0fdf4;
    border-left: 4px solid #22c55e;
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    animation: slideInFromTop 0.3s ease-out;
}

.success-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: #22c55e;
    flex-shrink: 0;
    margin-top: 0.125rem;
}

.success-text {
    flex: 1;
    color: #166534;
    font-weight: 500;
    font-size: 0.875rem;
    line-height: 1.4;
}

.success-close {
    background: none;
    border: none;
    color: #22c55e;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    transition: color 0.2s;
}

.success-close:hover {
    color: #16a34a;
}

.success-close i {
    width: 1.125rem;
    height: 1.125rem;
}
