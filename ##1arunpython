import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.math.BigDecimal;
import java.math.RoundingMode;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;
import java.util.stream.Stream;

public class FeeScheduleTransformerPAD {

    private static final List<String> OUTPUT_HEADERS = List.of(
            "SCH NAME", "Procedure Code", "Modifier1", "Modifier2", "Modifier3", "Modifier4",
            "Effective Date", "End Date", "Pricing Method", "New Rate", "Old Rate", "Comments"
    );

    private static final DateTimeFormatter OUT_DATE = DateTimeFormatter.ofPattern("MM/dd/yyyy");
    private static final LocalDate MIN_EFFECTIVE_DATE = LocalDate.of(2022, 1, 1);
    private static final String OPEN_END_OUTPUT = "12/31/9999";

    private record OutputRow(
            String schName,
            String procedureCode,
            String modifier1,
            String modifier2,
            String modifier3,
            String modifier4,
            String effectiveDate,
            String endDate,
            String pricingMethod,
            String newRate,
            String oldRate,
            String comments
    ) {
        List<String> toList() {
            return List.of(
                    nz(schName), nz(procedureCode), nz(modifier1), nz(modifier2), nz(modifier3), nz(modifier4),
                    nz(effectiveDate), nz(endDate), nz(pricingMethod), nz(newRate), nz(oldRate), nz(comments)
            );
        }
    }

    public static void main(String[] args) throws Exception {
        Path input = Path.of("/mnt/data/WEB-Phys-Admin-Drug-Services-Fee-Schedule-JAN-2026-FNL-v-2.xlsx");
        Path outputFolder = Path.of("/mnt/data/pad_output");
        Files.createDirectories(outputFolder);

        transform(input, outputFolder);
    }

    public static void transform(Path inputFile, Path outputFolder) throws IOException {
        try (InputStream in = Files.newInputStream(inputFile);
             Workbook sourceWorkbook = WorkbookFactory.create(in)) {

            Sheet padSheet = findSheetContains(sourceWorkbook, "PAD")
                    .orElseThrow(() -> new IllegalArgumentException("No sheet name contains 'PAD'"));

            Sheet manualSheet = findSheetContains(sourceWorkbook, "PAPRIC-PAY0-SYSMAN")
                    .or(() -> findSheetContains(sourceWorkbook, "PAPRIC"))
                    .orElseThrow(() -> new IllegalArgumentException("No sheet name contains 'PAPRIC-PAY0-SYSMAN' or 'PAPRIC'"));

            List<OutputRow> padlRows = new ArrayList<>();
            List<OutputRow> padlManRows = new ArrayList<>();

            processPadSheet(padSheet, padlRows);
            processManualSheet(manualSheet, padlRows, padlManRows);

            writeWorkbook(outputFolder.resolve("MS MCD PADL.xlsx"), padlRows);
            writeWorkbook(outputFolder.resolve("MS MCD PADL MAN.xlsx"), padlManRows);
        }
    }

    private static void processPadSheet(Sheet sheet, List<OutputRow> padlRows) {
        Map<String, Integer> headerMap = findHeaderMap(sheet,
                List.of("Code", "Modifier 1", "Modifier 2", "Modifier 3", "Modifier 4", "Rate Type", "Begin Date", "End Date", "Fee"));

        int headerRowIndex = findHeaderRowIndex(sheet,
                List.of("Code", "Modifier 1", "Modifier 2", "Modifier 3", "Modifier 4", "Rate Type", "Begin Date", "End Date", "Fee"));

        for (int r = headerRowIndex + 1; r <= sheet.getLastRowNum(); r++) {
            Row row = sheet.getRow(r);
            if (row == null || isCompletelyBlank(row)) continue;

            String code = readCell(row, headerMap.get("Code"));
            String rateType = readCell(row, headerMap.get("Rate Type"));
            if (isBlank(code) || !equalsIgnoreCaseTrim(rateType, "PAD")) continue;

            padlRows.add(new OutputRow(
                    "MS MCD PADL",
                    code,
                    readCell(row, headerMap.get("Modifier 1")),
                    readCell(row, headerMap.get("Modifier 2")),
                    readCell(row, headerMap.get("Modifier 3")),
                    readCell(row, headerMap.get("Modifier 4")),
                    normalizeEffectiveDate(readCell(row, headerMap.get("Begin Date"))),
                    normalizeEndDate(readCell(row, headerMap.get("End Date"))),
                    "Allowed",
                    normalizeRate(readCell(row, headerMap.get("Fee"))),
                    "N/A",
                    "New Code"
            ));
        }
    }

    private static void processManualSheet(Sheet sheet, List<OutputRow> padlRows, List<OutputRow> padlManRows) {
        Map<String, Integer> headerMap = findHeaderMap(sheet,
                List.of("Procedure Code", "Modifier", "Rate Type", "Pricing Indicator", "DOS From", "DOS Thru"));

        int headerRowIndex = findHeaderRowIndex(sheet,
                List.of("Procedure Code", "Modifier", "Rate Type", "Pricing Indicator", "DOS From", "DOS Thru"));

        Integer pricingIndicatorCol = headerMap.get("Pricing Indicator");
        Integer rateTypeCol = headerMap.get("Rate Type");

        for (int r = headerRowIndex + 1; r <= sheet.getLastRowNum(); r++) {
            Row row = sheet.getRow(r);
            if (row == null || isCompletelyBlank(row)) continue;

            String procedureCode = readCell(row, headerMap.get("Procedure Code"));
            String rateType = readCell(row, rateTypeCol);
            String pricingIndicator = readCell(row, pricingIndicatorCol);
            String modifier = readCell(row, headerMap.get("Modifier"));

            if (isBlank(procedureCode) || !equalsIgnoreCaseTrim(rateType, "DEF")) {
                continue;
            }

            OutputRow out = new OutputRow(
                    determineManualSchName(pricingIndicator),
                    procedureCode,
                    modifier,
                    "",
                    "",
                    "",
                    normalizeEffectiveDate(readCell(row, headerMap.get("DOS From"))),
                    normalizeEndDate(readCell(row, headerMap.get("DOS Thru"))),
                    determinePricingMethod(pricingIndicator),
                    "0.0000",
                    "N/A",
                    "New Code"
            );

            if (equalsIgnoreCaseTrim(pricingIndicator, "PAY0")) {
                padlRows.add(out);
            } else if (equalsIgnoreCaseTrim(pricingIndicator, "SYSMAN")) {
                padlManRows.add(out);
            }
        }
    }

    private static String determineManualSchName(String pricingIndicator) {
        if (equalsIgnoreCaseTrim(pricingIndicator, "PAY0")) return "MS MCD PADL";
        if (equalsIgnoreCaseTrim(pricingIndicator, "SYSMAN")) return "MS MCD PADL MAN";
        return "";
    }

    private static String determinePricingMethod(String pricingIndicator) {
        if (equalsIgnoreCaseTrim(pricingIndicator, "SYSMAN")) return "By Report";
        if (equalsIgnoreCaseTrim(pricingIndicator, "PAY0")) return "Allowed";
        return "";
    }

    private static void writeWorkbook(Path outputFile, List<OutputRow> rows) throws IOException {
        try (Workbook wb = new XSSFWorkbook()) {
            Sheet sheet = wb.createSheet("Change File Report");

            DataFormat df = wb.createDataFormat();
            CellStyle textStyle = wb.createCellStyle();
            textStyle.setDataFormat(df.getFormat("@"));

            Font headerFont = wb.createFont();
            headerFont.setBold(true);

            CellStyle headerStyle = wb.createCellStyle();
            headerStyle.cloneStyleFrom(textStyle);
            headerStyle.setFont(headerFont);

            Row header = sheet.createRow(0);
            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                Cell cell = header.createCell(i, CellType.STRING);
                cell.setCellValue(OUTPUT_HEADERS.get(i));
                cell.setCellStyle(headerStyle);
            }

            int rowIdx = 1;
            for (OutputRow out : rows) {
                Row row = sheet.createRow(rowIdx++);
                List<String> values = out.toList();
                for (int c = 0; c < values.size(); c++) {
                    Cell cell = row.createCell(c, CellType.STRING);
                    cell.setCellValue(values.get(c));
                    cell.setCellStyle(textStyle);
                }
            }

            IntStreamRange.range(0, OUTPUT_HEADERS.size()).forEach(i -> sheet.setColumnWidth(i, Math.min(9000, (OUTPUT_HEADERS.get(i).length() + 8) * 256)));
            sheet.setColumnWidth(0, 20 * 256);
            sheet.setColumnWidth(1, 18 * 256);
            sheet.setColumnWidth(8, 18 * 256);
            sheet.setColumnWidth(9, 12 * 256);
            sheet.setColumnWidth(10, 12 * 256);
            sheet.setColumnWidth(11, 18 * 256);

            try (OutputStream out = Files.newOutputStream(outputFile)) {
                wb.write(out);
            }
        }
    }

    private static Optional<Sheet> findSheetContains(Workbook workbook, String token) {
        String needle = token.toUpperCase(Locale.ROOT);
        return Stream.iterate(0, i -> i + 1)
                .limit(workbook.getNumberOfSheets())
                .map(workbook::getSheetAt)
                .filter(s -> s.getSheetName().toUpperCase(Locale.ROOT).contains(needle))
                .findFirst();
    }

    private static int findHeaderRowIndex(Sheet sheet, List<String> requiredHeaders) {
        for (int r = sheet.getFirstRowNum(); r <= sheet.getLastRowNum(); r++) {
            Row row = sheet.getRow(r);
            if (row == null) continue;
            Set<String> present = cellsAsNormalizedSet(row);
            boolean allFound = requiredHeaders.stream().map(FeeScheduleTransformerPAD::normalizeHeader).allMatch(present::contains);
            if (allFound) return r;
        }
        throw new IllegalArgumentException("Unable to locate header row in sheet: " + sheet.getSheetName());
    }

    private static Map<String, Integer> findHeaderMap(Sheet sheet, List<String> requiredHeaders) {
        int headerRowIndex = findHeaderRowIndex(sheet, requiredHeaders);
        Row headerRow = sheet.getRow(headerRowIndex);

        Map<String, Integer> raw = new HashMap<>();
        for (Cell cell : headerRow) {
            String text = normalizeHeader(readCell(cell));
            if (!text.isEmpty()) raw.put(text, cell.getColumnIndex());
        }

        return requiredHeaders.stream()
                .collect(Collectors.toMap(Function.identity(), h -> {
                    Integer idx = raw.get(normalizeHeader(h));
                    if (idx == null) throw new IllegalArgumentException("Missing header '" + h + "' in sheet: " + sheet.getSheetName());
                    return idx;
                }));
    }

    private static Set<String> cellsAsNormalizedSet(Row row) {
        Set<String> set = new HashSet<>();
        for (Cell cell : row) {
            String value = normalizeHeader(readCell(cell));
            if (!value.isEmpty()) set.add(value);
        }
        return set;
    }

    private static String normalizeHeader(String value) {
        return nz(value).trim().replace("\n", " ").replace("\r", " ").replaceAll("\\s+", " ").toUpperCase(Locale.ROOT);
    }

    private static String readCell(Row row, Integer colIndex) {
        if (row == null || colIndex == null) return "";
        return readCell(row.getCell(colIndex, Row.MissingCellPolicy.RETURN_BLANK_AS_NULL));
    }

    private static String readCell(Cell cell) {
        if (cell == null) return "";
        return switch (cell.getCellType()) {
            case STRING -> cell.getStringCellValue().trim();
            case NUMERIC -> DateUtil.isCellDateFormatted(cell)
                    ? OUT_DATE.format(cell.getLocalDateTimeCellValue().toLocalDate())
                    : stripTrailingZeros(BigDecimal.valueOf(cell.getNumericCellValue()).toPlainString());
            case BOOLEAN -> Boolean.toString(cell.getBooleanCellValue());
            case FORMULA -> readFormulaCell(cell);
            case BLANK, _NONE, ERROR -> "";
        };
    }

    private static String readFormulaCell(Cell cell) {
        return switch (cell.getCachedFormulaResultType()) {
            case STRING -> cell.getStringCellValue().trim();
            case NUMERIC -> DateUtil.isCellDateFormatted(cell)
                    ? OUT_DATE.format(cell.getLocalDateTimeCellValue().toLocalDate())
                    : stripTrailingZeros(BigDecimal.valueOf(cell.getNumericCellValue()).toPlainString());
            case BOOLEAN -> Boolean.toString(cell.getBooleanCellValue());
            default -> "";
        };
    }

    private static String normalizeEffectiveDate(String raw) {
        LocalDate parsed = parseDate(raw);
        if (parsed == null) return "";
        if (parsed.isBefore(MIN_EFFECTIVE_DATE)) parsed = MIN_EFFECTIVE_DATE;
        return OUT_DATE.format(parsed);
    }

    private static String normalizeEndDate(String raw) {
        String cleaned = nz(raw).trim();
        if (cleaned.equals("12/31/2299") || cleaned.equals("22991231")) return OPEN_END_OUTPUT;
        LocalDate parsed = parseDate(cleaned);
        return parsed == null ? cleaned : OUT_DATE.format(parsed);
    }

    private static LocalDate parseDate(String raw) {
        String value = nz(raw).trim();
        if (value.isEmpty()) return null;

        List<DateTimeFormatter> formats = List.of(
                DateTimeFormatter.ofPattern("M/d/yyyy"),
                DateTimeFormatter.ofPattern("MM/dd/yyyy"),
                DateTimeFormatter.ofPattern("M/d/uuuu"),
                DateTimeFormatter.ofPattern("MM/dd/uuuu"),
                DateTimeFormatter.ofPattern("yyyyMMdd")
        );

        for (DateTimeFormatter fmt : formats) {
            try {
                return LocalDate.parse(value, fmt);
            } catch (DateTimeParseException ignored) {
            }
        }
        return null;
    }

    private static String normalizeRate(String raw) {
        String value = nz(raw).replace("$", "").replace(",", "").trim();
        if (value.isEmpty()) return "";
        try {
            return new BigDecimal(value).setScale(4, RoundingMode.HALF_UP).toPlainString();
        } catch (NumberFormatException ex) {
            return value;
        }
    }

    private static boolean isCompletelyBlank(Row row) {
        if (row == null) return true;
        for (Cell cell : row) {
            if (!isBlank(readCell(cell))) return false;
        }
        return true;
    }

    private static boolean equalsIgnoreCaseTrim(String a, String b) {
        return nz(a).trim().equalsIgnoreCase(nz(b).trim());
    }

    private static boolean isBlank(String value) {
        return nz(value).trim().isEmpty();
    }

    private static String nz(String value) {
        return value == null ? "" : value;
    }

    private static String stripTrailingZeros(String numeric) {
        try {
            return new BigDecimal(numeric).stripTrailingZeros().toPlainString();
        } catch (NumberFormatException ex) {
            return numeric;
        }
    }

    private static final class IntStreamRange {
        private IntStreamRange() {}
        static java.util.stream.IntStream range(int startInclusive, int endExclusive) {
            return java.util.stream.IntStream.range(startInclusive, endExclusive);
        }
    }
}
