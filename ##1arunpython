                        <div id="errorMessage" class="error-message" style="display: none;">
                            <i data-lucide="alert-circle" class="error-icon"></i>
                            <p id="errorText" class="error-text"></p>
                            <button type="button" class="error-close" onclick="hideError()">
                                <i data-lucide="x"></i>
                            </button>
                        </div>


