def log(message: str):
    print(message, flush=True)

def normalize_text(value):
    if value is None:
        return ""
    if isinstance(value, float) and math.isnan(value):
        return ""
    text = str(value).strip()
    text = re.sub(r"\s+", " ", text)
    return text

def normalize_col_name(col):
    c = normalize_text(col).lower()
    c = c.replace("_", " ")
    c = c.replace("-", " ")
    c = c.replace("\n", " ")
    c = c.replace("/", " ")
    c = re.sub(r"\s+", " ", c).strip()
    return c

def normalize_value(value):
    if value is None:
        return ""
    if isinstance(value, float) and math.isnan(value):
        return ""
    text = str(value).strip()
    text = re.sub(r"\s+", " ", text)
    return text

def normalize_rate(value):
    text = normalize_value(value)
    if text == "":
        return ""
    text = text.replace("$", "").replace(",", "").strip()
    try:
        return f"{float(text):.4f}"
    except Exception:
        return text

def normalize_date(value):
    if value is None:
        return ""
    if isinstance(value, float) and math.isnan(value):
        return ""

    if isinstance(value, datetime):
        return value.strftime("%m/%d/%Y")

    text = str(value).strip()
    if text == "":
        return ""

    try:
        dt = pd.to_datetime(text, errors="coerce")
        if pd.notna(dt):
            return dt.strftime("%m/%d/%Y")
    except Exception:
        pass

    return text

def safe_filename(name):
    name = unquote(name)
    name = re.sub(r'[<>:"/\\|?*]+', "_", name)
    return name.strip()

def ensure_dir(path: Path):
    path.mkdir(parents=True, exist_ok=True)

def get_today_yesterday_folder_names():
    today_dt = datetime.today()
    yesterday_dt = today_dt - timedelta(days=1)
    return today_dt.strftime("%m%d%Y"), yesterday_dt.strftime("%m%d%Y")

def parse_folder_date(folder_name: str):
    try:
        return datetime.strptime(folder_name, "%m%d%Y")
    except Exception:
        return None

def find_latest_available_previous_folder(root_dir: Path, today_folder_name: str):
    """
    Find the latest available previous dated folder under root_dir.
    Example:
      today folder = 04172026
      available folders = 04092026, 04082026
      returns folder 04092026
    """
    today_dt = parse_folder_date(today_folder_name)
    if today_dt is None:
        return None

    candidate_folders = []

    if not root_dir.exists():
        return None

    for child in root_dir.iterdir():
        if not child.is_dir():
            continue

        folder_dt = parse_folder_date(child.name)
        if folder_dt is None:
            continue

        if folder_dt < today_dt:
            candidate_folders.append((folder_dt, child))

    if not candidate_folders:
        return None

    candidate_folders.sort(key=lambda x: x[0], reverse=True)
    return candidate_folders[0][1]

def tokenize_header(text):
    return set(normalize_col_name(text).split())

def header_match_score(actual_header, alias):
    """
    Stronger header scoring to avoid bad matches like:
      rate -> rate begin date
    """
    actual = normalize_col_name(actual_header)
    alias_norm = normalize_col_name(alias)

    if not actual or not alias_norm:
        return -1

    if actual == alias_norm:
        return 100

    actual_tokens = tokenize_header(actual)
    alias_tokens = tokenize_header(alias_norm)

    if actual_tokens == alias_tokens:
        return 95

    if alias_norm in actual and len(alias_tokens) >= 2:
        return 80

    if len(alias_tokens) >= 2 and alias_tokens.issubset(actual_tokens):
        return 75

    if len(alias_tokens) == 1:
        alias_token = next(iter(alias_tokens))
        if alias_token in actual_tokens:
            return 70

    return -1

def best_alias_score(actual_header, alias_list):
    best = -1
    for alias in alias_list:
        score = header_match_score(actual_header, alias)
        if score > best:
            best = score
    return best

def identify_header_fields(row_values):
    found_fields = {}

    for idx, value in enumerate(row_values):
        cell = normalize_col_name(value)
        if not cell:
            continue

        best_field = None
        best_score = -1

        for canonical_name, aliases in HEADER_ALIASES.items():
            if canonical_name in found_fields:
                continue
            score = best_alias_score(cell, aliases)
            if score > best_score:
                best_score = score
                best_field = canonical_name

        if best_field is not None and best_score >= 70:
            found_fields[best_field] = idx

    return found_fields

