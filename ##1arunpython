def workbook_sheet_names(file_path: Path):
    workbook = load_workbook(file_path, data_only=True, read_only=True)
    names = workbook.sheetnames
    workbook.close()
    return names

def find_header_row_in_sheet(file_path: Path, sheet_name: str, scan_limit=120):
    df = pd.read_excel(
        file_path,
        sheet_name=sheet_name,
        header=None,
        dtype=object,
        engine="openpyxl"
    )

    best_row_idx = None
    best_score = -1

    max_rows = min(scan_limit, len(df))

    for i in range(max_rows):
        row_values = df.iloc[i].tolist()
        found_fields = identify_header_fields(row_values)
        score = len(REQUIRED_CANONICAL_FIELDS.intersection(found_fields.keys()))

        if score == len(REQUIRED_CANONICAL_FIELDS):
            return i, found_fields

        if score > best_score:
            best_score = score
            best_row_idx = i

    if best_score >= 4 and best_row_idx is not None:
        row_values = df.iloc[best_row_idx].tolist()
        return best_row_idx, identify_header_fields(row_values)

    return None, None

def map_columns(actual_headers):
    """
    Robust canonical mapping with best-score selection and no duplicate reuse.
    """
    mapping = {}
    used_headers = set()

    for canonical_name, aliases in HEADER_ALIASES.items():
        best_header = None
        best_score = -1

        for actual in actual_headers:
            if actual in used_headers:
                continue

            score = best_alias_score(actual, aliases)
            actual_norm = normalize_col_name(actual)

            if canonical_name == "rate" and any(
                x in actual_norm for x in [
                    "begin date", "end date", "effective date",
                    "term date", "termination date"
                ]
            ):
                continue

            if canonical_name == "rate_begin_date" and "end date" in actual_norm:
                continue

            if canonical_name == "rate_end_date" and any(
                x in actual_norm for x in ["begin date", "effective date", "start date"]
            ):
                continue

            if score > best_score:
                best_score = score
                best_header = actual

        if best_header is not None and best_score >= 70:
            mapping[canonical_name] = best_header
            used_headers.add(best_header)
        else:
            mapping[canonical_name] = None

    return mapping

def read_schedule_file(file_path: Path):
    sheet_errors = []

    for sheet_name in workbook_sheet_names(file_path):
        try:
            header_idx, _ = find_header_row_in_sheet(file_path, sheet_name)
            if header_idx is None:
                sheet_errors.append(f"{sheet_name}: header not found")
                continue

            df = pd.read_excel(
                file_path,
                sheet_name=sheet_name,
                header=header_idx,
                dtype=object,
                engine="openpyxl"
            )

            df = df.dropna(how="all")
            df = df.loc[:, ~df.columns.isna()]
            df.columns = [normalize_text(col) for col in df.columns]

            col_map = map_columns(list(df.columns))

            required_missing = [
                key for key in ["proc", "mod", "rate_type", "rate", "rate_begin_date"]
                if not col_map.get(key)
            ]
            if required_missing:
                sheet_errors.append(
                    f"{sheet_name}: required columns missing after mapping -> {required_missing}; "
                    f"mapped={col_map}"
                )
                continue

            output_df = pd.DataFrame()
            output_df["proc"] = df[col_map["proc"]].map(normalize_value)
            output_df["mod"] = df[col_map["mod"]].map(normalize_value)
            output_df["rate_type"] = df[col_map["rate_type"]].map(normalize_value)
            output_df["rate"] = df[col_map["rate"]].map(normalize_rate)
            output_df["rate_begin_date"] = df[col_map["rate_begin_date"]].map(normalize_date)

            if col_map.get("rate_end_date"):
                output_df["rate_end_date"] = df[col_map["rate_end_date"]].map(normalize_date)
            else:
                output_df["rate_end_date"] = ""

            if col_map.get("specialty"):
                output_df["specialty"] = df[col_map["specialty"]].map(normalize_value)
                specialty_exists = True
            else:
                output_df["specialty"] = ""
                specialty_exists = False

            output_df = output_df[
                ~(
                    (output_df["proc"] == "") &
                    (output_df["mod"] == "") &
                    (output_df["rate_type"] == "") &
                    (output_df["rate"] == "") &
                    (output_df["rate_begin_date"] == "")
                )
            ].copy()

            output_df = output_df[
                ~(
                    output_df["proc"].str.lower().isin(["proc", "procedure", "procedure code", "code"]) |
                    output_df["rate_type"].str.lower().isin(["rate type", "pricing method", "enhancement"])
                )
            ].copy()

            output_df["sch_name"] = file_path.name

            if output_df.empty:
                sheet_errors.append(f"{sheet_name}: parsed but no usable data rows")
                continue

            return {
                "file_path": file_path,
                "sheet_name": sheet_name,
                "specialty_exists": specialty_exists,
                "data": output_df.reset_index(drop=True)
            }

        except Exception as exc:
            sheet_errors.append(f"{sheet_name}: {str(exc)}")
            continue

    raise ValueError(
        f"Could not find valid table in any sheet: {file_path.name}\n"
        f"Sheet diagnostics: {' | '.join(sheet_errors)}"
    )

