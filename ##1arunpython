import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.math.BigDecimal;
import java.math.RoundingMode;
import java.nio.file.Files;
import java.nio.file.Path;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;
import java.util.stream.StreamSupport;

/**
 * Java 17 + Apache POI solution.
 *
 * Input:
 *   Copy-of-WEB-Radiology-Service-Fee-Schedule-February-2026-FNL.xlsx
 *
 * Output:
 *   One single sheet in the requested format:
 *   SCH NAME | Procedure Code | Modifier1 | Modifier2 | Modifier3 | Modifier4 |
 *   Effective Date | End Date | Pricing Method | New Rate | Old Rate | Comments
 *
 * Notes:
 * - All output cells are written as TEXT.
 * - Sheet 1 is detected by sheet name containing "RADIOLOGY".
 * - Sheet 2 is detected by sheet name containing "PAY0" and "SYSMAN".
 * - For Sheet 2 modifier values like I~TC~1 -> TC.
 */
public class FeeScheduleTransformer {

    private static final DateTimeFormatter OUTPUT_DATE = DateTimeFormatter.ofPattern("MM/dd/yyyy");
    private static final LocalDate MIN_EFFECTIVE_DATE = LocalDate.of(2022, 1, 1);
    private static final String OPEN_END_OUTPUT = "12/31/9999";

    private static final List<String> OUTPUT_HEADERS = List.of(
            "SCH NAME",
            "Procedure Code",
            "Modifier1",
            "Modifier2",
            "Modifier3",
            "Modifier4",
            "Effective Date",
            "End Date",
            "Pricing Method",
            "New Rate",
            "Old Rate",
            "Comments"
    );

    public static void main(String[] args) throws Exception {
        Path input = Path.of("/mnt/data/Copy-of-WEB-Radiology-Service-Fee-Schedule-February-2026-FNL.xlsx");
        Path output = Path.of("/mnt/data/Change_File_Report_Output.xlsx");

        transform(input, output);
        System.out.println("Output created: " + output.toAbsolutePath());
    }

    public static void transform(Path inputFile, Path outputFile) throws IOException {
        try (InputStream in = Files.newInputStream(inputFile);
             Workbook sourceWorkbook = WorkbookFactory.create(in);
             Workbook targetWorkbook = new XSSFWorkbook()) {

            Sheet outputSheet = targetWorkbook.createSheet("Change File Report");
            CellStyle textStyle = createTextStyle(targetWorkbook);

            writeHeader(outputSheet, textStyle);

            int outputRowIndex = 1;
            outputRowIndex = processRadiologySheet(sourceWorkbook, outputSheet, textStyle, outputRowIndex);
            outputRowIndex = processSysmanSheet(sourceWorkbook, outputSheet, textStyle, outputRowIndex);

            autoSize(outputSheet, OUTPUT_HEADERS.size());

            try (OutputStream out = Files.newOutputStream(outputFile)) {
                targetWorkbook.write(out);
            }
        }
    }

    private static int processRadiologySheet(Workbook workbook,
                                             Sheet outputSheet,
                                             CellStyle textStyle,
                                             int startRowIndex) {

        Sheet sourceSheet = StreamSupport.stream(workbook.spliterator(), false)
                .filter(sheet -> containsIgnoreCase(sheet.getSheetName(), "RADIOLOGY"))
                .findFirst()
                .orElseThrow(() -> new IllegalStateException("No source sheet found with 'RADIOLOGY' in the name."));

        int headerRowNum = findHeaderRow(sourceSheet, Set.of(
                "Code", "Modifier 1", "Modifier 2", "Modifier 3", "Modifier 4",
                "Rate Type", "Begin Date", "End Date", "Fee"
        ));

        Map<String, Integer> headerMap = buildHeaderMap(sourceSheet.getRow(headerRowNum));

        for (int r = headerRowNum + 1; r <= sourceSheet.getLastRowNum(); r++) {
            Row row = sourceSheet.getRow(r);
            if (row == null || isMeaninglessRadiologyRow(row, headerMap)) {
                continue;
            }

            String code = getCellString(row, headerMap.get("Code"));
            if (code.isBlank()) {
                continue;
            }

            OutputRecord record = new OutputRecord(
                    "", // Keep blank. If you want sheet name here, replace with sourceSheet.getSheetName().trim()
                    code,
                    normalizeModifier(getCellString(row, headerMap.get("Modifier 1"))),
                    normalizeModifier(getCellString(row, headerMap.get("Modifier 2"))),
                    normalizeModifier(getCellString(row, headerMap.get("Modifier 3"))),
                    normalizeModifier(getCellString(row, headerMap.get("Modifier 4"))),
                    normalizeEffectiveDate(getCellString(row, headerMap.get("Begin Date"))),
                    normalizeEndDate(getCellString(row, headerMap.get("End Date"))),
                    mapRadiologyPricingMethod(getCellString(row, headerMap.get("Rate Type"))),
                    normalizeMoneyToFourDecimals(getCellString(row, headerMap.get("Fee"))),
                    "N/A",
                    "New Code"
            );

            writeOutputRecord(outputSheet.createRow(startRowIndex++), record, textStyle);
        }

        return startRowIndex;
    }

    private static int processSysmanSheet(Workbook workbook,
                                          Sheet outputSheet,
                                          CellStyle textStyle,
                                          int startRowIndex) {

        Sheet sourceSheet = StreamSupport.stream(workbook.spliterator(), false)
                .filter(sheet -> containsIgnoreCase(sheet.getSheetName(), "PAY0")
                        && containsIgnoreCase(sheet.getSheetName(), "SYSMAN"))
                .findFirst()
                .orElseThrow(() -> new IllegalStateException("No source sheet found for PAY0-SYSMAN."));

        Map<String, Integer> headerMap = buildHeaderMap(sourceSheet.getRow(sourceSheet.getFirstRowNum()));

        for (int r = sourceSheet.getFirstRowNum() + 1; r <= sourceSheet.getLastRowNum(); r++) {
            Row row = sourceSheet.getRow(r);
            if (row == null || isBlankRow(row)) {
                continue;
            }

            String procedureCode = getCellString(row, headerMap.get("Procedure Code"));
            if (procedureCode.isBlank()) {
                continue;
            }

            String rawModifier = getCellString(row, headerMap.get("MODIFIER"));
            String pricingIndicator = getCellString(row, headerMap.get("Pricing Indicator"));

            OutputRecord record = new OutputRecord(
                    "",
                    procedureCode,
                    extractSysmanModifier(rawModifier),
                    "",
                    "",
                    "",
                    normalizeEffectiveDate(getCellString(row, headerMap.get("DOS From"))),
                    normalizeEndDate(getCellString(row, headerMap.get("DOS Thru"))),
                    mapSysmanPricingMethod(pricingIndicator),
                    "0.0000",
                    "N/A",
                    "New Code"
            );

            writeOutputRecord(outputSheet.createRow(startRowIndex++), record, textStyle);
        }

        return startRowIndex;
    }

    private static boolean isMeaninglessRadiologyRow(Row row, Map<String, Integer> headerMap) {
        String code = getCellString(row, headerMap.get("Code"));
        String fee = getCellString(row, headerMap.get("Fee"));
        return code.isBlank() && fee.isBlank();
    }

    private static int findHeaderRow(Sheet sheet, Set<String> requiredHeaders) {
        for (Row row : sheet) {
            Set<String> rowValues = StreamSupport.stream(row.spliterator(), false)
                    .map(FeeScheduleTransformer::cellToString)
                    .map(String::trim)
                    .collect(Collectors.toSet());

            if (rowValues.containsAll(requiredHeaders)) {
                return row.getRowNum();
            }
        }
        throw new IllegalStateException("Header row not found in sheet: " + sheet.getSheetName());
    }

    private static Map<String, Integer> buildHeaderMap(Row headerRow) {
        return StreamSupport.stream(headerRow.spliterator(), false)
                .collect(Collectors.toMap(
                        cell -> cellToString(cell).trim(),
                        Cell::getColumnIndex,
                        (left, right) -> left,
                        LinkedHashMap::new
                ));
    }

    private static void writeHeader(Sheet sheet, CellStyle style) {
        Row header = sheet.createRow(0);
        for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
            Cell cell = header.createCell(i, CellType.STRING);
            cell.setCellValue(OUTPUT_HEADERS.get(i));
            cell.setCellStyle(style);
        }
    }

    private static void writeOutputRecord(Row row, OutputRecord record, CellStyle style) {
        List<String> values = List.of(
                record.schName(),
                record.procedureCode(),
                record.modifier1(),
                record.modifier2(),
                record.modifier3(),
                record.modifier4(),
                record.effectiveDate(),
                record.endDate(),
                record.pricingMethod(),
                record.newRate(),
                record.oldRate(),
                record.comments()
        );

        for (int i = 0; i < values.size(); i++) {
            Cell cell = row.createCell(i, CellType.STRING);
            cell.setCellValue(values.get(i));
            cell.setCellStyle(style);
        }
    }

    private static CellStyle createTextStyle(Workbook workbook) {
        CellStyle style = workbook.createCellStyle();
        DataFormat dataFormat = workbook.createDataFormat();
        style.setDataFormat(dataFormat.getFormat("@"));
        return style;
    }

    private static void autoSize(Sheet sheet, int columnCount) {
        for (int c = 0; c < columnCount; c++) {
            sheet.autoSizeColumn(c);
            int currentWidth = sheet.getColumnWidth(c);
            sheet.setColumnWidth(c, Math.min(currentWidth + 800, 18000));
        }
    }

    private static String getCellString(Row row, Integer colIndex) {
        if (row == null || colIndex == null) {
            return "";
        }
        Cell cell = row.getCell(colIndex, Row.MissingCellPolicy.RETURN_BLANK_AS_NULL);
        return cellToString(cell).trim();
    }

    private static String cellToString(Cell cell) {
        if (cell == null) {
            return "";
        }
        DataFormatter formatter = new DataFormatter();
        return formatter.formatCellValue(cell);
    }

    private static boolean isBlankRow(Row row) {
        return StreamSupport.stream(row.spliterator(), false)
                .map(FeeScheduleTransformer::cellToString)
                .allMatch(String::isBlank);
    }

    private static String normalizeModifier(String value) {
        if (value == null) {
            return "";
        }
        String trimmed = value.trim();
        return trimmed.equals("-") ? "" : trimmed;
    }

    /**
     * Input examples:
     *   "I~TC~1" -> "TC"
     *   "I~26~1" -> "26"
     *   "" -> ""
     */
    private static String extractSysmanModifier(String rawValue) {
        if (rawValue == null || rawValue.isBlank()) {
            return "";
        }
        String cleaned = rawValue.trim();
        if (!cleaned.contains("~")) {
            return cleaned;
        }
        String[] parts = cleaned.split("~");
        return parts.length >= 2 ? parts[1].trim() : cleaned;
    }

    private static String mapRadiologyPricingMethod(String rateType) {
        return equalsIgnoreCase(rateType, "DEF") ? "Allowed" : rateType;
    }

    /**
     * Based on your sample mapping, SYSMAN rows should become "By Report".
     * This uses Pricing Indicator because that is where SYSMAN exists in the source file.
     */
    private static String mapSysmanPricingMethod(String pricingIndicator) {
        return equalsIgnoreCase(pricingIndicator, "SYSMAN") ? "By Report" : pricingIndicator;
    }

    private static String normalizeMoneyToFourDecimals(String rawValue) {
        if (rawValue == null || rawValue.isBlank()) {
            return "";
        }
        String normalized = rawValue.replace("$", "")
                .replace(",", "")
                .trim();
        if (normalized.isBlank()) {
            return "";
        }
        try {
            return new BigDecimal(normalized)
                    .setScale(4, RoundingMode.HALF_UP)
                    .toPlainString();
        } catch (NumberFormatException ex) {
            return normalized;
        }
    }

    private static String normalizeEffectiveDate(String rawValue) {
        LocalDate parsed = parseDate(rawValue);
        if (parsed == null) {
            return rawValue == null ? "" : rawValue;
        }
        return (parsed.isBefore(MIN_EFFECTIVE_DATE) ? MIN_EFFECTIVE_DATE : parsed).format(OUTPUT_DATE);
    }

    private static String normalizeEndDate(String rawValue) {
        LocalDate parsed = parseDate(rawValue);
        if (parsed == null) {
            return rawValue == null ? "" : rawValue;
        }
        if (LocalDate.of(2299, 12, 31).equals(parsed)) {
            return OPEN_END_OUTPUT;
        }
        return parsed.format(OUTPUT_DATE);
    }

    private static LocalDate parseDate(String rawValue) {
        if (rawValue == null || rawValue.isBlank()) {
            return null;
        }

        String value = rawValue.trim();
        List<Function<String, LocalDate>> parsers = List.of(
                v -> tryParse(v, DateTimeFormatter.ofPattern("MM/dd/yyyy")),
                v -> tryParse(v, DateTimeFormatter.ofPattern("M/d/yyyy")),
                v -> tryParse(v, DateTimeFormatter.ofPattern("yyyyMMdd"))
        );

        for (Function<String, LocalDate> parser : parsers) {
            LocalDate date = parser.apply(value);
            if (date != null) {
                return date;
            }
        }
        return null;
    }

    private static LocalDate tryParse(String value, DateTimeFormatter formatter) {
        try {
            return LocalDate.parse(value, formatter);
        } catch (DateTimeParseException ex) {
            return null;
        }
    }

    private static boolean containsIgnoreCase(String text, String search) {
        return text != null && search != null && text.toLowerCase(Locale.ROOT).contains(search.toLowerCase(Locale.ROOT));
    }

    private static boolean equalsIgnoreCase(String left, String right) {
        return Objects.equals(
                left == null ? null : left.trim().toLowerCase(Locale.ROOT),
                right == null ? null : right.trim().toLowerCase(Locale.ROOT)
        );
    }

    private record OutputRecord(
            String schName,
            String procedureCode,
            String modifier1,
            String modifier2,
            String modifier3,
            String modifier4,
            String effectiveDate,
            String endDate,
            String pricingMethod,
            String newRate,
            String oldRate,
            String comments
    ) {}
}
