import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.nio.file.Files;
import java.nio.file.Path;
import java.text.DecimalFormat;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.*;

public class FeeScheduleTransformerAUDIO {

    private static final List<String> OUTPUT_HEADERS = List.of(
            "SCH NAME", "Procedure Code", "Modifier1", "Modifier2", "Modifier3", "Modifier4",
            "Effective Date", "End Date", "Pricing Method", "New Rate", "Old Rate", "Comments"
    );

    private static final LocalDate MIN_EFFECTIVE_DATE = LocalDate.of(2022, 1, 1);
    private static final DateTimeFormatter OUT_DATE = DateTimeFormatter.ofPattern("MM/dd/yyyy");
    private static final DecimalFormat RATE_FORMAT = new DecimalFormat("0.0000");

    public static void main(String[] args) throws Exception {
        Path input = Path.of("/mnt/data/WEB-Audiology-Hearing-Services-Fee-Schedule-January-2026-FNL-.xlsx");
        Path outputFolder = Path.of("/mnt/data/audio_output");
        Files.createDirectories(outputFolder);
        transform(input, outputFolder);
    }

    public static void transform(Path inputFile, Path outputFolder) throws Exception {
        try (InputStream is = Files.newInputStream(inputFile); Workbook workbook = WorkbookFactory.create(is)) {
            Sheet audioSheet = findSheetContaining(workbook, "AUDIO");
            Sheet manualSheet = findSheetContaining(workbook, "PAY0-SYSMAN-PAPRIC");

            if (audioSheet == null) {
                throw new IllegalArgumentException("Could not find sheet containing AUDIO");
            }
            if (manualSheet == null) {
                throw new IllegalArgumentException("Could not find sheet containing PAY0-SYSMAN-PAPRIC");
            }

            int audioHeaderRowIdx = findHeaderRow(audioSheet, List.of(
                    "Code", "Modifier 1", "Modifier 2", "Modifier 3", "Modifier 4",
                    "Rate Type", "Begin Date", "End Date", "Fee"
            ));
            if (audioHeaderRowIdx < 0) {
                throw new IllegalArgumentException("Header row not found in AUDIO sheet");
            }

            int manualHeaderRowIdx = findHeaderRow(manualSheet, List.of(
                    "Procedure Code", "Pricing Indicator", "Rate Type", "DOS From", "DOS Thru"
            ));
            if (manualHeaderRowIdx < 0) {
                throw new IllegalArgumentException("Header row not found in PAY0-SYSMAN-PAPRIC sheet");
            }

            Map<String, List<String[]>> grouped = new LinkedHashMap<>();
            grouped.put("MS MCD AUDL", new ArrayList<>());
            grouped.put("MS MCD AUDL FAC", new ArrayList<>());

            processAudioSheet(audioSheet, audioHeaderRowIdx, grouped);
            processManualSheet(manualSheet, manualHeaderRowIdx, grouped);

            writeWorkbook(outputFolder.resolve("MS MCD AUDL.xlsx"), grouped.get("MS MCD AUDL"));
            writeWorkbook(outputFolder.resolve("MS MCD AUDL FAC.xlsx"), grouped.get("MS MCD AUDL FAC"));
        }
    }

    private static void processAudioSheet(Sheet sheet, int headerRowIdx, Map<String, List<String[]>> grouped) {
        Map<String, Integer> col = buildHeaderMap(sheet.getRow(headerRowIdx));
        for (int r = headerRowIdx + 1; r <= sheet.getLastRowNum(); r++) {
            Row row = sheet.getRow(r);
            if (row == null || isBlankRow(row)) continue;

            String code = getCellString(row, col.get("CODE"));
            if (code.isBlank()) continue;

            String rateType = getCellString(row, col.get("RATE TYPE"));
            String schName = null;
            if (equalsAny(rateType, "DEF")) schName = "MS MCD AUDL";
            else if (equalsAny(rateType, "SDF")) schName = "MS MCD AUDL FAC";
            else continue;

            String[] out = new String[] {
                    schName,
                    code,
                    getCellString(row, col.get("MODIFIER 1")),
                    getCellString(row, col.get("MODIFIER 2")),
                    getCellString(row, col.get("MODIFIER 3")),
                    getCellString(row, col.get("MODIFIER 4")),
                    normalizeEffectiveDate(getCellString(row, col.get("BEGIN DATE"))),
                    normalizeEndDate(getCellString(row, col.get("END DATE"))),
                    "Allowed",
                    formatRate(getCellString(row, col.get("FEE"))),
                    "N/A",
                    "New Code"
            };
            grouped.get(schName).add(out);
        }
    }

    private static void processManualSheet(Sheet sheet, int headerRowIdx, Map<String, List<String[]>> grouped) {
        Map<String, Integer> col = buildHeaderMap(sheet.getRow(headerRowIdx));
        for (int r = headerRowIdx + 1; r <= sheet.getLastRowNum(); r++) {
            Row row = sheet.getRow(r);
            if (row == null || isBlankRow(row)) continue;

            String code = getCellString(row, col.get("PROCEDURE CODE"));
            if (code.isBlank()) continue;

            String rateType = getCellString(row, col.get("RATE TYPE"));
            String pricingIndicator = getCellString(row, col.get("PRICING INDICATOR"));
            String schName = null;
            if (equalsAny(rateType, "DEF") && equalsAny(pricingIndicator, "SYSMAN")) {
                schName = "MS MCD AUDL";
            } else if (equalsAny(rateType, "SDF") && equalsAny(pricingIndicator, "SYSMAN")) {
                schName = "MS MCD AUDL FAC";
            } else {
                continue;
            }

            String modifier = getCellString(row, col.get("MODIFIER"));
            String pricingMethod = equalsAny(pricingIndicator, "SYSMAN") ? "By Report"
                    : equalsAny(pricingIndicator, "PAY0") ? "Allowed" : "";

            String[] out = new String[] {
                    schName,
                    code,
                    modifier,
                    "",
                    "",
                    "",
                    normalizeEffectiveDate(getCellString(row, col.get("DOS FROM"))),
                    normalizeEndDate(getCellString(row, col.get("DOS THRU"))),
                    pricingMethod,
                    "0.0000",
                    "N/A",
                    "New Code"
            };
            grouped.get(schName).add(out);
        }
    }

    private static void writeWorkbook(Path outputFile, List<String[]> rows) throws IOException {
        try (Workbook wb = new XSSFWorkbook()) {
            Sheet sheet = wb.createSheet("Output");
            DataFormat dataFormat = wb.createDataFormat();
            CellStyle textStyle = wb.createCellStyle();
            textStyle.setDataFormat(dataFormat.getFormat("@"));

            Row header = sheet.createRow(0);
            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                Cell c = header.createCell(i, CellType.STRING);
                c.setCellValue(OUTPUT_HEADERS.get(i));
                c.setCellStyle(textStyle);
            }

            int rowNum = 1;
            for (String[] data : rows) {
                Row row = sheet.createRow(rowNum++);
                for (int i = 0; i < data.length; i++) {
                    Cell c = row.createCell(i, CellType.STRING);
                    c.setCellStyle(textStyle);
                    c.setCellValue(data[i] == null ? "" : data[i]);
                }
            }

            for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
                sheet.autoSizeColumn(i);
                sheet.setColumnWidth(i, Math.min(sheet.getColumnWidth(i) + 1024, 20000));
            }

            try (OutputStream os = Files.newOutputStream(outputFile)) {
                wb.write(os);
            }
        }
    }

    private static Sheet findSheetContaining(Workbook workbook, String token) {
        String needle = token.toUpperCase(Locale.ROOT);
        for (int i = 0; i < workbook.getNumberOfSheets(); i++) {
            Sheet s = workbook.getSheetAt(i);
            if (s.getSheetName().toUpperCase(Locale.ROOT).contains(needle)) return s;
        }
        return null;
    }

    private static int findHeaderRow(Sheet sheet, List<String> requiredHeaders) {
        List<String> normalizedRequired = requiredHeaders.stream().map(FeeScheduleTransformerAUDIO::normalizeHeader).toList();
        for (int r = 0; r <= Math.min(sheet.getLastRowNum(), 100); r++) {
            Row row = sheet.getRow(r);
            if (row == null) continue;
            Set<String> present = new HashSet<>();
            for (Cell cell : row) {
                String v = normalizeHeader(getCellString(cell));
                if (!v.isBlank()) present.add(v);
            }
            if (present.containsAll(normalizedRequired)) return r;
        }
        return -1;
    }

    private static Map<String, Integer> buildHeaderMap(Row headerRow) {
        Map<String, Integer> map = new HashMap<>();
        for (Cell cell : headerRow) {
            map.put(normalizeHeader(getCellString(cell)), cell.getColumnIndex());
        }
        return map;
    }

    private static String normalizeHeader(String s) {
        if (s == null) return "";
        return s.replace("\n", " ")
                .replace("\r", " ")
                .replaceAll("\\s+", " ")
                .trim()
                .toUpperCase(Locale.ROOT);
    }

    private static boolean isBlankRow(Row row) {
        for (Cell cell : row) {
            if (!getCellString(cell).isBlank()) return false;
        }
        return true;
    }

    private static String getCellString(Row row, Integer idx) {
        if (idx == null) return "";
        return getCellString(row.getCell(idx));
    }

    private static String getCellString(Cell cell) {
        if (cell == null) return "";
        return switch (cell.getCellType()) {
            case STRING -> cell.getStringCellValue().trim();
            case NUMERIC -> {
                double v = cell.getNumericCellValue();
                if (Math.floor(v) == v) yield String.valueOf((long) v);
                yield String.valueOf(v);
            }
            case BOOLEAN -> String.valueOf(cell.getBooleanCellValue());
            case FORMULA -> {
                try {
                    yield cell.getStringCellValue().trim();
                } catch (Exception e) {
                    try {
                        double v = cell.getNumericCellValue();
                        if (Math.floor(v) == v) yield String.valueOf((long) v);
                        yield String.valueOf(v);
                    } catch (Exception ex) {
                        yield "";
                    }
                }
            }
            default -> "";
        };
    }

    private static String normalizeEffectiveDate(String input) {
        LocalDate date = parseDate(input);
        if (date == null || date.isBefore(MIN_EFFECTIVE_DATE)) date = MIN_EFFECTIVE_DATE;
        return OUT_DATE.format(date);
    }

    private static String normalizeEndDate(String input) {
        LocalDate date = parseDate(input);
        if (date == null) return "";
        if (date.equals(LocalDate.of(2299, 12, 31))) date = LocalDate.of(9999, 12, 31);
        return OUT_DATE.format(date);
    }

    private static LocalDate parseDate(String input) {
        if (input == null) return null;
        String s = input.trim();
        if (s.isBlank()) return null;
        s = s.replace(".0", "");
        List<DateTimeFormatter> fmts = List.of(
                DateTimeFormatter.ofPattern("M/d/yyyy"),
                DateTimeFormatter.ofPattern("MM/dd/yyyy"),
                DateTimeFormatter.ofPattern("yyyyMMdd"),
                DateTimeFormatter.ofPattern("yyyy-MM-dd")
        );
        for (DateTimeFormatter f : fmts) {
            try { return LocalDate.parse(s, f); } catch (Exception ignored) {}
        }
        return null;
    }

    private static String formatRate(String input) {
        if (input == null || input.isBlank()) return "";
        String cleaned = input.replace("$", "").replace(",", "").trim();
        try {
            return RATE_FORMAT.format(Double.parseDouble(cleaned));
        } catch (Exception e) {
            return cleaned;
        }
    }

    private static boolean equalsAny(String value, String... options) {
        if (value == null) return false;
        for (String option : options) {
            if (value.trim().equalsIgnoreCase(option)) return true;
        }
        return false;
    }
}
