.dt-fill{height:100%;border-radius:99px}
.dt-pct{font-family:var(--font-mono);font-size:11px;color:var(--txm);width:28px;text-align:right;flex-shrink:0}

/* TFS SECTION */
.tfs-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--bdr);background:var(--surf2);flex-wrap:wrap;gap:10px;transition:all var(--t)}
.tfs-tr{display:flex;align-items:center;gap:10px}
.sec-ttl{font-size:14px;font-weight:600;color:var(--txw);transition:color var(--t)}
[data-theme="light"] .sec-ttl{color:var(--tx)}
.tfs-cbdg{font-size:11px;font-weight:700;color:var(--violet);background:var(--violets);padding:2px 9px;border-radius:99px;box-shadow:0 0 0 1px rgba(167,139,250,.25)}
.stpill{display:inline-flex;align-items:center;gap:5px;padding:3px 8px;border-radius:99px;font-size:11px;font-weight:600;white-space:nowrap}
.stpill.active{background:var(--blues);color:var(--blue);box-shadow:0 0 0 1px var(--bkblue)}
.stpill.review{background:var(--violets);color:var(--violet);box-shadow:0 0 0 1px rgba(167,139,250,.25)}
.stpill.blocked{background:var(--reds);color:var(--red);box-shadow:0 0 0 1px var(--gkred)}
.stpill.completed{background:var(--greens);color:var(--green);box-shadow:0 0 0 1px var(--gkgreen)}
.pdot{width:6px;height:6px;border-radius:50%;display:inline-block}
.ph{background:var(--red)}.pm{background:var(--amber)}.pl{background:var(--txm)}
.tprog-cell{display:flex;align-items:center;gap:8px}
.tprog-track{width:80px;height:5px;border-radius:99px;background:rgba(255,255,255,.07);overflow:hidden;flex-shrink:0;transition:background var(--t)}
[data-theme="light"] .tprog-track{background:rgba(0,0,0,.08)}
.tprog-fill{height:100%;border-radius:99px;transition:width .6s ease}
.tprog-fill.active{background:var(--blue)}.tprog-fill.review{background:var(--violet)}.tprog-fill.blocked{background:var(--red)}.tprog-fill.completed{background:var(--green)}
.tprog-pct{font-family:var(--font-mono);font-size:11px;color:var(--txm);min-width:28px}
.tfs-id{font-family:var(--font-mono);font-size:12px;color:var(--blue);white-space:nowrap}
.pcell{display:flex;align-items:center;gap:6px;color:var(--txs)}

