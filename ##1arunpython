package com.example.aspconverter;

import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.InputStream;
import java.io.OutputStream;
import java.nio.file.*;
import java.util.HashMap;
import java.util.List;
import java.util.Locale;
import java.util.Map;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class AspFileConverter {

    // Hardcoded paths
    private static final String INPUT_FOLDER = "C:/Users/InputFiles/";
    private static final String OUTPUT_FOLDER = "C:/Users/OutputFiles/";

    private static final List<String> SUPPORTED_EXTENSIONS = List.of(".xls", ".xlsx");

    // Required source headers
    private static final String HCPCS_HEADER = "HCPCS Code";
    private static final String PAYMENT_LIMIT_HEADER = "Payment Limit";

    // Output headers
    private static final String OUTPUT_PROCEDURE_CODE = "Procedure Code";
    private static final String OUTPUT_MODIFIER1 = "Modifier1";
    private static final String OUTPUT_NEW_RATE = "New Rate";

    // Month lookup
    private static final Map<String, String> MONTH_LOOKUP = createMonthLookup();

    public static void main(String[] args) {
        try {
            convertAllFiles();
            System.out.println("All files processed successfully.");
        } catch (Exception e) {
            System.err.println("Error while processing files: " + e.getMessage());
            e.printStackTrace();
        }
    }

    private static void convertAllFiles() throws Exception {
        Path inputPath = Paths.get(INPUT_FOLDER);
        Path outputPath = Paths.get(OUTPUT_FOLDER);

        if (!Files.exists(inputPath) || !Files.isDirectory(inputPath)) {
            throw new IllegalArgumentException("Input folder does not exist: " + INPUT_FOLDER);
        }

        if (!Files.exists(outputPath)) {
            Files.createDirectories(outputPath);
        }

        try (DirectoryStream<Path> stream = Files.newDirectoryStream(inputPath)) {
            for (Path file : stream) {
                if (Files.isRegularFile(file) && isExcelFile(file)) {
                    System.out.println("Processing: " + file.getFileName());
                    try {
                        processFile(file, outputPath);
                    } catch (Exception e) {
                        System.err.println("Failed to process file: " + file.getFileName());
                        System.err.println("Reason: " + e.getMessage());
                    }
                }
            }
        }
    }

    private static boolean isExcelFile(Path file) {
        String fileName = file.getFileName().toString().toLowerCase(Locale.ROOT);
        return SUPPORTED_EXTENSIONS.stream().anyMatch(fileName::endsWith);
    }

    private static void processFile(Path sourceFile, Path outputFolder) throws Exception {
        try (InputStream inputStream = Files.newInputStream(sourceFile);
             Workbook sourceWorkbook = WorkbookFactory.create(inputStream);
             Workbook outputWorkbook = new XSSFWorkbook()) {

            Sheet sourceSheet = sourceWorkbook.getSheetAt(0);
            HeaderInfo headerInfo = findHeaderRow(sourceSheet);

            if (headerInfo == null) {
                throw new IllegalStateException("Required headers not found in source file.");
            }

            Sheet outputSheet = outputWorkbook.createSheet("ASP Output");

            DataFormat dataFormat = outputWorkbook.createDataFormat();

            CellStyle headerStyle = outputWorkbook.createCellStyle();
            Font boldFont = outputWorkbook.createFont();
            boldFont.setBold(true);
            headerStyle.setFont(boldFont);

            CellStyle textStyle = outputWorkbook.createCellStyle();
            textStyle.setDataFormat(dataFormat.getFormat("@"));

            CellStyle rateStyle = outputWorkbook.createCellStyle();
            rateStyle.setDataFormat(dataFormat.getFormat("0.0000"));

            // Output header row
            Row headerRow = outputSheet.createRow(0);

            Cell h1 = headerRow.createCell(0);
            h1.setCellValue(OUTPUT_PROCEDURE_CODE);
            h1.setCellStyle(headerStyle);

            Cell h2 = headerRow.createCell(1);
            h2.setCellValue(OUTPUT_MODIFIER1);
            h2.setCellStyle(headerStyle);

            Cell h3 = headerRow.createCell(2);
            h3.setCellValue(OUTPUT_NEW_RATE);
            h3.setCellStyle(headerStyle);

            DataFormatter formatter = new DataFormatter();
            int outputRowNum = 1;

            for (int rowIndex = headerInfo.headerRowIndex + 1; rowIndex <= sourceSheet.getLastRowNum(); rowIndex++) {
                Row sourceRow = sourceSheet.getRow(rowIndex);
                if (sourceRow == null) {
                    continue;
                }

                String hcpcsCode = getCellValueAsString(sourceRow.getCell(headerInfo.hcpcsCodeColIndex), formatter).trim();
                String paymentLimit = getCellValueAsString(sourceRow.getCell(headerInfo.paymentLimitColIndex), formatter).trim();

                if (hcpcsCode.isEmpty() && paymentLimit.isEmpty()) {
                    continue;
                }

                Row outputRow = outputSheet.createRow(outputRowNum++);

                // Procedure Code
                Cell procedureCodeCell = outputRow.createCell(0);
                procedureCodeCell.setCellValue(hcpcsCode);
                procedureCodeCell.setCellStyle(textStyle);

                // Modifier1 -> blank
                Cell modifier1Cell = outputRow.createCell(1);
                modifier1Cell.setCellValue("");
                modifier1Cell.setCellStyle(textStyle);

                // New Rate
                Cell newRateCell = outputRow.createCell(2);
                Double numericRate = parsePaymentLimit(paymentLimit);

                if (numericRate != null) {
                    newRateCell.setCellValue(numericRate);
                    newRateCell.setCellStyle(rateStyle);
                } else {
                    newRateCell.setCellValue("");
                    newRateCell.setCellStyle(textStyle);
                }
            }

            outputSheet.autoSizeColumn(0);
            outputSheet.autoSizeColumn(1);
            outputSheet.autoSizeColumn(2);

            String outputFileName = buildOutputFileName(sourceFile.getFileName().toString());
            Path outputFile = outputFolder.resolve(outputFileName);

            try (OutputStream outputStream = Files.newOutputStream(outputFile)) {
                outputWorkbook.write(outputStream);
            }

            System.out.println("Created output file: " + outputFile.getFileName());
        }
    }

    private static HeaderInfo findHeaderRow(Sheet sheet) {
        DataFormatter formatter = new DataFormatter();

        for (int rowIndex = 0; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
            Row row = sheet.getRow(rowIndex);
            if (row == null) {
                continue;
            }

            Integer hcpcsIndex = null;
            Integer paymentLimitIndex = null;

            short lastCellNum = row.getLastCellNum();
            if (lastCellNum < 0) {
                continue;
            }

            for (int colIndex = 0; colIndex < lastCellNum; colIndex++) {
                Cell cell = row.getCell(colIndex);
                String cellValue = formatter.formatCellValue(cell);

                String normalizedHeader = normalizeHeader(cellValue);

                if (normalizedHeader.equals(normalizeHeader(HCPCS_HEADER))) {
                    hcpcsIndex = colIndex;
                }

                if (normalizedHeader.equals(normalizeHeader(PAYMENT_LIMIT_HEADER))) {
                    paymentLimitIndex = colIndex;
                }
            }

            if (hcpcsIndex != null && paymentLimitIndex != null) {
                return new HeaderInfo(rowIndex, hcpcsIndex, paymentLimitIndex);
            }
        }

        return null;
    }

    private static String normalizeHeader(String value) {
        if (value == null) {
            return "";
        }
        return value.replaceAll("[^A-Za-z0-9]", "")
                .toLowerCase(Locale.ROOT)
                .trim();
    }

    private static String getCellValueAsString(Cell cell, DataFormatter formatter) {
        if (cell == null) {
            return "";
        }
        return formatter.formatCellValue(cell);
    }

    private static Double parsePaymentLimit(String value) {
        if (value == null || value.trim().isEmpty()) {
            return null;
        }

        String cleaned = value.replaceAll("[$,\\s]", "").trim();

        if (cleaned.isEmpty()) {
            return null;
        }

        try {
            return Double.parseDouble(cleaned);
        } catch (NumberFormatException e) {
            return null;
        }
    }

    /**
     * Handles:
     * January 2025
     * Jan 2025
     * JAN_2025
     * APR-2025
     * Sept 2025
     * september_2025
     */
    private static String buildOutputFileName(String sourceFileName) {
        Pattern pattern = Pattern.compile(
                "(?i)\\b(" +
                        "jan(?:uary)?|" +
                        "feb(?:ruary)?|" +
                        "mar(?:ch)?|" +
                        "apr(?:il)?|" +
                        "may|" +
                        "jun(?:e)?|" +
                        "jul(?:y)?|" +
                        "aug(?:ust)?|" +
                        "sep(?:t|tember)?|" +
                        "oct(?:ober)?|" +
                        "nov(?:ember)?|" +
                        "dec(?:ember)?" +
                        ")\\b[\\s_\\-]+(\\d{4})\\b"
        );

        Matcher matcher = pattern.matcher(sourceFileName);

        if (matcher.find()) {
            String rawMonth = matcher.group(1);
            String year = matcher.group(2);

            String month = normalizeMonth(rawMonth);
            return month + " " + year + "_ASP.xlsx";
        }

        throw new IllegalArgumentException("Month and Year not found in source file name: " + sourceFileName);
    }

    private static String normalizeMonth(String rawMonth) {
        if (rawMonth == null || rawMonth.isBlank()) {
            throw new IllegalArgumentException("Month value is blank.");
        }

        String key = rawMonth.toLowerCase(Locale.ROOT).trim();

        String normalizedMonth = MONTH_LOOKUP.get(key);
        if (normalizedMonth != null) {
            return normalizedMonth;
        }

        throw new IllegalArgumentException("Unsupported month value found in file name: " + rawMonth);
    }

    private static Map<String, String> createMonthLookup() {
        Map<String, String> map = new HashMap<>();

        map.put("jan", "January");
        map.put("january", "January");

        map.put("feb", "February");
        map.put("february", "February");

        map.put("mar", "March");
        map.put("march", "March");

        map.put("apr", "April");
        map.put("april", "April");

        map.put("may", "May");

        map.put("jun", "June");
        map.put("june", "June");

        map.put("jul", "July");
        map.put("july", "July");

        map.put("aug", "August");
        map.put("august", "August");

        map.put("sep", "September");
        map.put("sept", "September");
        map.put("september", "September");

        map.put("oct", "October");
        map.put("october", "October");

        map.put("nov", "November");
        map.put("november", "November");

        map.put("dec", "December");
        map.put("december", "December");

        return map;
    }

    private static class HeaderInfo {
        private final int headerRowIndex;
        private final int hcpcsCodeColIndex;
        private final int paymentLimitColIndex;

        public HeaderInfo(int headerRowIndex, int hcpcsCodeColIndex, int paymentLimitColIndex) {
            this.headerRowIndex = headerRowIndex;
            this.hcpcsCodeColIndex = hcpcsCodeColIndex;
            this.paymentLimitColIndex = paymentLimitColIndex;
        }
    }
}
