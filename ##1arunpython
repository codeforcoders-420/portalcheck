import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFCellStyle;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;

import java.io.IOException;
import java.io.InputStream;
import java.io.OutputStream;
import java.math.BigDecimal;
import java.math.RoundingMode;
import java.nio.file.Files;
import java.nio.file.Path;
import java.text.DecimalFormat;
import java.text.ParseException;
import java.text.SimpleDateFormat;
import java.util.*;
import java.util.stream.Collectors;

public class FeeScheduleTransformerDME {

    private static final String OUTPUT_FILE_NAME = "MS MCD DME.xlsx";
    private static final String TARGET_SHEET_NAME = "Change File Report";
    private static final List<String> OUTPUT_HEADERS = List.of(
            "SCH NAME", "Procedure Code", "Modifier1", "Modifier2", "Modifier3", "Modifier4",
            "Effective Date", "End Date", "Pricing Method", "New Rate", "Old Rate", "Comments"
    );

    private static final List<String> DME_REQUIRED_HEADERS = List.of(
            "Code", "Modifier 1", "Modifier 2", "Modifier 3", "Modifier 4",
            "Rate Type", "Begin Date", "End Date", "Fee"
    );

    private static final List<String> MANUAL_REQUIRED_HEADERS = List.of(
            "Procedure Code", "Modifier", "Pricing Indicator", "DOS From", "DOS Thru", "Rate Type"
    );

    private static final String MIN_EFFECTIVE_DATE = "01/01/2022";
    private static final String OPEN_END_DATE = "12/31/9999";
    private static final SimpleDateFormat SOURCE_MMDDYYYY = new SimpleDateFormat("MM/dd/yyyy");
    private static final SimpleDateFormat SOURCE_YYYYMMDD = new SimpleDateFormat("yyyyMMdd");
    private static final DecimalFormat RATE_FORMAT = new DecimalFormat("0.0000");

    static {
        SOURCE_MMDDYYYY.setLenient(false);
        SOURCE_YYYYMMDD.setLenient(false);
    }

    public static void main(String[] args) throws Exception {
        Path input = Path.of("/mnt/data/WEB-Durable-Medical-Equipment-Fee-Schedule-FEBRUARY-2026-FNL21326.xlsx");
        Path output = Path.of("/mnt/data/" + OUTPUT_FILE_NAME);
        transform(input, output);
        System.out.println("Created: " + output.toAbsolutePath());
    }

    public static void transform(Path inputFile, Path outputFile) throws IOException {
        try (InputStream is = Files.newInputStream(inputFile);
             Workbook sourceWorkbook = WorkbookFactory.create(is);
             XSSFWorkbook targetWorkbook = new XSSFWorkbook()) {

            Sheet dmeSheet = findSheetContaining(sourceWorkbook, "DME")
                    .orElseThrow(() -> new IllegalArgumentException("No source sheet found containing 'DME'"));

            Sheet manualSheet = findSheetContaining(sourceWorkbook, "PAY0-SYSMAN-PAPRICE")
                    .or(() -> findSheetContaining(sourceWorkbook, "PAPRICE"))
                    .orElseThrow(() -> new IllegalArgumentException("No manual sheet found containing 'PAY0-SYSMAN-PAPRICE' or 'PAPRICE'"));

            HeaderContext dmeHeader = locateHeaderRow(dmeSheet, DME_REQUIRED_HEADERS);
            HeaderContext manualHeader = locateHeaderRow(manualSheet, MANUAL_REQUIRED_HEADERS);

            List<OutputRecord> outputRecords = new ArrayList<>();
            outputRecords.addAll(readDmeMainSheet(dmeSheet, dmeHeader));
            outputRecords.addAll(readManualSheet(manualSheet, manualHeader));

            writeOutputWorkbook(targetWorkbook, outputRecords);

            try (OutputStream os = Files.newOutputStream(outputFile)) {
                targetWorkbook.write(os);
            }
        } catch (Exception ex) {
            if (ex instanceof IOException ioException) {
                throw ioException;
            }
            throw new IOException("Failed to transform workbook", ex);
        }
    }

    private static List<OutputRecord> readDmeMainSheet(Sheet sheet, HeaderContext headerContext) {
        List<OutputRecord> records = new ArrayList<>();
        for (int rowIndex = headerContext.headerRowIndex() + 1; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
            Row row = sheet.getRow(rowIndex);
            if (row == null || isEffectivelyBlank(row)) {
                continue;
            }

            String code = cellText(row, headerContext.indexOf("Code"));
            String rateType = cellText(row, headerContext.indexOf("Rate Type"));
            if (isBlank(code) || !"DEF".equalsIgnoreCase(rateType.trim())) {
                continue;
            }

            OutputRecord rec = new OutputRecord();
            rec.schName = "MS MCD DME";
            rec.procedureCode = code;
            rec.modifier1 = cellText(row, headerContext.indexOf("Modifier 1"));
            rec.modifier2 = cellText(row, headerContext.indexOf("Modifier 2"));
            rec.modifier3 = cellText(row, headerContext.indexOf("Modifier 3"));
            rec.modifier4 = cellText(row, headerContext.indexOf("Modifier 4"));
            rec.effectiveDate = normalizeEffectiveDate(cellText(row, headerContext.indexOf("Begin Date")));
            rec.endDate = normalizeEndDate(cellText(row, headerContext.indexOf("End Date")));
            rec.pricingMethod = "Allowed";
            rec.newRate = formatRate(cellText(row, headerContext.indexOf("Fee")));
            rec.oldRate = "N/A";
            rec.comments = "New Code";
            records.add(rec);
        }
        return records;
    }

    private static List<OutputRecord> readManualSheet(Sheet sheet, HeaderContext headerContext) {
        List<OutputRecord> records = new ArrayList<>();
        for (int rowIndex = headerContext.headerRowIndex() + 1; rowIndex <= sheet.getLastRowNum(); rowIndex++) {
            Row row = sheet.getRow(rowIndex);
            if (row == null || isEffectivelyBlank(row)) {
                continue;
            }

            String code = cellText(row, headerContext.indexOf("Procedure Code"));
            String rateType = cellText(row, headerContext.indexOf("Rate Type"));
            String pricingIndicator = cellText(row, headerContext.indexOf("Pricing Indicator"));
            if (isBlank(code) || !"DEF".equalsIgnoreCase(rateType.trim()) || !"PAPRIC".equalsIgnoreCase(pricingIndicator.trim())) {
                continue;
            }

            List<String> modTokens = expandModifierTokens(cellText(row, headerContext.indexOf("Modifier")));
            if (modTokens.isEmpty()) {
                modTokens = List.of("");
            }

            for (String mod : modTokens) {
                OutputRecord rec = new OutputRecord();
                rec.schName = "MS MCD DME";
                rec.procedureCode = code;
                rec.modifier1 = mod;
                rec.modifier2 = "";
                rec.modifier3 = "";
                rec.modifier4 = "";
                rec.effectiveDate = normalizeEffectiveDate(cellText(row, headerContext.indexOf("DOS From")));
                rec.endDate = normalizeEndDate(cellText(row, headerContext.indexOf("DOS Thru")));
                rec.pricingMethod = "By Report";
                rec.newRate = "0.0000";
                rec.oldRate = "N/A";
                rec.comments = "New Code";
                records.add(rec);
            }
        }
        return records;
    }

    private static List<String> expandModifierTokens(String rawModifier) {
        if (isBlank(rawModifier)) {
            return new ArrayList<>();
        }

        String cleaned = rawModifier.trim();
        // Handle formats like |<NU RB>|1, <NU RB>, NU RB, NU, RB
        cleaned = cleaned.replace("|", " ")
                .replace("<", " ")
                .replace(">", " ")
                .replace("~", " ")
                .replace("^", " ");

        cleaned = cleaned.replaceAll("\\b\\d+\\b", " ");
        cleaned = cleaned.replaceAll("\\s+", " ").trim();
        if (cleaned.isEmpty()) {
            return new ArrayList<>();
        }

        return Arrays.stream(cleaned.split("\\s+"))
                .map(String::trim)
                .filter(s -> !s.isEmpty())
                .collect(Collectors.toList());
    }

    private static void writeOutputWorkbook(XSSFWorkbook workbook, List<OutputRecord> records) {
        Sheet sheet = workbook.createSheet(TARGET_SHEET_NAME);

        XSSFCellStyle textStyle = workbook.createCellStyle();
        DataFormat dataFormat = workbook.createDataFormat();
        textStyle.setDataFormat(dataFormat.getFormat("@"));

        Row headerRow = sheet.createRow(0);
        for (int col = 0; col < OUTPUT_HEADERS.size(); col++) {
            createTextCell(headerRow, col, OUTPUT_HEADERS.get(col), textStyle);
        }

        int rowIndex = 1;
        for (OutputRecord record : records) {
            Row row = sheet.createRow(rowIndex++);
            createTextCell(row, 0, record.schName, textStyle);
            createTextCell(row, 1, record.procedureCode, textStyle);
            createTextCell(row, 2, record.modifier1, textStyle);
            createTextCell(row, 3, record.modifier2, textStyle);
            createTextCell(row, 4, record.modifier3, textStyle);
            createTextCell(row, 5, record.modifier4, textStyle);
            createTextCell(row, 6, record.effectiveDate, textStyle);
            createTextCell(row, 7, record.endDate, textStyle);
            createTextCell(row, 8, record.pricingMethod, textStyle);
            createTextCell(row, 9, record.newRate, textStyle);
            createTextCell(row, 10, record.oldRate, textStyle);
            createTextCell(row, 11, record.comments, textStyle);
        }

        for (int i = 0; i < OUTPUT_HEADERS.size(); i++) {
            sheet.autoSizeColumn(i);
        }
    }

    private static void createTextCell(Row row, int colIndex, String value, CellStyle style) {
        Cell cell = row.createCell(colIndex, CellType.STRING);
        cell.setCellStyle(style);
        cell.setCellValue(value == null ? "" : value);
    }

    private static Optional<Sheet> findSheetContaining(Workbook workbook, String keyword) {
        String lowered = keyword.toLowerCase(Locale.ROOT);
        for (int i = 0; i < workbook.getNumberOfSheets(); i++) {
            Sheet sheet = workbook.getSheetAt(i);
            if (sheet.getSheetName().toLowerCase(Locale.ROOT).contains(lowered)) {
                return Optional.of(sheet);
            }
        }
        return Optional.empty();
    }

    private static HeaderContext locateHeaderRow(Sheet sheet, List<String> requiredHeaders) {
        DataFormatter formatter = new DataFormatter();
        for (int rowIndex = sheet.getFirstRowNum(); rowIndex <= sheet.getLastRowNum(); rowIndex++) {
            Row row = sheet.getRow(rowIndex);
            if (row == null) {
                continue;
            }
            Map<String, Integer> headerIndex = new HashMap<>();
            for (Cell cell : row) {
                String value = normalizeHeader(formatter.formatCellValue(cell));
                if (!value.isEmpty()) {
                    headerIndex.put(value, cell.getColumnIndex());
                }
            }
            boolean allPresent = requiredHeaders.stream()
                    .map(FeeScheduleTransformerDME::normalizeHeader)
                    .allMatch(headerIndex::containsKey);
            if (allPresent) {
                return new HeaderContext(rowIndex, headerIndex);
            }
        }
        throw new IllegalArgumentException("Unable to locate header row in sheet: " + sheet.getSheetName());
    }

    private static String normalizeHeader(String value) {
        return value == null ? "" : value.trim().replace('\n', ' ').replaceAll("\\s+", " ");
    }

    private static boolean isEffectivelyBlank(Row row) {
        DataFormatter formatter = new DataFormatter();
        for (Cell cell : row) {
            if (!formatter.formatCellValue(cell).trim().isEmpty()) {
                return false;
            }
        }
        return true;
    }

    private static String cellText(Row row, int colIndex) {
        if (colIndex < 0) {
            return "";
        }
        Cell cell = row.getCell(colIndex, Row.MissingCellPolicy.RETURN_BLANK_AS_NULL);
        if (cell == null) {
            return "";
        }
        DataFormatter formatter = new DataFormatter();
        return formatter.formatCellValue(cell).trim();
    }

    private static boolean isBlank(String value) {
        return value == null || value.trim().isEmpty();
    }

    private static String normalizeEffectiveDate(String raw) {
        if (isBlank(raw)) {
            return "";
        }
        Date parsed = parseDate(raw);
        if (parsed == null) {
            return raw.trim();
        }
        Date min = parseDate(MIN_EFFECTIVE_DATE);
        return parsed.before(min) ? MIN_EFFECTIVE_DATE : SOURCE_MMDDYYYY.format(parsed);
    }

    private static String normalizeEndDate(String raw) {
        if (isBlank(raw)) {
            return "";
        }
        String trimmed = raw.trim();
        if ("12/31/2299".equals(trimmed) || "22991231".equals(trimmed)) {
            return OPEN_END_DATE;
        }
        Date parsed = parseDate(trimmed);
        return parsed == null ? trimmed : SOURCE_MMDDYYYY.format(parsed);
    }

    private static Date parseDate(String raw) {
        if (isBlank(raw)) {
            return null;
        }
        List<SimpleDateFormat> formats = List.of(
                SOURCE_MMDDYYYY,
                SOURCE_YYYYMMDD,
                new SimpleDateFormat("M/d/yyyy"),
                new SimpleDateFormat("MM-dd-yyyy"),
                new SimpleDateFormat("yyyy-MM-dd")
        );
        for (SimpleDateFormat format : formats) {
            format.setLenient(false);
            try {
                return format.parse(raw.trim());
            } catch (ParseException ignored) {
            }
        }
        return null;
    }

    private static String formatRate(String raw) {
        if (isBlank(raw)) {
            return "";
        }
        String cleaned = raw.replace("$", "").replace(",", "").trim();
        try {
            BigDecimal value = new BigDecimal(cleaned).setScale(4, RoundingMode.HALF_UP);
            return RATE_FORMAT.format(value);
        } catch (NumberFormatException ex) {
            return raw.trim();
        }
    }

    private record HeaderContext(int headerRowIndex, Map<String, Integer> headers) {
        int indexOf(String header) {
            return headers.getOrDefault(normalizeHeader(header), -1);
        }
    }

    private static final class OutputRecord {
        String schName;
        String procedureCode;
        String modifier1;
        String modifier2;
        String modifier3;
        String modifier4;
        String effectiveDate;
        String endDate;
        String pricingMethod;
        String newRate;
        String oldRate;
        String comments;
    }
}
