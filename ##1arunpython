/* SPARKLINE */
function spk(data,sync){
  const W=80,H=28,max=Math.max(...data,1);
  const pts=data.map((v,i)=>[(i/(data.length-1))*W, H-(v/max)*(H-4)+2]);
  const d=pts.map((p,i)=>`${i===0?'M':'L'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
  const fill=`${d} L${W},${H} L0,${H} Z`;
  const c=sync==='synced'?'#34d399':sync==='stale'?'#fbbf24':'#f87171';
  const fc=sync==='synced'?'rgba(52,211,153,.09)':sync==='stale'?'rgba(251,191,36,.09)':'rgba(248,113,113,.09)';
  const lp=pts[pts.length-1];
  return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" style="overflow:visible"><path d="${fill}" fill="${fc}"/><path d="${d}" fill="none" stroke="${c}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="${lp[0].toFixed(1)}" cy="${lp[1].toFixed(1)}" r="2.5" fill="${c}"/></svg>`;
}

/* GAUGE */
function gauge(pct,color){
  const r=16,cx=20,cy=20,circ=2*Math.PI*r,dash=(pct/100)*circ;
