<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TFS Workflow Applications</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #334155; border-radius: 20px; }
        .loader { border: 3px solid #f3f3f3; border-bottom-color: #2563eb; border-radius: 50%; width: 48px; height: 48px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .chat-container { scroll-behavior: smooth; }
    </style>
</head>
<body class="flex h-screen bg-slate-50 font-sans text-slate-800 overflow-hidden">

    <!-- Sidebar -->
    <div class="w-[280px] bg-[#1a202c] flex flex-col h-full flex-shrink-0 shadow-lg z-10">
        <div class="p-6 pb-2">
            <h2 class="text-slate-400 text-[11px] font-bold tracking-widest uppercase">Applications</h2>
        </div>
        <div class="flex-1 overflow-y-auto py-2 custom-scrollbar">
            <nav class="flex flex-col px-3 gap-0.5" id="app-nav"></nav>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col h-full overflow-hidden relative">
        <!-- Header -->
        <header class="bg-white border-b border-gray-200 flex items-center justify-between px-8 py-3 flex-shrink-0 z-10">
            <div class="flex items-start gap-6">
                <button class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 font-medium transition-colors mt-1">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    Back to Home
                </button>
                <div class="h-full w-px bg-gray-300 self-stretch"></div>
                <div class="flex flex-col gap-2">
                    <h1 class="text-lg font-semibold text-indigo-950">Workflow of TFS #####</h1>
                    <div class="flex items-center gap-3 text-[12px] flex-wrap">
                        <div class="flex items-center gap-1.5 bg-blue-50/50 text-blue-700 px-2.5 py-1 rounded-md border border-blue-100/50 shadow-sm">
                            <span class="text-blue-500/90 font-medium">Fee Schedule:</span>
                            <span id="fee-schedule-value" class="font-bold tracking-wide">XXXX</span>
                        </div>
                        <div class="flex items-center gap-1.5 bg-slate-50 text-slate-600 px-2.5 py-1 rounded-md border border-slate-200/70 shadow-sm">
                            <span class="text-slate-500 font-medium">Config Last Updated:</span>
                            <span id="config-last-updated-value" class="font-bold tracking-wide">XXXX</span>
                        </div>
                        <div class="flex items-center gap-1.5 bg-slate-50 text-slate-600 px-2.5 py-1 rounded-md border border-slate-200/70 shadow-sm">
                            <span class="text-slate-500 font-medium">Config Last Updated By:</span>
                            <span id="config-last-updated-by-value" class="font-bold tracking-wide">XXXX</span>
                        </div>
                        <div class="flex items-center gap-1.5 bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-md border border-emerald-100/50 shadow-sm">
                            <span class="text-emerald-600 font-medium">PROD Last Updated:</span>
                            <span id="prod-last-updated-value" class="font-bold tracking-wide">XXXX</span>
                        </div>
                        <div class="flex items-center gap-1.5 bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-md border border-emerald-100/50 shadow-sm">
                            <span class="text-emerald-600 font-medium">PROD Last Updated By:</span>
                            <span id="prod-last-updated-by-value" class="font-bold tracking-wide">XXXX</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-sm font-medium text-gray-400 mt-1">MN Team Portal</div>
        </header>

        <!-- Scrollable Form Content -->
        <div class="flex-1 overflow-y-auto p-6 md:p-10 relative bg-[#f4f7fa]">
            <div class="max-w-[900px] mx-auto bg-white rounded-2xl shadow-sm border border-gray-200/60 p-8 md:p-10 relative overflow-hidden">
                <div id="loader-overlay" class="hidden absolute inset-0 bg-white/80 backdrop-blur-sm z-50 flex flex-col items-center justify-center transition-opacity">
                    <div class="loader mb-4"></div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Running <span id="running-app-name">Application</span>...</h3>
                    <p class="text-gray-500 text-sm">Please wait while the process completes.</p>
                </div>
                <div class="mb-8 border-b border-gray-100 pb-6">
                    <h2 id="app-title" class="text-2xl font-bold text-gray-900 mb-1">Change File Generator</h2>
                    <p id="app-desc" class="text-gray-500 text-sm">Select source file and run scrub analysis to generate change files.</p>
                </div>
                <div id="form-container"></div>
            </div>
        </div>
    </div>

    <!-- AI Agent Modal -->
    <div id="ai-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl h-[80vh] flex flex-col">
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-purple-50 to-blue-50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-r from-purple-600 to-blue-600 flex items-center justify-center">
                        <i data-lucide="sparkles" class="w-5 h-5 text-white"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-gray-900">AI Scrub Assistant</h3>
                        <p class="text-xs text-gray-600">Processing: <span id="ai-file-name"></span></p>
                    </div>
                </div>
                <button onclick="closeAIModal()" class="w-8 h-8 rounded-full hover:bg-gray-200 flex items-center justify-center transition-colors">
                    <i data-lucide="x" class="w-5 h-5 text-gray-600"></i>
                </button>
            </div>
            <div id="ai-messages" class="flex-1 overflow-y-auto p-6 space-y-4 chat-container"></div>
            <div class="border-t border-gray-200 p-4 bg-gray-50">
                <div class="flex gap-3">
                    <input type="text" id="ai-prompt-input" onkeypress="if(event.key==='Enter') sendAIPrompt()" placeholder="Describe how you want to scrub the file..." class="flex-1 bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-purple-500/20 focus:border-purple-500 block p-3 transition-all outline-none placeholder:text-gray-400" />
                    <button onclick="sendAIPrompt()" class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white text-sm font-semibold py-3 px-6 rounded-lg transition-all focus:ring-4 focus:ring-purple-200 shadow-sm">
                        <i data-lucide="send" class="w-4 h-4"></i> Send
                    </button>
                </div>
                <p class="text-xs text-gray-500 mt-2">Try: "Remove all PII data and mask credit cards" or "Filter records from 2024 only"</p>
            </div>
        </div>
    </div>

    <script>
        const applications = [
            { id: 1, name: 'Change File Generator', title: 'Change File Generator', desc: 'Select source file and run scrub analysis to generate change files.', icon: 'file-text' },
            { id: 2, name: 'Application 2', title: 'Application 2 - Database Sync', desc: 'Synchronize database records across environments.', icon: 'database' },
            { id: 3, name: 'Application 3', title: 'Application 3 - Task Management', desc: 'Manage and assign pending workflow tasks.', icon: 'clipboard-list' },
            { id: 4, name: 'Application 4', title: 'Application 4 - System Options', desc: 'Adjust global system options and parameters.', icon: 'settings-2' },
            { id: 5, name: 'Application 5', title: 'Application 5 - Analytics Engine', desc: 'Run detailed analytics on workflow performance.', icon: 'bar-chart-2' },
            { id: 6, name: 'Application 6', title: 'Application 6 - Cloud Deployment', desc: 'Deploy packaged workflows to cloud environments.', icon: 'cloud' },
            { id: 7, name: 'Application 7', title: 'Application 7 - Scheduler', desc: 'Schedule recurring workflow executions.', icon: 'clock' },
            { id: 8, name: 'Application 8', title: 'Application 8 - Audit Logs', desc: 'Review and verify system audit logs.', icon: 'file-check' },
            { id: 9, name: 'Application 9', title: 'Application 9 - Portfolio Manager', desc: 'Manage workflow portfolios and groups.', icon: 'briefcase' },
            { id: 10, name: 'Application 10', title: 'Application 10 - Advanced Settings', desc: 'Configure advanced system properties.', icon: 'settings' },
            { id: 11, name: 'Application 11', title: 'Application 11 - User Access', desc: 'Manage user roles and access permissions.', icon: 'users' },
            { id: 12, name: 'Application 12', title: 'Application 12 - Security Scan', desc: 'Run security vulnerability scans on workflows.', icon: 'shield' },
        ];

        let activeAppId = 1, selectedFile = null, outputLocation = '', aiMessages = [];
        const navContainer = document.getElementById('app-nav');

        function updateHeaderValues(feeSchedule, configLastUpdated, configLastUpdatedBy, prodLastUpdated, prodLastUpdatedBy) {
            if (feeSchedule) document.getElementById('fee-schedule-value').textContent = feeSchedule;
            if (configLastUpdated) document.getElementById('config-last-updated-value').textContent = configLastUpdated;
            if (configLastUpdatedBy) document.getElementById('config-last-updated-by-value').textContent = configLastUpdatedBy;
            if (prodLastUpdated) document.getElementById('prod-last-updated-value').textContent = prodLastUpdated;
            if (prodLastUpdatedBy) document.getElementById('prod-last-updated-by-value').textContent = prodLastUpdatedBy;
        }

        function renderSidebar() {
            navContainer.innerHTML = applications.map(app => {
                const isActive = app.id === activeAppId;
                const baseClasses = "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 w-full text-left";
                const activeClasses = isActive ? "bg-blue-600/15 text-blue-400 shadow-[inset_4px_0_0_0_#3b82f6]" : "text-slate-300 hover:bg-slate-800 hover:text-white";
                const iconColor = isActive ? "text-blue-400" : "text-slate-400";
                return `<button onclick="switchApp(${app.id})" class="${baseClasses} ${activeClasses}"><i data-lucide="${app.icon}" class="w-[18px] h-[18px] ${iconColor}"></i>${app.name}</button>`;
            }).join('');
            lucide.createIcons();
        }

        function renderForm() {
            const formContainer = document.getElementById('form-container');
            if (activeAppId === 1) {
                const feeSchedule = document.getElementById('fee-schedule-value').textContent;
                formContainer.innerHTML = `
                    <div class="bg-[#f0f7ff] border border-[#dbeafe] rounded-xl p-4 flex items-start gap-3 mb-8">
                        <i data-lucide="info" class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0"></i>
                        <div class="flex-1">
                            <h4 class="text-sm font-semibold text-blue-900 mb-1">Configuration</h4>
                            <p class="text-[13px] text-blue-800/80 font-medium">Fee Schedule ID: <span class="font-bold text-blue-900">${feeSchedule}</span></p>
                        </div>
                    </div>
                    <form class="space-y-6" onsubmit="event.preventDefault();">
                        <div class="space-y-1.5">
                            <label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Select Source File <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <input type="file" id="sourceFile" onchange="handleFileChange(event)" class="hidden" accept=".txt,.csv,.xlsx,.xls" />
                                <label for="sourceFile" class="flex items-center gap-3 w-full bg-white border-2 border-dashed border-gray-300 text-gray-700 text-sm rounded-lg hover:border-blue-400 hover:bg-blue-50/30 cursor-pointer p-6 transition-all">
                                    <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-blue-100">
                                        <i data-lucide="upload" class="w-6 h-6 text-blue-600"></i>
                                    </div>
                                    <div class="flex-1" id="file-upload-content">
                                        <p class="font-medium text-gray-700">Click to upload source file</p>
                                        <p class="text-xs text-gray-500 mt-0.5">Supports: TXT, CSV, XLSX, XLS</p>
                                    </div>
                                    <i data-lucide="check-circle-2" class="w-5 h-5 text-green-600 hidden" id="file-check-icon"></i>
                                </label>
                            </div>
                        </div>
                        <div id="output-location-container" class="space-y-1.5 hidden">
                            <label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Output Location</label>
                            <div class="flex items-center gap-3 bg-green-50 border border-green-200 rounded-lg p-4">
                                <i data-lucide="folder-open" class="w-5 h-5 text-green-600 flex-shrink-0"></i>
                                <code id="output-location-path" class="text-sm text-green-800 font-mono break-all"></code>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 pt-8 mt-4 flex-wrap">
                            <button type="button" id="run-btn" onclick="runApplication()" disabled class="inline-flex items-center gap-2 bg-[#1a56db] hover:bg-blue-800 text-white text-sm font-semibold py-2.5 px-6 rounded-lg transition-colors focus:ring-4 focus:ring-blue-200 disabled:opacity-70 disabled:cursor-not-allowed shadow-sm">
                                <i data-lucide="arrow-right" class="w-4 h-4"></i><span>Run Scrub Analysis</span>
                            </button>
                            <button type="button" id="genai-btn" onclick="openAIModal()" disabled class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white text-sm font-semibold py-2.5 px-6 rounded-lg transition-all focus:ring-4 focus:ring-purple-200 disabled:opacity-70 disabled:cursor-not-allowed shadow-sm">
                                <i data-lucide="sparkles" class="w-4 h-4"></i><span>Use GenAI</span>
                            </button>
                            <button type="button" onclick="resetForm()" class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold py-2.5 px-6 rounded-lg transition-colors focus:ring-4 focus:ring-gray-100 shadow-sm ml-auto">Reset</button>
                        </div>
                    </form>`;
            } else {
                formContainer.innerHTML = `<div class="bg-[#f0f7ff] border border-[#dbeafe] rounded-xl p-4 flex items-start gap-3 mb-8"><i data-lucide="info" class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0"></i><div><h4 class="text-sm font-semibold text-blue-900 mb-1">Story Information</h4><p class="text-[13px] text-blue-800/80 font-medium">Story ID: STY-0000 <span class="mx-2 text-blue-300">|</span> Year: N/A <span class="mx-2 text-blue-300">|</span> LOB: N/A <span class="mx-2 text-blue-300">|</span> FS: N/A</p></div></div><form class="space-y-6" onsubmit="event.preventDefault();"><div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6"><div class="space-y-1.5"><label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Environment <span class="text-red-500">*</span></label><div class="relative"><select class="w-full appearance-none bg-white border border-gray-300 text-gray-700 text-sm rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 block p-3 pr-10 transition-all outline-none"><option>Select Environment</option><option>Development</option><option>QA</option><option>Production</option></select><i data-lucide="chevron-down" class="w-4 h-4 text-gray-500 absolute right-3 top-3.5 pointer-events-none"></i></div></div><div class="space-y-1.5"><label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Region <span class="text-red-500">*</span></label><div class="relative"><select class="w-full appearance-none bg-white border border-gray-300 text-gray-700 text-sm rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 block p-3 pr-10 transition-all outline-none"><option>Select Region</option><option>US-East</option><option>US-West</option><option>EU-Central</option></select><i data-lucide="chevron-down" class="w-4 h-4 text-gray-500 absolute right-3 top-3.5 pointer-events-none"></i></div></div><div class="space-y-1.5"><label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Configuration Name</label><input type="text" placeholder="Enter configuration name" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 block p-3 transition-all outline-none placeholder:text-gray-400" /></div><div class="space-y-1.5"><label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Version</label><input type="text" placeholder="e.g., 1.0.0" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 block p-3 transition-all outline-none placeholder:text-gray-400" /></div></div><div class="space-y-1.5"><label class="text-sm font-semibold text-gray-700 flex items-center gap-1">Description</label><textarea rows="4" placeholder="Enter description..." class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 block p-3 transition-all outline-none resize-y placeholder:text-gray-400"></textarea></div><div class="flex items-center gap-3 pt-8 mt-4"><button type="button" onclick="runApplication()" class="inline-flex items-center gap-2 bg-[#1a56db] hover:bg-blue-800 text-white text-sm font-semibold py-2.5 px-6 rounded-lg transition-colors focus:ring-4 focus:ring-blue-200 shadow-sm"><i data-lucide="arrow-right" class="w-4 h-4"></i>Run Application</button><button type="button" class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold py-2.5 px-6 rounded-lg transition-colors focus:ring-4 focus:ring-gray-100 shadow-sm">Validate</button><button type="reset" class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold py-2.5 px-6 rounded-lg transition-colors focus:ring-4 focus:ring-gray-100 shadow-sm ml-auto">Reset</button></div></form>`;
            }
            lucide.createIcons();
        }

        // LINES 206-244: GenAI Modal Functions (NEW CODE - EXTRACT THIS SECTION)
        function openAIModal() {
            document.getElementById('ai-modal').classList.remove('hidden');
            document.getElementById('ai-file-name').textContent = selectedFile ? selectedFile.name : '';
            if (aiMessages.length === 0) {
                aiMessages = [{
                    role: 'assistant',
                    content: `Hello! I'm your AI assistant for file scrubbing. I can help you clean and process your source file: ${selectedFile?.name || 'your file'}.\n\nWhat would you like me to do? For example:\n- Remove sensitive data\n- Format data columns\n- Filter specific records\n- Validate data integrity`
                }];
                renderAIMessages();
            }
            lucide.createIcons();
        }

        function closeAIModal() {
            document.getElementById('ai-modal').classList.add('hidden');
        }

        function renderAIMessages() {
            const container = document.getElementById('ai-messages');
            container.innerHTML = aiMessages.map((msg, idx) => `
                <div class="flex gap-3 ${msg.role === 'user' ? 'justify-end' : 'justify-start'}">
                    ${msg.role === 'assistant' ? '<div class="w-8 h-8 rounded-full bg-gradient-to-r from-purple-600 to-blue-600 flex items-center justify-center flex-shrink-0"><i data-lucide="bot" class="w-4 h-4 text-white"></i></div>' : ''}
                    <div class="max-w-[70%] rounded-2xl px-4 py-3 ${msg.role === 'user' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-900'}">
                        <p class="text-sm whitespace-pre-line">${msg.content}</p>
                    </div>
                    ${msg.role === 'user' ? '<div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0"><i data-lucide="user" class="w-4 h-4 text-white"></i></div>' : ''}
                </div>
            `).join('');
            lucide.createIcons();
            container.scrollTop = container.scrollHeight;
        }

        function sendAIPrompt() {
            const input = document.getElementById('ai-prompt-input');
            const prompt = input.value.trim();
            if (!prompt) return;

            aiMessages.push({ role: 'user', content: prompt });
            input.value = '';
            renderAIMessages();

            const mockResponses = [
                `I've analyzed your request. I'll process the file "${selectedFile?.name}" and:\n\n1. Remove all PII (Personal Identifiable Information)\n2. Mask credit card numbers\n3. Anonymize email addresses\n4. Keep transaction IDs intact\n\nProcessing will take approximately 30 seconds. Shall I proceed?`,
                `Great! I'm starting the scrub process now.\n\n✓ Scanning 1,247 records...\n✓ Detected 89 sensitive fields\n✓ Applying transformation rules\n✓ Validating output format\n\nEstimated completion: 25 seconds`,
                `Processing complete! Here's the summary:\n\n• Total records processed: 1,247\n• Sensitive fields masked: 89\n• Data integrity: 100%\n• Output size: 2.3 MB\n\nThe scrubbed file is ready at:\n/output/change_files/${document.getElementById('fee-schedule-value').textContent}/${selectedFile?.name}_AI_scrubbed.txt\n\nWould you like me to generate a detailed transformation report?`
            ];

            setTimeout(() => {
                const userMsgCount = aiMessages.filter(m => m.role === 'user').length;
                const responseIdx = Math.min(userMsgCount - 1, mockResponses.length - 1);
                aiMessages.push({ role: 'assistant', content: mockResponses[responseIdx] });
                renderAIMessages();
            }, 1000);
        }
        // END OF GenAI SECTION

        function handleFileChange(event) {
            const file = event.target.files[0];
            if (file) {
                selectedFile = file;
                outputLocation = '';
                document.getElementById('file-upload-content').innerHTML = `<div class="flex items-center gap-2"><i data-lucide="file" class="w-4 h-4 text-green-600"></i><span class="font-medium text-gray-900">${file.name}</span><span class="text-xs text-gray-500">(${(file.size / 1024).toFixed(2)} KB)</span></div>`;
                document.getElementById('file-check-icon').classList.remove('hidden');
                document.getElementById('run-btn').disabled = false;
                document.getElementById('genai-btn').disabled = false;
                document.getElementById('output-location-container').classList.add('hidden');
                lucide.createIcons();
            }
        }

        function resetForm() {
            selectedFile = null;
            outputLocation = '';
            aiMessages = [];
            document.getElementById('sourceFile').value = '';
            document.getElementById('file-upload-content').innerHTML = `<p class="font-medium text-gray-700">Click to upload source file</p><p class="text-xs text-gray-500 mt-0.5">Supports: TXT, CSV, XLSX, XLS</p>`;
            document.getElementById('file-check-icon').classList.add('hidden');
            document.getElementById('run-btn').disabled = true;
            document.getElementById('genai-btn').disabled = true;
            document.getElementById('output-location-container').classList.add('hidden');
        }

        function switchApp(id) {
            activeAppId = id;
            const app = applications.find(a => a.id === id);
            document.getElementById('app-title').textContent = app.title;
            document.getElementById('app-desc').textContent = app.desc;
            document.getElementById('running-app-name').textContent = app.name;
            selectedFile = null;
            outputLocation = '';
            renderSidebar();
            renderForm();
        }

        function runApplication() {
            const loader = document.getElementById('loader-overlay');
            loader.classList.remove('hidden');
            setTimeout(() => {
                loader.classList.add('hidden');
                if (activeAppId === 1 && selectedFile) {
                    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
                    const feeSchedule = document.getElementById('fee-schedule-value').textContent;
                    const fileName = selectedFile.name.replace(/\.[^/.]+$/, '');
                    outputLocation = `/output/change_files/${feeSchedule}/${fileName}_scrubbed_${timestamp}.txt`;
                    document.getElementById('output-location-path').textContent = outputLocation;
                    document.getElementById('output-location-container').classList.remove('hidden');
                    lucide.createIcons();
                }
            }, 2500);
        }

        renderSidebar();
        renderForm();
        lucide.createIcons();
    </script>
</body>
</html>
