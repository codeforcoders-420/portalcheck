<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Engineering Workflow Portal - Login</title>
    <link rel="stylesheet" href="auth-styles.css">
    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <div class="container">
        <!-- Auth Card - Split Screen -->
        <div class="auth-card">
            <!-- Left Side - Welcome -->
            <div class="left-side">
                <div class="logo-section">
                    <div class="logo-badge">
                        <div class="logo-circle-app">
                            <i data-lucide="users" class="logo-icon-small"></i>
                            <i data-lucide="briefcase" class="logo-icon-tiny"></i>
                        </div>
                        <div class="app-name-text">
                            <span class="app-title">MN Team</span>
                            <span class="app-subtitle">Internal Portal</span>
                        </div>
                    </div>
                </div>

                <div id="leftContent" class="welcome-content">
                    <h1>WELCOME BACK !</h1>
                    <p>Enter your ID and Password to continue</p>
                </div>

                <div class="tech-decoration">
                    <i data-lucide="code-2"></i>
                    <i data-lucide="git-branch"></i>
                    <i data-lucide="terminal"></i>
                </div>
            </div>

            <!-- Right Side - Form -->
            <div class="right-side">
                <!-- Tech Pattern Background -->
                <div class="tech-pattern">
                    <div class="pattern-grid">
                        <i data-lucide="code-2" class="pattern-icon"></i>
                        <i data-lucide="git-branch" class="pattern-icon"></i>
                        <i data-lucide="terminal" class="pattern-icon"></i>
                        <i data-lucide="workflow" class="pattern-icon"></i>
                        <i data-lucide="code-2" class="pattern-icon"></i>
                        <i data-lucide="git-branch" class="pattern-icon"></i>
                        <i data-lucide="terminal" class="pattern-icon"></i>
                        <i data-lucide="workflow" class="pattern-icon"></i>
                        <i data-lucide="code-2" class="pattern-icon"></i>
                        <i data-lucide="git-branch" class="pattern-icon"></i>
                        <i data-lucide="terminal" class="pattern-icon"></i>
                        <i data-lucide="workflow" class="pattern-icon"></i>
                        <i data-lucide="code-2" class="pattern-icon"></i>
                        <i data-lucide="git-branch" class="pattern-icon"></i>
                        <i data-lucide="terminal" class="pattern-icon"></i>
                        <i data-lucide="workflow" class="pattern-icon"></i>
                        <i data-lucide="code-2" class="pattern-icon"></i>
                        <i data-lucide="git-branch" class="pattern-icon"></i>
                        <i data-lucide="terminal" class="pattern-icon"></i>
                        <i data-lucide="workflow" class="pattern-icon"></i>
                        <i data-lucide="code-2" class="pattern-icon"></i>
                        <i data-lucide="git-branch" class="pattern-icon"></i>
                        <i data-lucide="terminal" class="pattern-icon"></i>
                        <i data-lucide="workflow" class="pattern-icon"></i>
                    </div>
                </div>

                <div class="form-wrapper">
                    <!-- Login Form -->
                    <div id="loginForm">
                        <div class="header">
                            <h2 class="title">SIGN IN</h2>
                            <p class="subtitle">TO ACCESS THE PORTAL</p>
                        </div>

                        <form class="form" onsubmit="handleLogin(event)">
                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="user" class="input-icon"></i>
                                    <input 
                                        type="text" 
                                        id="login-username" 
                                        class="input" 
                                        placeholder="Enter User Name Here"
                                        required
                                    />
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="lock" class="input-icon"></i>
                                    <input 
                                        type="password" 
                                        id="login-password" 
                                        class="input password-input" 
                                        placeholder="Enter Password"
                                        required
                                    />
                                    <button type="button" class="toggle-password" onclick="togglePassword('login-password')">
                                        <i data-lucide="eye" class="eye-icon"></i>
                                    </button>
                                </div>
                            </div>

                            <button type="submit" class="submit-btn">Login</button>

                            <div class="forgot-password-wrapper">
                                <button type="button" class="forgot-password-btn" onclick="showForgotPassword()">
                                    Forgot Password?
                                </button>
                            </div>

                            <div class="divider">
                                <div class="switch-form">
                                    <span class="switch-text">New user? </span>
                                    <button type="button" class="switch-btn" onclick="showSignUp()">
                                        Sign Up
                                    </button>
                                </div>
                            </div>
                        </form>

                        <div class="copyright">
                            Copyright © 2026 Engineering Workflow Portal. All rights reserved.
                        </div>
                    </div>

                    <!-- Sign Up Form -->
                    <div id="signupForm" style="display: none;">
                        <div class="header">
                            <h2 class="title">SIGN UP</h2>
                            <p class="subtitle">CREATE YOUR ACCOUNT</p>
                        </div>

                        <form class="form" onsubmit="handleSignUp(event)">
                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="user" class="input-icon"></i>
                                    <input 
                                        type="text" 
                                        id="signup-username" 
                                        class="input" 
                                        placeholder="Username"
                                        required
                                    />
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="id-card" class="input-icon"></i>
                                    <input 
                                        type="text" 
                                        id="signup-userid" 
                                        class="input" 
                                        placeholder="User ID"
                                        required
                                    />
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="lock" class="input-icon"></i>
                                    <input 
                                        type="password" 
                                        id="signup-password" 
                                        class="input password-input" 
                                        placeholder="Password"
                                        required
                                    />
                                    <button type="button" class="toggle-password" onclick="togglePassword('signup-password')">
                                        <i data-lucide="eye" class="eye-icon"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="mail" class="input-icon"></i>
                                    <input 
                                        type="email" 
                                        id="signup-email" 
                                        class="input" 
                                        placeholder="Email"
                                        required
                                    />
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="input-wrapper">
                                    <i data-lucide="user-circle" class="input-icon"></i>
                                    <select id="signup-role" class="input select-input" required>
                                        <option value="">Select Role</option>
                                        <option value="developer">Developer</option>
                                        <option value="qa">QA Engineer</option>
                                        <option value="devops">DevOps Engineer</option>
                                        <option value="manager">Project Manager</option>
                                        <option value="admin">Admin</option>
                                    </select>
                                    <i data-lucide="chevron-down" class="select-arrow"></i>
                                </div>
                            </div>

                            <button type="submit" class="submit-btn">Sign Up</button>

                            <div class="divider">
                                <div class="switch-form">
                                    <span class="switch-text">Already have an account? </span>
                                    <button type="button" class="switch-btn" onclick="showLogin()">
                                        Login
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Forgot Password Modal -->
        <div id="forgotPasswordModal" class="modal">
            <div class="modal-content">
                <button class="modal-close" onclick="hideForgotPassword()">
                    <i data-lucide="x"></i>
                </button>

                <div class="modal-icon">
                    <div class="modal-icon-circle">
                        <i data-lucide="mail"></i>
                    </div>
                </div>

                <h2 class="modal-title">Forgot Password?</h2>
                <p class="modal-subtitle">
                    Enter your email address and we'll send you a link to reset your password.
                </p>

                <form class="form" onsubmit="handleForgotPassword(event)">
                    <div class="form-group">
                        <div class="input-wrapper">
                            <i data-lucide="mail" class="input-icon"></i>
                            <input 
                                type="email" 
                                id="forgot-email" 
                                class="input" 
                                placeholder="Enter your email"
                                required
                            />
                        </div>
                    </div>

                    <button type="submit" class="submit-btn">Submit</button>
                    <button type="button" class="cancel-btn" onclick="hideForgotPassword()">Cancel</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Toggle password visibility
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = input.parentElement.querySelector('.eye-icon');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }

        // Show/hide forms
        function showSignUp() {
            document.getElementById('loginForm').style.display = 'none';
            document.getElementById('signupForm').style.display = 'block';
            document.getElementById('leftContent').innerHTML = '<h1>CREATE ACCOUNT</h1><p>Join the Engineering Workflow Portal</p>';
            lucide.createIcons();
        }

        function showLogin() {
            document.getElementById('signupForm').style.display = 'none';
            document.getElementById('loginForm').style.display = 'block';
            document.getElementById('leftContent').innerHTML = '<h1>WELCOME BACK !</h1><p>Enter your ID and Password to continue</p>';
            lucide.createIcons();
        }

        function showForgotPassword() {
            document.getElementById('forgotPasswordModal').style.display = 'flex';
            lucide.createIcons();
        }

        function hideForgotPassword() {
            document.getElementById('forgotPasswordModal').style.display = 'none';
            document.getElementById('forgot-email').value = '';
        }

        // Form handlers
        function handleLogin(e) {
            e.preventDefault();
            const username = document.getElementById('login-username').value;
            const password = document.getElementById('login-password').value;
            console.log('Login:', { username, password });
            alert('Login submitted! Check console for details.');
        }

        function handleSignUp(e) {
            e.preventDefault();
            const formData = {
                username: document.getElementById('signup-username').value,
                userId: document.getElementById('signup-userid').value,
                password: document.getElementById('signup-password').value,
                email: document.getElementById('signup-email').value,
                role: document.getElementById('signup-role').value
            };
            console.log('Sign Up:', formData);
            alert('Sign up submitted! Check console for details.');
        }

        function handleForgotPassword(e) {
            e.preventDefault();
            const email = document.getElementById('forgot-email').value;
            console.log('Password reset requested for:', email);
            alert('Password reset link sent to ' + email);
            hideForgotPassword();
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('forgotPasswordModal');
            if (event.target === modal) {
                hideForgotPassword();
            }
        }
    </script>
</body>
</html>


**********************************************************************

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    padding: 1rem;
}

/* Auth Card - Split Screen */
.auth-card {
    width: 100%;
    max-width: 75rem;
    background: white;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    display: flex;
    min-height: 600px;
    position: relative;
    overflow: hidden;
}

/* Left Side - Welcome */
.left-side {
    width: 50%;
    background: white;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
}

.logo-section {
    margin-bottom: 3rem;
}

.logo-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
}

.logo-circle {
    background: black;
    padding: 0.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.logo-circle-app {
    background: linear-gradient(135deg, #2563eb 0%, #1e3a8a 100%);
    padding: 0.75rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.3);
}

.logo-icon {
    width: 2rem;
    height: 2rem;
    color: white;
}

.logo-icon-small {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
}

.logo-icon-tiny {
    width: 1.25rem;
    height: 1.25rem;
    color: white;
}

.sso-text {
    display: flex;
    flex-direction: column;
}

.sso-title {
    color: #2563eb;
    font-weight: 600;
    font-size: 0.875rem;
}

.sso-subtitle {
    color: #2563eb;
    font-size: 0.75rem;
}

.app-name-text {
    display: flex;
    flex-direction: column;
}

.app-title {
    color: #2563eb;
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1.2;
}

.app-subtitle {
    color: #60a5fa;
    font-size: 0.875rem;
    font-weight: 500;
}

.welcome-content h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2563eb;
    margin-bottom: 1rem;
}

.welcome-content p {
    font-size: 1.125rem;
    color: #60a5fa;
}

.tech-decoration {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    opacity: 0.1;
    display: flex;
    gap: 1rem;
}

.tech-decoration i {
    width: 3rem;
    height: 3rem;
    color: #2563eb;
}

/* Right Side - Form */
.right-side {
    width: 50%;
    background: linear-gradient(135deg, #2563eb 0%, #1e40af 50%, #1e3a8a 100%);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
}

.tech-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    padding: 2rem;
}

.pattern-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    height: 100%;
}

.pattern-icon {
    width: 100%;
    height: 100%;
    color: white;
}

.form-wrapper {
    position: relative;
    z-index: 10;
}

/* Header */
.header {
    text-align: center;
    margin-bottom: 2rem;
}

.title {
    font-size: 1.875rem;
    font-weight: 700;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
}

.subtitle {
    color: #6b7280;
    font-size: 1rem;
}

/* Form */
.form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.input-icon {
    position: absolute;
    left: 1rem;
    color: #9ca3af;
    width: 1.25rem;
    height: 1.25rem;
    pointer-events: none;
}

.input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 3rem;
    border: 1px solid #d1d5db;
    border-radius: 0.75rem;
    font-size: 1rem;
    outline: none;
    transition: all 0.2s;
    background: white;
}

.input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.password-input {
    padding-right: 3rem;
}

.toggle-password {
    position: absolute;
    right: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #9ca3af;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: color 0.2s;
}

.toggle-password:hover {
    color: #6b7280;
}

.eye-icon {
    width: 1.25rem;
    height: 1.25rem;
}

.select-input {
    appearance: none;
    cursor: pointer;
    padding-right: 2.5rem;
}

.select-arrow {
    position: absolute;
    right: 1rem;
    color: #9ca3af;
    width: 1.25rem;
    height: 1.25rem;
    pointer-events: none;
}

/* Forgot Password */
.forgot-password-wrapper {
    display: flex;
    justify-content: center;
}

.forgot-password-btn {
    background: none;
    border: none;
    color: white;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
    text-decoration: underline;
}

.forgot-password-btn:hover {
    color: #bfdbfe;
}

/* Submit Button */
.submit-btn {
    width: 100%;
    padding: 0.75rem;
    background: #22c55e;
    color: white;
    border: none;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 10px 15px -3px rgba(34, 197, 94, 0.3);
}

.submit-btn:hover {
    background: #16a34a;
}

/* Divider */
.divider {
    margin: 1rem 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.3);
}

.divider-text {
    display: none;
}

/* Switch Form */
.switch-form {
    text-align: center;
}

.switch-text {
    color: white;
    font-size: 0.875rem;
}

.switch-btn {
    background: none;
    border: none;
    color: #4ade80;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
    text-decoration: underline;
}

.switch-btn:hover {
    color: #86efac;
}

/* Copyright */
.copyright {
    margin-top: 3rem;
    text-align: center;
    font-size: 0.75rem;
    color: #bfdbfe;
}

/* Modal */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 50;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}

.modal-content {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    padding: 2rem;
    width: 100%;
    max-width: 28rem;
    position: relative;
    animation: modalFadeIn 0.2s ease-out;
}

@keyframes modalFadeIn {
    from {
        opacity: 0;
        transform: scale(0.95);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

.modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: #9ca3af;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: color 0.2s;
}

.modal-close:hover {
    color: #6b7280;
}

.modal-close i {
    width: 1.5rem;
    height: 1.5rem;
}

.modal-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
}

.modal-icon-circle {
    background: #2563eb;
    padding: 1rem;
    border-radius: 50%;
}

.modal-icon-circle i {
    width: 2.5rem;
    height: 2.5rem;
    color: white;
}

.modal-title {
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
    color: #2563eb;
    margin-bottom: 0.5rem;
}

.modal-subtitle {
    text-align: center;
    color: #6b7280;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
}

.cancel-btn {
    width: 100%;
    padding: 0.75rem;
    background: none;
    color: #6b7280;
    border: none;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.5rem;
}

.cancel-btn:hover {
    color: #374151;
}

/* Responsive */
@media (max-width: 1024px) {
    .auth-card {
        flex-direction: column;
    }
    
    .left-side,
    .right-side {
        width: 100%;
    }
    
    .left-side {
        padding: 2rem;
    }
    
    .right-side {
        padding: 2rem;
    }
    
    .welcome-content h1 {
        font-size: 2rem;
    }
}

@media (max-width: 640px) {
    .left-side,
    .right-side {
        padding: 1.5rem;
    }

    .title {
        font-size: 1.5rem;
    }

    .form {
        gap: 1rem;
    }
}
